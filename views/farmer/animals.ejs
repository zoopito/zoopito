<% layout("layouts/boilerplate") %>

<div class="min-h-screen bg-gradient-to-br from-gray-50 to-green-50 dark:from-gray-900 dark:to-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <!-- Breadcrumb -->
        <nav class="flex mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li><a href="/farmer/dashboard" class="text-gray-600 hover:text-green-600"><i class="fas fa-home mr-2"></i>Dashboard</a></li>
                <li><i class="fas fa-chevron-right text-gray-400 text-sm"></i></li>
                <li><span class="text-gray-500">My Animals</span></li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="flex flex-wrap justify-between items-center mb-6 gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white">My Animals</h1>
                <p class="text-gray-600 dark:text-gray-400 mt-1">Manage and track all your livestock</p>
            </div>
            <div class="flex gap-3">
                <button onclick="window.location.href='/farmer/dashboard'" class="px-4 py-2 border rounded-lg hover:bg-gray-50 transition">
                    <i class="fas fa-arrow-left mr-2"></i>Back to Dashboard
                </button>
            </div>
        </div>

        <!-- Stats Summary -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Total Animals</p>
                        <p class="text-2xl font-bold text-gray-900"><%= animals.length %></p>
                    </div>
                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-paw text-blue-600"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Vaccinated</p>
                        <p class="text-2xl font-bold text-green-600"><%= animals.filter(a => a.vaccinationSummary?.isUpToDate).length %></p>
                    </div>
                    <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-check-circle text-green-600"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Pregnant</p>
                        <p class="text-2xl font-bold text-pink-600"><%= animals.filter(a => a.pregnancyStatus?.isPregnant).length %></p>
                    </div>
                    <div class="w-10 h-10 bg-pink-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-baby-carriage text-pink-600"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Due for Vaccination</p>
                        <p class="text-2xl font-bold text-yellow-600"><%= animals.filter(a => !a.vaccinationSummary?.isUpToDate).length %></p>
                    </div>
                    <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-clock text-yellow-600"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search & Filter -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow mb-6 p-4">
            <div class="flex flex-wrap gap-4">
                <div class="flex-1 min-w-[200px]">
                    <div class="relative">
                        <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
                        <input type="text" id="searchInput" placeholder="Search by name, tag number, or type..." 
                               class="w-full pl-10 pr-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500">
                    </div>
                </div>
                <select id="typeFilter" class="px-4 py-2 border rounded-lg">
                    <option value="all">All Types</option>
                    <option value="Cow">Cow</option>
                    <option value="Buffalo">Buffalo</option>
                    <option value="Goat">Goat</option>
                    <option value="Sheep">Sheep</option>
                    <option value="Poultry">Poultry</option>
                    <option value="Other">Other</option>
                </select>
                <select id="statusFilter" class="px-4 py-2 border rounded-lg">
                    <option value="all">All Status</option>
                    <option value="vaccinated">Vaccinated</option>
                    <option value="pending">Pending Vaccination</option>
                    <option value="pregnant">Pregnant</option>
                </select>
                <button onclick="resetFilters()" class="px-4 py-2 bg-gray-100 rounded-lg hover:bg-gray-200">
                    <i class="fas fa-redo mr-2"></i>Reset
                </button>
            </div>
        </div>

        <!-- Animals Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% animals.forEach(animal => { %>
                <div class="animal-card bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-all">
                    <!-- Animal Image/Header -->
                    <div class="relative h-40 bg-gradient-to-r from-green-400 to-blue-500">
                        <% if (animal.photos && animal.photos.front && animal.photos.front.url) { %>
                            <img src="<%= animal.photos.front.url %>" alt="<%= animal.name %>" class="w-full h-full object-cover">
                        <% } else { %>
                            <div class="flex items-center justify-center h-full">
                                <i class="fas fa-paw text-white text-6xl opacity-50"></i>
                            </div>
                        <% } %>
                        
                        <!-- Status Badges -->
                        <div class="absolute top-2 right-2 flex gap-1">
                            <% if (animal.pregnancyStatus?.isPregnant) { %>
                                <span class="px-2 py-1 bg-pink-500 text-white text-xs rounded-full">
                                    <i class="fas fa-baby-carriage mr-1"></i>Pregnant
                                </span>
                            <% } %>
                            <% if (!animal.vaccinationSummary?.isUpToDate) { %>
                                <span class="px-2 py-1 bg-yellow-500 text-white text-xs rounded-full">
                                    <i class="fas fa-clock mr-1"></i>Due Soon
                                </span>
                            <% } %>
                        </div>
                        
                        <!-- Health Status Indicator -->
                        <div class="absolute bottom-2 left-2">
                            <span class="px-2 py-1 rounded-full text-xs font-semibold 
                                <%= animal.healthStatus?.currentStatus === 'Healthy' ? 'bg-green-500 text-white' : 
                                   animal.healthStatus?.currentStatus === 'Under Treatment' ? 'bg-red-500 text-white' : 
                                   'bg-yellow-500 text-white' %>">
                                <i class="fas fa-heartbeat mr-1"></i>
                                <%= animal.healthStatus?.currentStatus || 'Healthy' %>
                            </span>
                        </div>
                    </div>
                    
                    <div class="p-5">
                        <div class="flex justify-between items-start mb-2">
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 dark:text-white">
                                    <%= animal.name || 'Unnamed Animal' %>
                                </h3>
                                <p class="text-sm text-gray-500">
                                    <i class="fas fa-tag mr-1"></i>
                                    <%= animal.tagNumber || 'No Tag' %>
                                </p>
                            </div>
                            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-xs rounded-full font-semibold">
                                <%= animal.animalType %>
                            </span>
                        </div>
                        
                        <div class="grid grid-cols-2 gap-2 text-sm mb-4">
                            <div>
                                <p class="text-gray-500">Breed</p>
                                <p class="font-medium"><%= animal.breed || 'Unknown' %></p>
                            </div>
                            <div>
                                <p class="text-gray-500">Age</p>
                                <p class="font-medium"><%= animal.age?.value || 'N/A' %> <%= animal.age?.unit || '' %></p>
                            </div>
                            <div>
                                <p class="text-gray-500">Gender</p>
                                <p class="font-medium"><%= animal.gender || 'Unknown' %></p>
                            </div>
                            <div>
                                <p class="text-gray-500">ID</p>
                                <p class="font-medium text-xs"><%= animal.uniqueAnimalId || 'N/A' %></p>
                            </div>
                        </div>
                        
                        <!-- Vaccination Progress -->
                        <div class="mb-4">
                            <div class="flex justify-between text-xs mb-1">
                                <span class="text-gray-500">Vaccination Status</span>
                                <span class="<%= animal.vaccinationSummary?.isUpToDate ? 'text-green-600' : 'text-yellow-600' %>">
                                    <%= animal.vaccinationSummary?.isUpToDate ? 'Up to Date' : 'Pending' %>
                                </span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-2">
                                <div class="bg-green-500 h-2 rounded-full" style="width: <%= animal.vaccinationSummary?.totalVaccinations ? Math.min((animal.vaccinationSummary.totalVaccinations / 5) * 100, 100) : 0 %>%"></div>
                            </div>
                            <p class="text-xs text-gray-400 mt-1">
                                <%= animal.vaccinationSummary?.totalVaccinations || 0 %> vaccinations completed
                            </p>
                        </div>
                        
                        <!-- Next Vaccination -->
                        <% if (animal.nextVaccination) { %>
                            <div class="mb-4 p-2 bg-yellow-50 dark:bg-yellow-900/20 rounded-lg">
                                <p class="text-xs text-yellow-700 dark:text-yellow-300">
                                    <i class="fas fa-calendar-alt mr-1"></i>
                                    Next vaccination due: <%= moment(animal.nextVaccination.nextDueDate).format('DD MMM YYYY') %>
                                    (<%= moment(animal.nextVaccination.nextDueDate).fromNow() %>)
                                </p>
                            </div>
                        <% } %>
                        
                        <!-- Actions -->
                        <div class="flex gap-2">
                            <a href="/farmer/animal/<%= animal._id %>" 
                               class="flex-1 text-center bg-blue-600 text-white px-3 py-2 rounded-lg hover:bg-blue-700 transition">
                                <i class="fas fa-eye mr-1"></i>View Details
                            </a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

        <!-- Empty State -->
        <% if (animals.length === 0) { %>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow p-12 text-center">
                <i class="fas fa-paw text-6xl text-gray-300 mb-4"></i>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">No Animals Added Yet</h3>
                <p class="text-gray-500">You haven't added any animals to your farm.</p>
                <p class="text-sm text-gray-400 mt-2">Contact your sales executive to add animals.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
// Search and filter functionality
document.getElementById('searchInput').addEventListener('input', filterAnimals);
document.getElementById('typeFilter').addEventListener('change', filterAnimals);
document.getElementById('statusFilter').addEventListener('change', filterAnimals);

function filterAnimals() {
    const searchTerm = document.getElementById('searchInput').value.toLowerCase();
    const typeFilter = document.getElementById('typeFilter').value;
    const statusFilter = document.getElementById('statusFilter').value;
    
    const cards = document.querySelectorAll('.animal-card');
    
    cards.forEach(card => {
        const text = card.innerText.toLowerCase();
        const type = card.querySelector('.bg-blue-100')?.innerText || '';
        const isVaccinated = text.includes('up to date');
        const isPregnant = text.includes('pregnant');
        
        let matchesSearch = text.includes(searchTerm);
        let matchesType = typeFilter === 'all' || type.includes(typeFilter);
        let matchesStatus = true;
        
        if (statusFilter === 'vaccinated') {
            matchesStatus = isVaccinated;
        } else if (statusFilter === 'pending') {
            matchesStatus = !isVaccinated && text.includes('pending');
        } else if (statusFilter === 'pregnant') {
            matchesStatus = isPregnant;
        }
        
        if (matchesSearch && matchesType && matchesStatus) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

function resetFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('typeFilter').value = 'all';
    document.getElementById('statusFilter').value = 'all';
    filterAnimals();
}
</script>