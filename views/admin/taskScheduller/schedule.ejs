                            <i class="fas fa-check-circle"></i>
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <!-- Farmer Footer Actions -->
            <div class="px-4 md:px-6 py-3 bg-gray-50 dark:bg-gray-700 flex flex-wrap justify-between items-center gap-2">
              <div class="flex space-x-2">
                <button onclick="selectFarmerVaccinations('<%= group.farmer?._id %>')" 
                        class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-lg text-xs hover:bg-blue-200 transition-colors">
                  <i class="fas fa-check-double mr-1"></i>
                  Select All
                </button>
                <button onclick="assignFarmerToParavet('<%= group.farmer?._id %>')" 
                        class="px-3 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-lg text-xs hover:bg-purple-200 transition-colors">
                  <i class="fas fa-user-md mr-1"></i>
                  Assign Paravet to Selected
                </button>
                <a href="/vaccination/new?farmerId=<%= group.farmer?._id %>" 
                   class="px-3 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-lg text-xs hover:bg-green-200 transition-colors">
                  <i class="fas fa-plus mr-1"></i>
                  Add Vaccination
                </a>
              </div>
              <div class="text-xs text-gray-500 dark:text-gray-400">
                <%= group.vaccinations.length %> vaccination(s)
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>

    <!-- Pagination -->
    <% if (pagination && pagination.pages && pagination.pages > 1) { %>
      <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="text-sm text-gray-700 dark:text-gray-300">
          Showing <span class="font-medium"><%= (pagination.page - 1) * pagination.limit + 1 %></span> to 
          <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span> of 
          <span class="font-medium"><%= pagination.total %></span> results
        </div>
        <div class="flex flex-wrap justify-center gap-1">
          <% if (pagination.page > 1) { %>
            <a href="?<%= new URLSearchParams({...(filters || {}), page: pagination.page - 1}).toString() %>" 
               class="px-3 py-1 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-sm transition-colors">
              Previous
            </a>
          <% } %>
          
          <% let startPage = Math.max(1, pagination.page - 2); %>
           <% let endPage = Math.min(pagination.pages, pagination.page + 2); %>
           <% if (startPage > 1) {  %>
          
            <a href="?<%= new URLSearchParams({...(filters || {}), page: 1}).toString() %>" 
               class="px-3 py-1 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-sm">1</a>
            <% if (startPage > 2) { %>
              <span class="px-2 text-gray-500">...</span>
            <% } %>
          <% } %>
          
          <% for(let i = startPage; i <= endPage; i++) { %>
            <% if (i === pagination.page) { %>
              <span class="px-3 py-1 bg-blue-600 text-white rounded-lg text-sm"><%= i %></span>
            <% } else { %>
              <a href="?<%= new URLSearchParams({...(filters || {}), page: i}).toString() %>" 
                 class="px-3 py-1 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-sm"><%= i %></a>
            <% } %>
          <% } %>
          
          <% if (endPage < pagination.pages) { %>
            <% if (endPage < pagination.pages - 1) { %>
              <span class="px-2 text-gray-500">...</span>
            <% } %>
            <a href="?<%= new URLSearchParams({...(filters || {}), page: pagination.pages}).toString() %>" 
               class="px-3 py-1 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-sm"><%= pagination.pages %></a>
          <% } %>
          
          <% if (pagination.page < pagination.pages) { %>
            <a href="?<%= new URLSearchParams({...(filters || {}), page: pagination.page + 1}).toString() %>" 
               class="px-3 py-1 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-sm">
              Next
            </a>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
</div>

