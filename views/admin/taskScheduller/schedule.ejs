<% layout("layouts/boilerplate") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
            <i class="fas fa-calendar-check mr-3 text-blue-500"></i>
            Vaccination Schedule
          </h1>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
            Manage all pending and scheduled vaccinations
          </p>
        </div>
        <div class="flex space-x-3">
          <button onclick="openBulkAssignModal()" 
                  class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg flex items-center transition-colors">
            <i class="fas fa-tasks mr-2"></i>
            Bulk Assign Paravet
          </button>
          <a href="/vaccination/export/schedule?<%= new URLSearchParams(filters).toString() %>" 
             class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg flex items-center transition-colors">
            <i class="fas fa-download mr-2"></i>
            Export CSV
          </a>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 md:gap-6 mb-8">
      <div class="stat-card bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 border-l-4 border-yellow-500 hover:shadow-lg transition-all">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Total Pending</p>
            <p class="text-2xl font-bold text-yellow-600 dark:text-yellow-400"><%= stats.totalPending || 0 %></p>
          </div>
          <div class="w-10 h-10 bg-yellow-100 dark:bg-yellow-900/30 rounded-full flex items-center justify-center">
            <i class="fas fa-clock text-yellow-600 dark:text-yellow-400"></i>
          </div>
        </div>
      </div>

      <div class="stat-card bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 border-l-4 border-blue-500 hover:shadow-lg transition-all">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Today's Schedule</p>
            <p class="text-2xl font-bold text-blue-600 dark:text-blue-400"><%= stats.todayScheduled || 0 %></p>
          </div>
          <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center">
            <i class="fas fa-calendar-day text-blue-600 dark:text-blue-400"></i>
          </div>
        </div>
      </div>

      <div class="stat-card bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 border-l-4 border-red-500 hover:shadow-lg transition-all">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Overdue</p>
            <p class="text-2xl font-bold text-red-600 dark:text-red-400"><%= stats.totalOverdue || 0 %></p>
          </div>
          <div class="w-10 h-10 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center">
            <i class="fas fa-exclamation-triangle text-red-600 dark:text-red-400"></i>
          </div>
        </div>
      </div>

      <div class="stat-card bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 border-l-4 border-green-500 hover:shadow-lg transition-all">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Completed</p>
            <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= stats.totalCompleted || 0 %></p>
          </div>
          <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center">
            <i class="fas fa-check-circle text-green-600 dark:text-green-400"></i>
          </div>
        </div>
      </div>

      <div class="stat-card bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 border-l-4 border-purple-500 hover:shadow-lg transition-all">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Untagged Animals</p>
            <p class="text-2xl font-bold text-purple-600 dark:text-purple-400"><%= tagStats.untagged || 0 %></p>
          </div>
          <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-full flex items-center justify-center">
            <i class="fas fa-tag text-purple-600 dark:text-purple-400"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters Section -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 md:p-6 mb-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4 gap-2">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
          <i class="fas fa-filter mr-2 text-blue-500"></i>
          Filters
        </h2>
        <button onclick="clearFilters()" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors">
          Clear All Filters
        </button>
      </div>

      <form id="filterForm" method="GET" action="/vaccination/schedule" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Area</label>
          <select name="area" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Areas</option>
            <% (areas || []).forEach(area => { %>
              <option value="<%= area.village || area.taluka || area.district %>" 
                      <%= (filters.area === (area.village || area.taluka || area.district)) ? 'selected' : '' %>>
                <%= area.village || area.taluka || area.district || 'N/A' %>
              </option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Status</label>
          <select name="status" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Status</option>
            <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="Scheduled" <%= filters.status === 'Scheduled' ? 'selected' : '' %>>Scheduled</option>
            <option value="Payment Pending" <%= filters.status === 'Payment Pending' ? 'selected' : '' %>>Payment Pending</option>
            <option value="overdue" <%= filters.status === 'overdue' ? 'selected' : '' %>>Overdue</option>
            <option value="today" <%= filters.status === 'today' ? 'selected' : '' %>>Today</option>
            <option value="week" <%= filters.status === 'week' ? 'selected' : '' %>>This Week</option>
            <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Due Date</label>
          <select name="dueDate" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">Any Time</option>
            <option value="overdue" <%= filters.dueDate === 'overdue' ? 'selected' : '' %>>Overdue</option>
            <option value="today" <%= filters.dueDate === 'today' ? 'selected' : '' %>>Today</option>
            <option value="week" <%= filters.dueDate === 'week' ? 'selected' : '' %>>This Week</option>
            <option value="month" <%= filters.dueDate === 'month' ? 'selected' : '' %>>This Month</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Species</label>
          <select name="species" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Species</option>
            <option value="Cow" <%= filters.species === 'Cow' ? 'selected' : '' %>>Cow</option>
            <option value="Buffalo" <%= filters.species === 'Buffalo' ? 'selected' : '' %>>Buffalo</option>
            <option value="Goat" <%= filters.species === 'Goat' ? 'selected' : '' %>>Goat</option>
            <option value="Sheep" <%= filters.species === 'Sheep' ? 'selected' : '' %>>Sheep</option>
            <option value="Dog" <%= filters.species === 'Dog' ? 'selected' : '' %>>Dog</option>
            <option value="Cat" <%= filters.species === 'Cat' ? 'selected' : '' %>>Cat</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tag Status</label>
          <select name="tagStatus" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All</option>
            <option value="tagged" <%= filters.tagStatus === 'tagged' ? 'selected' : '' %>>Tagged</option>
            <option value="untagged" <%= filters.tagStatus === 'untagged' ? 'selected' : '' %>>Untagged</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Assigned To</label>
          <select name="paravet" class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Paravets</option>
            <option value="unassigned" <%= filters.paravet === 'unassigned' ? 'selected' : '' %>>Unassigned</option>
            <% (paravets || []).forEach(p => { %>
              <option value="<%= p._id %>" <%= filters.paravet === p._id.toString() ? 'selected' : '' %>>
                <%= p.user?.name || 'Unknown' %>
              </option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Search</label>
          <input type="text" name="search" value="<%= filters.search || '' %>" 
                 placeholder="Farmer/Animal/Vaccine..."
                 class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        </div>

        <div class="flex items-end">
          <button type="submit" class="w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors">
            <i class="fas fa-search mr-2"></i>
            Apply Filters
          </button>
        </div>
      </form>
    </div>

    <!-- Bulk Selection Bar -->
    <div id="bulkSelectionBar" class="fixed bottom-4 right-4 bg-blue-600 text-white px-4 py-3 rounded-lg shadow-lg z-50 hidden">
      <div class="flex items-center space-x-4">
        <span id="selectedCount">0</span>
        <span>selected</span>
        <button onclick="openBulkAssignModal()" class="bg-white text-blue-600 px-3 py-1 rounded-lg hover:bg-gray-100">
          Assign Paravet
        </button>
        <button onclick="clearBulkSelection()" class="text-white/80 hover:text-white">
          <i class="fas fa-times"></i>
        </button>
      </div>
    </div>

    <!-- UNTAGGED ANIMALS ALERT SECTION -->
    <% if (untaggedAnimals && untaggedAnimals.length > 0) { %>
      <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-xl p-4 mb-6">
        <div class="flex items-start justify-between flex-wrap gap-3">
          <div class="flex items-start">
            <i class="fas fa-tag text-yellow-600 dark:text-yellow-400 mt-1 mr-3"></i>
            <div>
              <h3 class="text-sm font-semibold text-yellow-800 dark:text-yellow-300">
                Animals Need Tagging (<%= untaggedAnimals.length %>)
              </h3>
              <p class="text-xs text-yellow-700 dark:text-yellow-400 mt-1">
                These animals don't have tag numbers. Please assign tags to them.
              </p>
            </div>
          </div>
          <button onclick="showUntaggedAnimalsModal()" class="px-3 py-1 bg-yellow-600 hover:bg-yellow-700 text-white rounded-lg text-sm transition-colors">
            View All
          </button>
        </div>
      </div>
    <% } %>

    <!-- ANIMALS NEEDING VACCINATION ALERT SECTION -->
    <% if (animalsNeedingVaccination && animalsNeedingVaccination.length > 0) { %>
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-4 mb-6">
        <div class="flex items-start justify-between flex-wrap gap-3">
          <div class="flex items-start">
            <i class="fas fa-syringe text-red-600 dark:text-red-400 mt-1 mr-3"></i>
            <div>
              <h3 class="text-sm font-semibold text-red-800 dark:text-red-300">
                Animals Need Vaccination (<%= animalsNeedingVaccination.length %>)
              </h3>
              <p class="text-xs text-red-700 dark:text-red-400 mt-1">
                These animals haven't received their required vaccinations.
              </p>
              <div class="mt-3 flex flex-wrap gap-2 max-h-32 overflow-y-auto">
                <% animalsNeedingVaccination.slice(0, 10).forEach(animal => { %>
                  <label class="inline-flex items-center cursor-pointer">
                    <input type="checkbox" class="needing-animal-checkbox mr-1.5 rounded border-gray-300 dark:border-gray-600" value="<%= animal._id %>" data-name="<%= animal.name || 'Unnamed' %>">
                    <span class="inline-flex items-center px-2 py-1 bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300 rounded-lg text-xs">
                      <i class="fas fa-paw mr-1"></i>
                      <%= animal.name || 'Unnamed' %> 
                      <span class="ml-1 bg-red-200 dark:bg-red-800 px-1 rounded-full text-[10px]"><%= animal.pendingCount || 1 %> due</span>
                    </span>
                  </label>
                <% }) %>
                <% if (animalsNeedingVaccination.length > 10) { %>
                  <span class="text-xs text-red-600 dark:text-red-400">+<%= animalsNeedingVaccination.length - 10 %> more</span>
                <% } %>
              </div>
            </div>
          </div>
          <div class="flex space-x-2">
            <button onclick="selectAllNeedingAnimals()" 
                    class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-lg text-sm hover:bg-blue-200 dark:hover:bg-blue-800/50 transition-colors">
              Select All
            </button>
            <button onclick="openBulkScheduleNeedingModal()" 
                    class="px-3 py-1 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm flex items-center transition-colors">
              <i class="fas fa-calendar-plus mr-1"></i>
              Schedule Selected
            </button>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Main Content - Grouped by Farmer -->
    <div class="space-y-6">
      <% if (!groupedVaccinations || groupedVaccinations.length === 0) { %>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-12 text-center">
          <i class="fas fa-calendar-check text-6xl text-gray-400 dark:text-gray-500 mb-4"></i>
          <h3 class="text-xl font-medium text-gray-900 dark:text-white mb-2">No Vaccinations Found</h3>
          <p class="text-gray-500 dark:text-gray-400">No vaccinations match your current filters.</p>
          <a href="/vaccination/new" class="inline-block mt-4 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors">
            <i class="fas fa-plus mr-2"></i>
            Add New Vaccination
          </a>
        </div>
      <% } else { %>
        <% groupedVaccinations.forEach(group => { %>
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
            <!-- Farmer Header -->
            <div class="px-4 md:px-6 py-4 bg-gradient-to-r from-blue-500 to-green-500">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                <div class="flex items-center space-x-3">
                  <div class="w-8 h-8 md:w-10 md:h-10 bg-white/20 rounded-full flex items-center justify-center">
                    <i class="fas fa-user text-sm md:text-base text-white"></i>
                  </div>
                  <div>
                    <h2 class="text-base md:text-lg font-semibold text-white">
                      <%= group.farmer?.name || 'Unknown Farmer' %>
                      <span class="text-xs md:text-sm bg-white/20 px-2 py-0.5 rounded-full ml-2">
                        <%= group.farmer?.uniqueFarmerId || 'No ID' %>
                      </span>
                    </h2>
                    <p class="text-xs md:text-sm text-white/80">
                      <i class="fas fa-phone mr-1"></i> <%= group.farmer?.mobileNumber || 'N/A' %> |
                      <i class="fas fa-map-marker-alt ml-2 mr-1"></i> 
                      <%= group.farmer?.address?.village || 'N/A' %>
                    </p>
                  </div>
                </div>
                <div class="flex items-center space-x-3">
                  <button onclick="openFarmerAssignModal('<%= group.farmer?._id %>')" 
                          class="bg-white/20 hover:bg-white/30 text-white px-3 py-1 rounded-lg text-sm flex items-center transition-colors">
                    <i class="fas fa-user-md mr-1"></i>
                    Assign Paravet to All
                  </button>
                  <span class="bg-white/20 text-white px-2 py-1 rounded-full text-xs">
                    <%= group.pendingCount %> pending / <%= group.totalAnimals %> animals
                  </span>
                </div>
              </div>
            </div>

            <!-- Vaccinations Table -->
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-700">
                  <tr>
                    <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider w-8">
                      <input type="checkbox" id="selectAll_<%= group.farmer?._id %>" onchange="toggleSelectAll('<%= group.farmer?._id %>', this.checked)" class="rounded border-gray-300 dark:border-gray-600">
                    </th>
                    <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Animal</th>
                    <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Vaccine</th>
                    <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Scheduled Date</th>
                    <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Next Due</th>
                    <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Assigned To</th>
                    <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                    <th class="px-3 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <% group.vaccinations.forEach(vac => { %>
                   <% const isOverdue = vac.nextDueDate && new Date(vac.nextDueDate) < new Date(); %>
                   <% const isTodayScheduled = vac.scheduledDate && new Date(vac.scheduledDate).toDateString() === new Date().toDateString(); %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors vaccination-row" data-id="<%= vac._id %>" data-farmer="<%= group.farmer?._id %>">
                  
                      <td class="px-3 py-3">
                        <input type="checkbox" class="vaccination-checkbox farmer-<%= group.farmer?._id %> rounded border-gray-300 dark:border-gray-600" value="<%= vac._id %>">
                      </td>
                      <td class="px-3 py-3">
                        <div class="flex items-center">
                          <div class="w-8 h-8 bg-gray-200 dark:bg-gray-600 rounded-full flex items-center justify-center">
                            <i class="fas fa-paw text-gray-500 dark:text-gray-400 text-xs"></i>
                          </div>
                          <div class="ml-3">
                            <p class="text-sm font-medium text-gray-900 dark:text-white">
                              <%= vac.animal?.name || 'Unnamed' %>
                            </p>
                            <p class="text-xs text-gray-500 dark:text-gray-400">
                              <%= vac.animal?.animalType %> | Tag: <%= vac.animal?.tagNumber || 'No Tag' %>
                            </p>
                          </div>
                        </div>
                      </td>
                      <td class="px-3 py-3">
                        <p class="text-sm font-medium text-gray-900 dark:text-white"><%= vac.vaccine?.name || vac.vaccineName %></p>
                        <p class="text-xs text-gray-500 dark:text-gray-400"><%= vac.vaccine?.diseaseTarget || 'N/A' %></p>
                      </td>
                      <td class="px-3 py-3">
                        <% if (vac.scheduledDate) { %>
                          <div class="text-sm <%= isTodayScheduled ? 'text-green-600 dark:text-green-400 font-semibold' : 'text-gray-700 dark:text-gray-300' %>">
                            <%= new Date(vac.scheduledDate).toLocaleDateString('en-IN') %>
                            <% if (isTodayScheduled) { %>
                              <span class="ml-1 text-xs bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300 px-1 rounded">Today</span>
                            <% } %>
                          </div>
                        <% } else { %>
                          <span class="text-sm text-gray-400 dark:text-gray-500">Not scheduled</span>
                        <% } %>
                      </td>
                      <td class="px-3 py-3">
                        <% if (vac.nextDueDate) { %>
                          <div class="text-sm <%= isOverdue ? 'text-red-600 dark:text-red-400 font-semibold' : 'text-gray-700 dark:text-gray-300' %>">
                            <%= new Date(vac.nextDueDate).toLocaleDateString('en-IN') %>
                            <% if (isOverdue) { %>
                              <span class="ml-1 text-xs bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300 px-1 rounded">Overdue</span>
                            <% } %>
                          </div>
                        <% } else { %>
                          <span class="text-sm text-gray-400 dark:text-gray-500">Not set</span>
                        <% } %>
                      </td>
                      <td class="px-3 py-3">
                        <% if (vac.assignedParavet && vac.assignedParavet.user) { %>
                          <span class="text-sm text-green-600 dark:text-green-400">
                            <i class="fas fa-user-md mr-1"></i><%= vac.assignedParavet.user.name %>
                          </span>
                        <% } else { %>
                          <span class="text-sm text-gray-400 dark:text-gray-500">Unassigned</span>
                        <% } %>
                        <button onclick="openAssignModal('<%= vac._id %>')" class="ml-2 text-xs text-blue-600 hover:text-blue-800">
                          <i class="fas fa-edit"></i>
                        </button>
                      </td>
                      <td class="px-3 py-3">
                        <% 
                          let statusClass = '';
                          if (vac.status === 'Scheduled') statusClass = 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300';
                          else if (vac.status === 'Completed' || vac.status === 'Administered') statusClass = 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300';
                          else if (vac.status === 'Payment Pending') statusClass = 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300';
                          else if (isOverdue) statusClass = 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300';
                          else statusClass = 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300';
                        %>
