<script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js"></script>
<script>
let selectedVaccinations = new Set();

$(document).ready(function() {
    // Update selected count
    updateSelectedCount();
    
    // Handle checkbox changes
    $(document).on('change', '.animal-checkbox', function() {
        const vacId = $(this).val();
        if ($(this).is(':checked')) {
            selectedVaccinations.add(vacId);
        } else {
            selectedVaccinations.delete(vacId);
        }
        updateSelectedCount();
    });
});


// Toggle all animals for a farmer
function toggleFarmerAnimals(farmerId, checked) {
    if (!farmerId) return;
    $(`.farmer-${farmerId}`).each(function() {
        $(this).prop('checked', checked);
        const vacId = $(this).val();
        if (checked) {
            selectedVaccinations.add(vacId);
        } else {
            selectedVaccinations.delete(vacId);
        }
    });
    updateSelectedCount();
}

// Update selected count in UI
function updateSelectedCount() {
    const count = selectedVaccinations.size;
    if (count > 0) {
        if (!$('#selectedCountBadge').length) {
            const badgeHtml = 
                '<div id="selectedCountBadge" class="fixed bottom-4 right-4 bg-blue-600 text-white px-4 py-2 rounded-lg shadow-lg flex items-center z-50">' +
                '<span class="mr-2">' + count + ' selected</span>' +
                '<button onclick="clearSelection()" class="ml-2 text-white/80 hover:text-white">' +
                '<i class="fas fa-times"></i>' +
                '</button>' +
                '<button onclick="openBulkActions()" class="ml-4 bg-white text-blue-600 px-3 py-1 rounded-lg hover:bg-gray-100">' +
                'Bulk Actions' +
                '</button>' +
                '</div>';
            
            $('body').append(badgeHtml);
        } else {
            $('#selectedCountBadge span').first().text(count + ' selected');
        }
    } else {
        $('#selectedCountBadge').remove();
    }
}

// Clear selection
function clearSelection() {
    $('.animal-checkbox').prop('checked', false);
    selectedVaccinations.clear();
    updateSelectedCount();
}

// Open bulk actions menu
function openBulkActions() {
    const count = selectedVaccinations.size;
    if (count === 0) {
        Swal.fire({
            icon: 'warning',
            title: 'No Selection',
            text: 'Please select at least one vaccination record'
        });
        return;
    }
    
    const actions = [
        { label: 'Assign to Paravet', action: 'assign', icon: 'user-md' },
        { label: 'Schedule Date', action: 'schedule', icon: 'calendar-alt' },
        { label: 'Mark as Completed', action: 'complete', icon: 'check-circle' },
        { label: 'Export Selected', action: 'export', icon: 'download' }
    ];
    
    let actionsHtml = '<div class="grid grid-cols-2 gap-2">';
    actions.forEach(a => {
        actionsHtml += 
            '<button onclick="performBulkAction(\'' + a.action + '\')" ' +
            'class="px-4 py-3 bg-gray-100 hover:bg-gray-200 rounded-lg flex flex-col items-center w-full">' +
            '<i class="fas fa-' + a.icon + ' text-xl mb-1"></i>' +
            '<span class="text-sm">' + a.label + '</span>' +
            '</button>';
    });
    actionsHtml += '</div>';
    
    Swal.fire({
        title: 'Bulk Actions (' + count + ' selected)',
        html: actionsHtml,
        showConfirmButton: false,
        showCloseButton: true,
        width: '500px'
    });
}

// Perform bulk action
function performBulkAction(action) {
    Swal.close();
    
    const vaccinationIds = Array.from(selectedVaccinations);
    
    switch(action) {
        case 'assign':
            openAssignModal(vaccinationIds);
            break;
        case 'schedule':
            openBulkScheduleModal(vaccinationIds);
            break;
        case 'complete':
            openBulkCompleteModal(vaccinationIds);
            break;
        case 'export':
            exportSelected(vaccinationIds);
            break;
    }
}

// Select all animals for a farmer
function selectFarmer(farmerId) {
    if (!farmerId) return;
    toggleFarmerAnimals(farmerId, true);
}

// Open assignment modal
function openAssignModal(vaccinationIds) {
    $('#assignVaccinationIds').val(JSON.stringify(vaccinationIds));
    $('#assignModal').removeClass('hidden');
}

// Submit assignment
function submitAssignment(event) {
    event.preventDefault();
    
    const vaccinationIds = JSON.parse($('#assignVaccinationIds').val());
    const paravetId = $('#assignParavetId').val();
    const scheduledDate = $('#assignScheduledDate').val();
    
    if (!paravetId) {
        Swal.fire({
            icon: 'warning',
            title: 'No Paravet Selected',
            text: 'Please select a paravet'
        });
        return;
    }
    
    Swal.fire({
        title: 'Processing...',
        text: 'Please wait',
        allowOutsideClick: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });
    
    $.ajax({
        url: '/vaccination/api/assign-paravet',
        method: 'POST',
        data: JSON.stringify({
            paravetId,
            vaccinationIds,
            scheduledDate
        }),
        contentType: 'application/json',
        success: function(response) {
            if (response.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: response.message,
                    timer: 2000
                }).then(() => {
                    location.reload();
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: response.message || 'Failed to assign paravet'
                });
            }
        },
        error: function(xhr) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: xhr.responseJSON?.message || 'Failed to assign paravet'
            });
        }
    });
}

// Open schedule modal
function scheduleDate(vaccinationId) {
    $('#scheduleVaccinationIds').val(JSON.stringify([vaccinationId]));
    $('#scheduleModal').removeClass('hidden');
}

// Open bulk schedule modal
function openBulkScheduleModal(vaccinationIds) {
    $('#scheduleVaccinationIds').val(JSON.stringify(vaccinationIds));
    $('#scheduleModal').removeClass('hidden');
    $('#scheduleModal h3').text('Schedule ' + vaccinationIds.length + ' Vaccinations');
}

// Submit schedule
function submitSchedule(event) {
    event.preventDefault();
    
    const vaccinationIdsInput = $('#scheduleVaccinationIds').val();
    const scheduledDate = $('#scheduleDate').val();
    const notes = $('#scheduleNotes').val();
    
    console.log('Schedule input - vaccinationIds:', vaccinationIdsInput);
    console.log('Schedule input - scheduledDate:', scheduledDate);
    
    // Parse vaccinationIds
    let vaccinationIds;
    try {
        vaccinationIds = JSON.parse(vaccinationIdsInput);
    } catch (e) {
        // If it's not JSON, treat as comma-separated or single ID
        vaccinationIds = vaccinationIdsInput.split(',').map(id => id.trim());
    }
    
    if (!vaccinationIds || vaccinationIds.length === 0) {
        Swal.fire({
            icon: 'warning',
            title: 'No Vaccinations',
            text: 'No vaccinations selected'
        });
        return;
    }
    
    if (!scheduledDate) {
        Swal.fire({
            icon: 'warning',
            title: 'No Date Selected',
            text: 'Please select a date'
        });
        return;
    }
    
    // Prepare request data
    const requestData = {
        vaccinationIds: vaccinationIds,
        scheduledDate: scheduledDate,
        notes: notes || ''
    };
    
    console.log('Sending schedule request:', requestData);
    
    Swal.fire({
        title: 'Processing...',
        text: 'Please wait',
        allowOutsideClick: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });
    
    $.ajax({
        url: '/vaccination/api/schedule-date',
        method: 'POST',
        data: JSON.stringify(requestData),
        contentType: 'application/json',
        dataType: 'json',
        success: function(response) {
            console.log('Schedule success response:', response);
            if (response.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Scheduled!',
                    text: response.message,
                    timer: 2000
                }).then(() => {
                    location.reload();
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: response.message || 'Failed to schedule'
                });
            }
        },
        error: function(xhr, status, error) {
            console.error('Schedule error - status:', status);
            console.error('Schedule error - response:', xhr.responseText);
            console.error('Schedule error - error:', error);
            
            let errorMsg = 'Failed to schedule';
            try {
                const response = JSON.parse(xhr.responseText);
                errorMsg = response.message || errorMsg;
            } catch(e) {
                errorMsg = error || errorMsg;
            }
            
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: errorMsg
            });
        }
    });
}
// Open bulk assign modal
function openBulkAssignModal() {
    $('#bulkAssignModal').removeClass('hidden');
    addAssignmentRow();
}

// Add assignment row in bulk modal
function addAssignmentRow() {
    const paravetOptions = '<option value="">Select Paravet</option>' +
        '<% (paravets || []).forEach(p => { %>' +
            '<option value="<%= p._id %>"><%= p.user?.name || "Unknown" %></option>' +
        '<% }); %>';
    
    const row = `
        <div class="assignment-row bg-gray-50 p-4 rounded-lg relative">
            <button type="button" onclick="removeAssignmentRow(this)" 
                    class="absolute top-2 right-2 text-gray-400 hover:text-gray-600">
                <i class="fas fa-times"></i>
            </button>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Paravet</label>
                    <select name="paravetIds[]" class="w-full px-3 py-2 border rounded-lg" required>
                        ${paravetOptions}
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Scheduled Date</label>
                    <input type="date" name="scheduledDates[]" class="w-full px-3 py-2 border rounded-lg"
                           min="<%= new Date().toISOString().split('T')[0] %>">
                </div>
            </div>
            <div class="mt-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Vaccination IDs (comma separated)</label>
                <input type="text" name="vaccinationIdLists[]" class="w-full px-3 py-2 border rounded-lg"
                       placeholder="e.g. id1,id2,id3" required>
            </div>
        </div>
    `;
    
    $('#bulkAssignments').append(row);
}

// Remove assignment row
function removeAssignmentRow(button) {
    $(button).closest('.assignment-row').remove();
}

// Submit bulk assignment
function submitBulkAssignment(event) {
    event.preventDefault();
    
    const assignments = [];
    
    $('.assignment-row').each(function() {
        const paravetId = $(this).find('select[name="paravetIds[]"]').val();
        const scheduledDate = $(this).find('input[name="scheduledDates[]"]').val();
        const vaccinationIdList = $(this).find('input[name="vaccinationIdLists[]"]').val();
        
        if (paravetId && vaccinationIdList) {
            const vaccinationIds = vaccinationIdList.split(',').map(id => id.trim());
            assignments.push({
                paravetId,
                scheduledDate,
                vaccinationIds
            });
        }
    });
    
    if (assignments.length === 0) {
        Swal.fire({
            icon: 'warning',
            title: 'No Assignments',
            text: 'Please add at least one assignment'
        });
        return;
    }
    
    Swal.fire({
        title: 'Processing...',
        text: 'Please wait while we process your request',
        allowOutsideClick: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });
    
    $.ajax({
        url: '/vaccination/api/bulk-assign',
        method: 'POST',
        data: JSON.stringify({ assignments }),
        contentType: 'application/json',
        success: function(response) {
            if (response.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: response.message,
                    timer: 2000
                }).then(() => {
                    location.reload();
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: response.message || 'Failed to process bulk assignments'
                });
            }
        },
        error: function(xhr) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: xhr.responseJSON?.message || 'Failed to process bulk assignments'
            });
        }
    });
}

// View details
function viewDetails(vaccinationId) {
    $.get('/vaccination/api/vaccination/' + vaccinationId)
        .done(function(response) {
            if (response.success) {
                const vac = response.vaccination;
                let html = `
                    <div class="border-b pb-4">
                        <h4 class="font-semibold mb-2">Animal Information</h4>
                        <p><span class="text-gray-600">Name:</span> ${vac.animal?.name || 'N/A'}</p>
                        <p><span class="text-gray-600">Tag:</span> ${vac.animal?.tagNumber || 'No Tag'}</p>
                        <p><span class="text-gray-600">Species:</span> ${vac.animal?.animalType || 'N/A'}</p>
                    </div>
                    <div class="border-b pb-4">
                        <h4 class="font-semibold mb-2">Vaccine Information</h4>
                        <p><span class="text-gray-600">Vaccine:</span> ${vac.vaccine?.name || vac.vaccineName || 'N/A'}</p>
                        <p><span class="text-gray-600">Batch:</span> ${vac.batchNumber || 'N/A'}</p>
                        <p><span class="text-gray-600">Dose:</span> ${vac.doseNumber || 1}/${vac.totalDosesRequired || 1}</p>
                    </div>
                    <div class="border-b pb-4">
                        <h4 class="font-semibold mb-2">Dates</h4>
                        <p><span class="text-gray-600">Administered:</span> ${vac.dateAdministered ? moment(vac.dateAdministered).format('DD/MM/YYYY') : 'Not yet'}</p>
                        <p><span class="text-gray-600">Next Due:</span> ${vac.nextDueDate ? moment(vac.nextDueDate).format('DD/MM/YYYY') : 'Not set'}</p>
                        <p><span class="text-gray-600">Scheduled:</span> ${vac.scheduledDate ? moment(vac.scheduledDate).format('DD/MM/YYYY') : 'Not scheduled'}</p>
                    </div>
                    <div>
                        <h4 class="font-semibold mb-2">Status & Payment</h4>
                        <p><span class="text-gray-600">Status:</span> ${vac.status || 'N/A'}</p>
                        <p><span class="text-gray-600">Payment:</span> ${vac.payment?.paymentStatus || 'N/A'}</p>
                        <p><span class="text-gray-600">Amount:</span> ₹${vac.payment?.totalAmount || 0}</p>
                    </div>
                `;
                $('#detailsContent').html(html);
                $('#detailsModal').removeClass('hidden');
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to load details'
                });
            }
        })
        .fail(function() {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to load details'
            });
        });
}

// View animal vaccination history
function viewHistory(animalId) {
    if (!animalId) {
        Swal.fire({
            icon: 'info',
            title: 'No History',
            text: 'No animal ID provided'
        });
        return;
    }
    
    $.get('/vaccination/api/animal/' + animalId + '/history')
        .done(function(response) {
            if (response.success && response.history && response.history.length > 0) {
                let historyHtml = '<div class="space-y-4 max-h-96 overflow-y-auto">';
                response.history.forEach(vac => {
                    historyHtml += `
                        <div class="border-b pb-3">
                            <div class="flex justify-between">
                                <span class="font-semibold">${vac.vaccine?.name || vac.vaccineName || 'Unknown'}</span>
                                <span class="text-sm text-gray-500">${moment(vac.dateAdministered).format('DD/MM/YYYY')}</span>
                            </div>
                            <div class="text-sm text-gray-600">
                                <p>Dose: ${vac.doseNumber || 1}/${vac.totalDosesRequired || 1}</p>
                                <p>Status: ${vac.status || 'N/A'}</p>
                                <p>Given by: ${vac.administeredBy || 'N/A'}</p>
                            </div>
                        </div>
                    `;
                });
                historyHtml += '</div>';
                
                Swal.fire({
                    title: 'Vaccination History',
                    html: historyHtml,
                    width: '600px',
                    showCloseButton: true,
                    showConfirmButton: false
                });
            } else {
                Swal.fire({
                    icon: 'info',
                    title: 'No History',
                    text: 'No vaccination history found for this animal'
                });
            }
        })
        .fail(function() {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to load vaccination history'
            });
        });
}

// Mark complete
function markComplete(vaccinationId) {
    $('#completeVaccinationId').val(vaccinationId);
    $('#completeModal').removeClass('hidden');
}

// Submit complete
function submitComplete(event) {
    event.preventDefault();
    
    const vaccinationId = $('#completeVaccinationId').val();
    const completedDate = $('#completeDate').val();
    const notes = $('#completeNotes').val();
    
    if (!completedDate) {
        Swal.fire({
            icon: 'warning',
            title: 'No Date Selected',
            text: 'Please select a completion date'
        });
        return;
    }
    
    Swal.fire({
        title: 'Processing...',
        text: 'Please wait',
        allowOutsideClick: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });
    
    $.ajax({
        url: '/vaccination/api/vaccination/' + vaccinationId + '/status',
        method: 'PATCH',
        data: JSON.stringify({
            status: 'Completed',
            completedDate: completedDate,
            notes: notes
        }),
        contentType: 'application/json',
        success: function(response) {
            if (response.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Completed!',
                    text: response.message,
                    timer: 2000
                }).then(() => {
                    location.reload();
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: response.message || 'Failed to mark complete'
                });
            }
        },
        error: function(xhr) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: xhr.responseJSON?.message || 'Failed to mark complete'
            });
        }
    });
}

// Delete vaccination
function deleteVaccination(vaccinationId) {
    Swal.fire({
        title: 'Are you sure?',
        text: "You won't be able to revert this!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, delete it!'
    }).then((result) => {
        if (result.isConfirmed) {
            Swal.fire({
                title: 'Deleting...',
                text: 'Please wait',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });
            
            $.ajax({
                url: '/vaccination/api/vaccination/' + vaccinationId,
                method: 'DELETE',
                success: function(response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Deleted!',
                            text: response.message,
                            timer: 2000
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.message || 'Failed to delete'
                        });
                    }
                },
                error: function(xhr) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: xhr.responseJSON?.message || 'Failed to delete'
                    });
                }
            });
        }
    });
}

// Assign paravet to farmer
function assignParavetToFarmer(farmerId) {
    if (!farmerId) return;
    
    const vaccinationIds = [];
    $(`.farmer-${farmerId}`).each(function() {
        if ($(this).is(':checked')) {
            vaccinationIds.push($(this).val());
        }
    });
    
    if (vaccinationIds.length === 0) {
        Swal.fire({
            icon: 'warning',
            title: 'No Selection',
            text: 'Please select at least one animal for this farmer'
        });
        return;
    }
    
    openAssignModal(vaccinationIds);
}

// Schedule all for farmer
function scheduleFarmer(farmerId) {
    if (!farmerId) return;
    
    const vaccinationIds = [];
    $(`.farmer-${farmerId}`).each(function() {
        $(this).prop('checked', true);
        vaccinationIds.push($(this).val());
        selectedVaccinations.add($(this).val());
    });
    updateSelectedCount();
    
    openBulkScheduleModal(vaccinationIds);
}

// Open bulk complete modal
function openBulkCompleteModal(vaccinationIds) {
    $('#completeVaccinationId').val(JSON.stringify(vaccinationIds));
    $('#completeModal').removeClass('hidden');
    $('#completeModal h3').text('Mark ' + vaccinationIds.length + ' Vaccinations Complete');
}

// Close modal
function closeModal(modalId) {
    $('#' + modalId).addClass('hidden');
}

// Remove filter
function removeFilter(filterName) {
    const url = new URL(window.location);
    url.searchParams.delete(filterName);
    window.location = url.toString();
}

// Clear all filters
function clearFilters() {
    window.location = '/vaccination/schedule';
}

// Export selected
function exportSelected(vaccinationIds) {
    window.location = '/vaccination/export/selected?ids=' + vaccinationIds.join(',');
}

// Handle keyboard escape key
$(document).keydown(function(e) {
    if (e.key === 'Escape') {
        $('.fixed').addClass('hidden');
    }
});
</script>

