<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  let selectedVaccinations = new Set();
  let currentVaccinationId = null;
  let bulkAssignmentCounter = 0;

  // ================ SELECTION FUNCTIONS ================
  
  function toggleSelectAll(farmerId, checked) {
    document.querySelectorAll(`.farmer-${farmerId}`).forEach(cb => {
      cb.checked = checked;
      const vacId = cb.value;
      if (checked) {
        selectedVaccinations.add(vacId);
      } else {
        selectedVaccinations.delete(vacId);
      }
    });
    updateBulkSelectionBar();
  }

  function selectFarmerVaccinations(farmerId) {
    const checkboxes = document.querySelectorAll(`.farmer-${farmerId}`);
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => {
      cb.checked = !allChecked;
      const vacId = cb.value;
      if (!allChecked) {
        selectedVaccinations.add(vacId);
      } else {
        selectedVaccinations.delete(vacId);
      }
    });
    updateBulkSelectionBar();
  }

  function updateBulkSelectionBar() {
    const count = selectedVaccinations.size;
    const bar = document.getElementById('bulkSelectionBar');
    const countSpan = document.getElementById('selectedCount');
    
    if (count > 0) {
      countSpan.textContent = count;
      bar.classList.remove('hidden');
    } else {
      bar.classList.add('hidden');
    }
  }

  function clearBulkSelection() {
    document.querySelectorAll('.vaccination-checkbox').forEach(cb => {
      cb.checked = false;
    });
    selectedVaccinations.clear();
    updateBulkSelectionBar();
  }

  // ================ SCHEDULE FUNCTIONS ================
  
  function openScheduleModal(vaccinationId) {
    currentVaccinationId = vaccinationId;
    document.getElementById('scheduleVaccinationId').value = vaccinationId;
    document.getElementById('scheduleModal').classList.remove('hidden');
  }

  function closeScheduleModal() {
    document.getElementById('scheduleModal').classList.add('hidden');
    currentVaccinationId = null;
  }

  async function submitSchedule(event) {
    event.preventDefault();
    
    const vaccinationId = document.getElementById('scheduleVaccinationId').value;
    const scheduledDate = document.getElementById('scheduleDate').value;
    
    if (!scheduledDate) {
      Swal.fire({ icon: 'warning', title: 'Required', text: 'Please select a date' });
      return;
    }
    
    Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
    
    try {
      const response = await fetch('/vaccination/api/schedule-date', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          vaccinationIds: [vaccinationId], 
          scheduledDate: scheduledDate 
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        Swal.fire({ icon: 'success', title: 'Scheduled!', text: data.message, timer: 2000 })
          .then(() => location.reload());
      } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Failed to schedule' });
      }
    } catch (error) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to schedule vaccination' });
    }
    closeScheduleModal();
  }

  // ================ ASSIGN PARAVET FUNCTIONS ================
  
  function openAssignModal(vaccinationId) {
    document.getElementById('assignVaccinationIds').value = JSON.stringify([vaccinationId]);
    document.getElementById('assignInfo').textContent = 'Selected: 1 vaccination';
    document.getElementById('assignModal').classList.remove('hidden');
  }

  function openFarmerAssignModal(farmerId) {
    const selectedIds = [];
    document.querySelectorAll(`.farmer-${farmerId}:checked`).forEach(cb => {
      selectedIds.push(cb.value);
    });
    
    if (selectedIds.length === 0) {
      Swal.fire({ icon: 'warning', title: 'No Selection', text: 'Please select at least one vaccination' });
      return;
    }
    
    document.getElementById('assignVaccinationIds').value = JSON.stringify(selectedIds);
    document.getElementById('assignInfo').textContent = `Selected: ${selectedIds.length} vaccination(s)`;
    document.getElementById('assignModal').classList.remove('hidden');
  }

  function assignFarmerToParavet(farmerId) {
    const selectedIds = [];
    document.querySelectorAll(`.farmer-${farmerId}:checked`).forEach(cb => {
      selectedIds.push(cb.value);
    });
    
    if (selectedIds.length === 0) {
      Swal.fire({ icon: 'warning', title: 'No Selection', text: 'Please select at least one vaccination' });
      return;
    }
    
    document.getElementById('assignVaccinationIds').value = JSON.stringify(selectedIds);
    document.getElementById('assignInfo').textContent = `Selected: ${selectedIds.length} vaccination(s)`;
    document.getElementById('assignModal').classList.remove('hidden');
  }

  function closeAssignModal() {
    document.getElementById('assignModal').classList.add('hidden');
    document.getElementById('assignParavetId').value = '';
    document.getElementById('assignScheduledDate').value = '';
  }

  async function submitAssignment(event) {
    event.preventDefault();
    
    const vaccinationIdsInput = document.getElementById('assignVaccinationIds').value;
    let vaccinationIds;
    try {
      vaccinationIds = JSON.parse(vaccinationIdsInput);
    } catch(e) {
      vaccinationIds = vaccinationIdsInput.split(',').map(id => id.trim());
    }
    
    const paravetId = document.getElementById('assignParavetId').value;
    const scheduledDate = document.getElementById('assignScheduledDate').value;
    
    if (!paravetId) {
      Swal.fire({ icon: 'warning', title: 'Required', text: 'Please select a paravet' });
      return;
    }
    
    Swal.fire({ title: 'Assigning...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
    
    try {
      const response = await fetch('/vaccination/api/assign-paravet', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          vaccinationIds: vaccinationIds,
          paravetId: paravetId,
          scheduledDate: scheduledDate || null
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        Swal.fire({ icon: 'success', title: 'Assigned!', text: data.message, timer: 2000 })
          .then(() => location.reload());
      } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Failed to assign' });
      }
    } catch (error) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to assign paravet' });
    }
    closeAssignModal();
  }

  // ================ BULK ASSIGN FUNCTIONS ================
  
  function openBulkAssignModal() {
    document.getElementById('bulkAssignmentsList').innerHTML = '';
    addBulkAssignmentRow();
    document.getElementById('bulkAssignModal').classList.remove('hidden');
  }

  function closeBulkAssignModal() {
    document.getElementById('bulkAssignModal').classList.add('hidden');
  }

  function addBulkAssignmentRow() {
    const paravetOptions = '<option value="">Select Paravet...</option>' +
      '<% (paravets || []).forEach(p => { %>' +
        '<option value="<%= p._id %>"><%= p.user?.name || "Unknown" %> - <%= p.qualification || "N/A" %></option>' +
      '<% }); %>';
    
    const rowId = `bulk_row_${Date.now()}_${bulkAssignmentCounter++}`;
    const row = `
      <div id="${rowId}" class="bulk-assignment-row bg-gray-50 dark:bg-gray-700 p-4 rounded-lg relative">
        <button type="button" onclick="removeBulkAssignmentRow('${rowId}')" 
                class="absolute top-2 right-2 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300">
          <i class="fas fa-times"></i>
        </button>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Paravet *</label>
            <select class="bulk-paravet w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
              ${paravetOptions}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Schedule Date</label>
            <input type="date" class="bulk-date w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
                   min="<%= new Date().toISOString().split('T')[0] %>">
          </div>
        </div>
        <div class="mt-3">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Vaccination IDs (comma separated) *</label>
          <textarea class="bulk-ids w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" 
                    rows="2" placeholder="e.g., id1, id2, id3"></textarea>
        </div>
      </div>
    `;
    document.getElementById('bulkAssignmentsList').insertAdjacentHTML('beforeend', row);
  }

  function removeBulkAssignmentRow(rowId) {
    document.getElementById(rowId).remove();
  }

  async function submitBulkAssignments(event) {
    event.preventDefault();
    
    const assignments = [];
    const rows = document.querySelectorAll('.bulk-assignment-row');
    
    for (const row of rows) {
      const paravetId = row.querySelector('.bulk-paravet').value;
      const scheduledDate = row.querySelector('.bulk-date').value;
      const idsText = row.querySelector('.bulk-ids').value;
      
      if (!paravetId) continue;
      
      const vaccinationIds = idsText.split(',').map(id => id.trim()).filter(id => id);
      if (vaccinationIds.length === 0) continue;
      
      assignments.push({
        paravetId: paravetId,
        scheduledDate: scheduledDate || null,
        vaccinationIds: vaccinationIds
      });
    }
    
    if (assignments.length === 0) {
      Swal.fire({ icon: 'warning', title: 'No Assignments', text: 'Please add at least one valid assignment' });
      return;
    }
    
    Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
    
    try {
      const response = await fetch('/vaccination/api/bulk-assign', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ assignments: assignments })
      });
      
      const data = await response.json();
      
      if (data.success) {
        Swal.fire({ icon: 'success', title: 'Success!', text: data.message, timer: 2000 })
          .then(() => location.reload());
      } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Failed to process assignments' });
      }
    } catch (error) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to process assignments' });
    }
    closeBulkAssignModal();
  }

  // ================ COMPLETE FUNCTIONS ================
  
  async function markComplete(vaccinationId, vaccineId) {
    document.getElementById('completeVaccinationId').value = vaccinationId;
    document.getElementById('completeVaccineId').value = vaccineId;
    document.getElementById('completeModal').classList.remove('hidden');
  }

  function closeCompleteModal() {
    document.getElementById('completeModal').classList.add('hidden');
  }

  async function submitComplete(event) {
    event.preventDefault();
    
    const vaccinationId = document.getElementById('completeVaccinationId').value;
    const completionDate = document.getElementById('completeDate').value;
    const batchNumber = document.getElementById('completeBatchNumber').value;
    const notes = document.getElementById('completeNotes').value;
    
    if (!completionDate) {
      Swal.fire({ icon: 'warning', title: 'Required', text: 'Please select a completion date' });
      return;
    }
    
    Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
    
    try {
      const response = await fetch(`/vaccination/${vaccinationId}/complete`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          completionDate: completionDate,
          batchNumber: batchNumber,
          notes: notes
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        Swal.fire({ icon: 'success', title: 'Completed!', text: data.message, timer: 2000 })
          .then(() => location.reload());
      } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Failed to complete' });
      }
    } catch (error) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to complete vaccination' });
    }
    closeCompleteModal();
  }

  // ================ VIEW DETAILS ================
  
  async function viewVaccinationDetails(vaccinationId) {
    try {
      const response = await fetch(`/vaccination/api/vaccination/${vaccinationId}`);
      const data = await response.json();
      
      if (data.success) {
        const vac = data.vaccination;
        const detailsHtml = `
          <div class="border-b pb-3">
            <h4 class="font-semibold mb-2 text-gray-900 dark:text-white">Animal Information</h4>
            <p><span class="text-gray-600">Name:</span> ${vac.animal?.name || 'N/A'}</p>
            <p><span class="text-gray-600">Tag:</span> ${vac.animal?.tagNumber || 'No Tag'}</p>
            <p><span class="text-gray-600">Species:</span> ${vac.animal?.animalType || 'N/A'}</p>
          </div>
          <div class="border-b pb-3">
            <h4 class="font-semibold mb-2">Vaccine Information</h4>
            <p><span class="text-gray-600">Vaccine:</span> ${vac.vaccine?.name || vac.vaccineName || 'N/A'}</p>
            <p><span class="text-gray-600">Batch:</span> ${vac.batchNumber || 'N/A'}</p>
            <p><span class="text-gray-600">Dose:</span> ${vac.doseNumber || 1}/${vac.totalDosesRequired || 1}</p>
          </div>
          <div>
            <h4 class="font-semibold mb-2">Dates</h4>
            <p><span class="text-gray-600">Administered:</span> ${vac.dateAdministered ? new Date(vac.dateAdministered).toLocaleDateString() : 'Not yet'}</p>
            <p><span class="text-gray-600">Next Due:</span> ${vac.nextDueDate ? new Date(vac.nextDueDate).toLocaleDateString() : 'Not set'}</p>
            <p><span class="text-gray-600">Scheduled:</span> ${vac.scheduledDate ? new Date(vac.scheduledDate).toLocaleDateString() : 'Not scheduled'}</p>
          </div>
        `;
        document.getElementById('detailsContent').innerHTML = detailsHtml;
        document.getElementById('detailsModal').classList.remove('hidden');
      }
    } catch (error) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to load details' });
    }
  }

  function closeDetailsModal() {
    document.getElementById('detailsModal').classList.add('hidden');
  }

  // ================ BULK SCHEDULE FUNCTIONS ================
  
  function selectAllNeedingAnimals() {
    const checkboxes = document.querySelectorAll('.needing-animal-checkbox');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => cb.checked = !allChecked);
  }

  function openBulkScheduleNeedingModal() {
    const selectedCheckboxes = document.querySelectorAll('.needing-animal-checkbox:checked');
    const selectedIds = Array.from(selectedCheckboxes).map(cb => cb.value);
    
    if (selectedIds.length === 0) {
      Swal.fire({ icon: 'warning', title: 'No Selection', text: 'Please select at least one animal' });
      return;
    }
    
    const defaultDate = new Date();
    defaultDate.setDate(defaultDate.getDate() + 7);
    document.getElementById('needingScheduledDate').value = defaultDate.toISOString().split('T')[0];
    document.getElementById('needingAnimalIds').value = JSON.stringify(selectedIds);
    document.getElementById('bulkScheduleNeedingModal').classList.remove('hidden');
  }

  function closeBulkScheduleNeedingModal() {
    document.getElementById('bulkScheduleNeedingModal').classList.add('hidden');
  }

  async function submitBulkScheduleNeeding(event) {
    event.preventDefault();
    
    const animalIdsInput = document.getElementById('needingAnimalIds').value;
    let animalIds;
    try {
      animalIds = JSON.parse(animalIdsInput);
    } catch(e) {
      animalIds = animalIdsInput.split(',').map(id => id.trim());
    }
    
    const paravetId = document.getElementById('needingParavetId').value;
    const scheduledDate = document.getElementById('needingScheduledDate').value;
    const notes = document.getElementById('needingNotes').value;
    
    if (!paravetId) {
      Swal.fire({ icon: 'warning', title: 'Required', text: 'Please select a paravet' });
      return;
    }
    
    if (!scheduledDate) {
      Swal.fire({ icon: 'warning', title: 'Required', text: 'Please select a date' });
      return;
    }
    
    Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
    
    try {
      const response = await fetch('/vaccination/api/bulk-schedule-needing', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          animalIds: animalIds,
          paravetId: paravetId,
          scheduledDate: scheduledDate,
          notes: notes
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        Swal.fire({ icon: 'success', title: 'Scheduled!', text: data.message, timer: 3000 })
          .then(() => location.reload());
      } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Failed to schedule' });
      }
    } catch (error) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to schedule vaccinations' });
    }
    closeBulkScheduleNeedingModal();
  }

  // ================ UNTAGGED MODAL ================
  
  function showUntaggedAnimalsModal() {
    document.getElementById('untaggedModal').classList.remove('hidden');
  }

  function closeUntaggedModal() {
    document.getElementById('untaggedModal').classList.add('hidden');
  }

  // ================ FILTER FUNCTIONS ================
  
  function clearFilters() {
    window.location.href = '/vaccination/schedule';
  }

  // Initialize checkbox listeners
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.vaccination-checkbox').forEach(cb => {
      cb.addEventListener('change', function() {
        const vacId = this.value;
        if (this.checked) {
          selectedVaccinations.add(vacId);
        } else {
          selectedVaccinations.delete(vacId);
        }
        updateBulkSelectionBar();
      });
    });
  });
</script>

