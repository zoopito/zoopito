<%- include('../../includes/navbar') %>

<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800 py-8 px-4">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">Verify Payment</h1>
      <p class="text-gray-600 dark:text-gray-400">Complete the payment verification process for animal registration plans</p>
    </div>

    <!-- Payment Details Card -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl border border-gray-100 dark:border-gray-700 p-8 mb-6">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Payment Details</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Payment Amount -->
        <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-900/30 rounded-xl p-4 border border-blue-200 dark:border-blue-700">
          <label class="text-sm font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wide">Amount</label>
          <p id="displayAmount" class="text-3xl font-bold text-blue-900 dark:text-blue-300 mt-1">₹ 0</p>
        </div>

        <!-- Payment Type -->
        <div class="bg-gradient-to-br from-orange-50 to-orange-100 dark:from-orange-900/20 dark:to-orange-900/30 rounded-xl p-4 border border-orange-200 dark:border-orange-700">
          <label class="text-sm font-semibold text-orange-600 dark:text-orange-400 uppercase tracking-wide">Payment Type</label>
          <p id="displayType" class="text-3xl font-bold text-orange-900 dark:text-orange-300 mt-1">-</p>
        </div>

        <!-- Animals Count -->
        <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-900/30 rounded-xl p-4 border border-green-200 dark:border-green-700">
          <label class="text-sm font-semibold text-green-600 dark:text-green-400 uppercase tracking-wide">Animals</label>
          <p id="animalCount" class="text-3xl font-bold text-green-900 dark:text-green-300 mt-1">0</p>
        </div>

        <!-- Status -->
        <div class="bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900/20 dark:to-purple-900/30 rounded-xl p-4 border border-purple-200 dark:border-purple-700">
          <label class="text-sm font-semibold text-purple-600 dark:text-purple-400 uppercase tracking-wide">Status</label>
          <div id="statusBadge" class="text-lg font-bold text-purple-900 dark:text-purple-300 mt-1">
            <span class="inline-block px-3 py-1 rounded-full text-sm bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300">Pending</span>
          </div>
        </div>
      </div>

      <!-- Animals List -->
      <div class="mb-8">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Animals Included in This Payment</h3>
        <div id="animalsList" class="space-y-3">
          <p class="text-gray-500 dark:text-gray-400">Loading animals...</p>
        </div>
      </div>

      <!-- Payment Form -->
      <form id="paymentForm" method="POST" class="space-y-6">
        <input type="hidden" id="paymentId" name="paymentId">

        <!-- Payment Method -->
        <div>
          <label for="paymentMethod" class="block text-sm font-bold text-gray-900 dark:text-white mb-2">Payment Method</label>
          <select id="paymentMethod" name="paymentMethod" 
            class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent" required>
            <option value="">Select payment method...</option>
            <option value="bank_transfer">Bank Transfer</option>
            <option value="upi">UPI</option>
            <option value="cash">Cash</option>
            <option value="check">Check</option>
            <option value="online">Online Payment</option>
          </select>
        </div>

        <!-- UTR Number -->
        <div>
          <label for="utrNumber" class="block text-sm font-bold text-gray-900 dark:text-white mb-2">
            UTR / Reference Number <span class="text-red-500">*</span>
          </label>
          <input type="text" id="utrNumber" name="utrNumber" placeholder="Enter transaction reference number"
            class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent" required>
        </div>

        <!-- Paid Amount -->
        <div>
          <label for="paidAmount" class="block text-sm font-bold text-gray-900 dark:text-white mb-2">
            Paid Amount <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <span class="absolute left-4 top-3 text-gray-600 dark:text-gray-400 font-bold">₹</span>
            <input type="number" id="paidAmount" name="paidAmount" placeholder="0.00"
              class="w-full pl-8 pr-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent" 
              step="0.01" required>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
            Expected: <span id="expectedAmount" class="font-bold">₹0</span>
          </p>
        </div>

        <!-- Payment Date -->
        <div>
          <label for="paymentDate" class="block text-sm font-bold text-gray-900 dark:text-white mb-2">
            Payment Date <span class="text-red-500">*</span>
          </label>
          <input type="date" id="paymentDate" name="paymentDate"
            class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent" required>
        </div>

        <!-- Notes -->
        <div>
          <label for="notes" class="block text-sm font-bold text-gray-900 dark:text-white mb-2">Notes (Optional)</label>
          <textarea id="notes" name="notes" placeholder="Add any notes about this payment..."
            class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            rows="3"></textarea>
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
          <a href="/admin/payments" 
            class="px-6 py-2 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-semibold hover:bg-gray-100 dark:hover:bg-gray-700 transition">
            Cancel
          </a>
          <button type="button" onclick="resetForm()" 
            class="px-6 py-2 rounded-lg bg-gray-300 dark:bg-gray-600 text-gray-900 dark:text-white font-semibold hover:bg-gray-400 dark:hover:bg-gray-500 transition">
            Clear
          </button>
          <button type="submit" 
            class="ml-auto px-8 py-2 rounded-lg bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold transition transform hover:scale-105">
            Verify Payment
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Initialize form with payment data
  document.addEventListener('DOMContentLoaded', function() {
    const urlParams = new URLSearchParams(window.location.search);
    const paymentId = urlParams.get('paymentId');
    
    if (paymentId) {
      document.getElementById('paymentId').value = paymentId;
      loadPaymentDetails(paymentId);
    }
    
    // Set today's date as default
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('paymentDate').value = today;
  });

  async function loadPaymentDetails(paymentId) {
    try {
      const response = await fetch(`/admin/payments/${paymentId}`);
      const data = await response.json();
      
      if (data.success) {
        const payment = data.payment;
        
        // Display payment details
        document.getElementById('displayAmount').textContent = `₹ ${payment.amount.toFixed(2)}`;
        document.getElementById('displayType').textContent = payment.metadata?.planType || 'Custom';
        document.getElementById('animalCount').textContent = payment.animalIds?.length || 0;
        document.getElementById('expectedAmount').textContent = `₹ ${payment.amount.toFixed(2)}`;
        document.getElementById('paidAmount').value = payment.amount || '';
        
        // Display animals
        const animalsList = document.getElementById('animalsList');
        if (payment.animalIds && payment.animalIds.length > 0) {
          animalsList.innerHTML = payment.animalIds.map((animal, index) => `
            <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 border border-gray-200 dark:border-gray-600">
              <div class="flex justify-between items-start">
                <div>
                  <p class="font-semibold text-gray-900 dark:text-white">${animal.name || 'Animal ' + (index + 1)}</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">
                    Tag: ${animal.tagNumber || animal.uniqueAnimalId || 'N/A'} | Type: ${animal.animalType}
                  </p>
                </div>
                <span class="px-3 py-1 rounded-full text-xs font-medium 
                  ${animal.plan?.status === 'active' ? 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300' : 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300'}">
                  ${animal.plan?.status || 'Pending'}
                </span>
              </div>
            </div>
          `).join('');
        }
        
        // Update status badge
        const statusBadge = document.getElementById('statusBadge');
        if (payment.paymentStatus === 'completed') {
          statusBadge.innerHTML = '<span class="inline-block px-3 py-1 rounded-full text-sm bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300">✓ Verified</span>';
          // Disable form if already verified
          document.getElementById('paymentForm').style.opacity = '0.6';
          document.querySelectorAll('#paymentForm input, #paymentForm select, #paymentForm textarea, #paymentForm button[type="submit"]').forEach(el => {
            el.disabled = true;
          });
        }
      }
    } catch (error) {
      console.error('Error loading payment:', error);
      alert('Error loading payment details');
    }
  }

  // Form submission
  document.getElementById('paymentForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const paymentId = document.getElementById('paymentId').value;
    const formData = {
      utrNumber: document.getElementById('utrNumber').value,
      paidAmount: parseFloat(document.getElementById('paidAmount').value),
      paymentDate: document.getElementById('paymentDate').value,
      notes: document.getElementById('notes').value
    };

    try {
      const response = await fetch(`/admin/animals/verify-payment/${paymentId}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(formData)
      });

      const data = await response.json();

      if (data.success) {
        alert('✓ Payment verified successfully!\n\n' + data.message);
        window.location.href = data.redirectUrl || '/admin/animals';
      } else {
        alert('✗ Error: ' + (data.message || 'Unknown error occurred'));
      }
    } catch (error) {
      console.error('Error verifying payment:', error);
      alert('Error verifying payment. Please try again.');
    }
  });

  function resetForm() {
    document.getElementById('paymentForm').reset();
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('paymentDate').value = today;
  }
</script>

<%- include('../../includes/footer') %>
