<% layout("layouts/boilerplate", {
    title: 'Verify Vaccination Requests - Zoopito Admin',
    description: 'Review and verify vaccination requests submitted by paravets'
}) %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Header -->
        <div class="mb-6">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
                        <i class="fas fa-clipboard-list text-blue-500"></i>
                        Verify Vaccination Requests
                    </h1>
                    <p class="text-sm text-gray-500 mt-0.5">Review and verify vaccination requests from paravets</p>
                </div>
                <div class="flex gap-2">
                    <a href="/admin/vaccinations" class="px-3 py-1.5 bg-gray-600 text-white text-sm rounded-lg hover:bg-gray-700 transition">
                        <i class="fas fa-arrow-left mr-1"></i> Back
                    </a>
                    <button onclick="refreshPage()" class="px-3 py-1.5 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition">
                        <i class="fas fa-sync-alt mr-1"></i> Refresh
                    </button>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
            <div class="bg-yellow-50 dark:bg-yellow-900/20 rounded-lg p-3 border-l-3 border-yellow-500">
                <p class="text-xs text-yellow-600 font-medium">Pending</p>
                <p class="text-2xl font-bold text-yellow-700"><%= pendingCount || 0 %></p>
            </div>
            <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-3 border-l-3 border-green-500">
                <p class="text-xs text-green-600 font-medium">Verified</p>
                <p class="text-2xl font-bold text-green-700"><%= verifiedCount || 0 %></p>
            </div>
            <div class="bg-red-50 dark:bg-red-900/20 rounded-lg p-3 border-l-3 border-red-500">
                <p class="text-xs text-red-600 font-medium">Rejected</p>
                <p class="text-2xl font-bold text-red-700"><%= rejectedCount || 0 %></p>
            </div>
            <div class="bg-purple-50 dark:bg-purple-900/20 rounded-lg p-3 border-l-3 border-purple-500">
                <p class="text-xs text-purple-600 font-medium">This Month</p>
                <p class="text-2xl font-bold text-purple-700"><%= totalThisMonth || 0 %></p>
            </div>
        </div>

        <!-- Filter Tabs -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm mb-4 p-2">
            <div class="flex flex-wrap gap-1">
                <a href="?status=pending" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all <%= currentStatus === 'pending' ? 'bg-yellow-500 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
                    <i class="fas fa-clock mr-1"></i> Pending
                    <% if (pendingCount > 0) { %><span class="ml-1 bg-red-500 text-white px-1.5 py-0.5 rounded-full text-xs"><%= pendingCount %></span><% } %>
                </a>
                <a href="?status=verified" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all <%= currentStatus === 'verified' ? 'bg-green-500 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
                    <i class="fas fa-check-circle mr-1"></i> Verified
                </a>
                <a href="?status=rejected" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all <%= currentStatus === 'rejected' ? 'bg-red-500 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
                    <i class="fas fa-times-circle mr-1"></i> Rejected
                </a>
                <a href="?status=all" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all <%= currentStatus === 'all' ? 'bg-blue-500 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
                    <i class="fas fa-list mr-1"></i> All
                </a>
            </div>
        </div>

        <!-- Bulk Actions Bar -->
        <% if (requests && requests.length > 0 && currentStatus === 'pending') { %>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm mb-4 p-3 sticky top-0 z-10">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <div class="flex items-center gap-3">
                        <label class="flex items-center gap-1 cursor-pointer text-sm">
                            <input type="checkbox" id="selectAllCheckbox" class="rounded">
                            <span>Select All</span>
                        </label>
                        <span id="selectedCount" class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full">0</span>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="bulkReject()" class="px-3 py-1.5 bg-red-600 text-white text-sm rounded-lg hover:bg-red-700 flex items-center gap-1 disabled:opacity-50" id="bulkRejectBtn" disabled>
                            <i class="fas fa-times text-xs"></i> Reject
                        </button>
                        <button onclick="bulkApprove()" class="px-3 py-1.5 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700 flex items-center gap-1 disabled:opacity-50" id="bulkApproveBtn" disabled>
                            <i class="fas fa-check text-xs"></i> Approve
                        </button>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Requests List -->
        <div class="space-y-3">
            <% if (requests && requests.length > 0) { %>
                <% requests.forEach((request) => { 
                    const status = request.verificationStatus || 'Pending';
                %>
                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm overflow-hidden border-l-3 
                        <%= status === 'Pending' ? 'border-l-yellow-500' : (status === 'Verified' ? 'border-l-green-500' : 'border-l-red-500') %>">
                        
                        <div class="p-3">
                            <div class="flex flex-wrap items-center justify-between gap-2">
                                <div class="flex items-center gap-2">
                                    <% if (status === 'Pending') { %>
                                        <input type="checkbox" class="request-checkbox rounded" data-id="<%= request._id %>">
                                    <% } %>
                                    <div class="w-8 h-8 rounded-full bg-gradient-to-r from-blue-500 to-blue-600 flex items-center justify-center text-white font-bold text-sm">
                                        <%= (request.paravet?.user?.name || 'P').charAt(0).toUpperCase() %>
                                    </div>
                                    <div>
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <span class="font-semibold text-gray-900 dark:text-white text-sm"><%= request.paravet?.user?.name || 'Unknown Paravet' %></span>
                                            <span class="px-1.5 py-0.5 rounded-full text-xs font-medium
                                                <%= status === 'Pending' ? 'bg-yellow-100 text-yellow-800' : 
                                                   (status === 'Verified' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800') %>">
                                                <%= status %>
                                            </span>
                                        </div>
                                        <p class="text-xs text-gray-500"><i class="fas fa-envelope mr-1"></i> <%= request.paravet?.user?.email || 'No email' %></p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="text-xs text-gray-500">
                                        <i class="far fa-calendar-alt mr-1"></i>
                                        <%= moment(request.createdAt).format('DD MMM, hh:mm A') %>
                                    </span>
                                    <% if (status === 'Pending') { %>
                                        <button onclick="quickApprove('<%= request._id %>')" 
                                                class="px-2 py-1 bg-green-600 text-white text-xs rounded-lg hover:bg-green-700 transition flex items-center gap-1">
                                            <i class="fas fa-check"></i> Approve
                                        </button>
                                        <button onclick="quickReject('<%= request._id %>')" 
                                                class="px-2 py-1 bg-red-600 text-white text-xs rounded-lg hover:bg-red-700 transition flex items-center gap-1">
                                            <i class="fas fa-times"></i> Reject
                                        </button>
                                    <% } %>
                                    <button onclick="viewRequestDetails('<%= request._id %>')" 
                                            class="px-2 py-1 bg-blue-600 text-white text-xs rounded-lg hover:bg-blue-700 transition flex items-center gap-1">
                                        <i class="fas fa-eye"></i> View
                                    </button>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mt-2 text-xs">
                                <div>
                                    <p class="text-gray-500">Farmer</p>
                                    <p class="font-medium text-gray-900"><%= request.farmer?.name || 'N/A' %></p>
                                </div>
                                <div>
                                    <p class="text-gray-500">Mobile</p>
                                    <p class="text-gray-900"><%= request.farmer?.mobileNumber || 'N/A' %></p>
                                </div>
                                <div>
                                    <p class="text-gray-500">Village</p>
                                    <p class="text-gray-900"><%= request.farmer?.address?.village || 'N/A' %></p>
                                </div>
                                <div>
                                    <p class="text-gray-500">Vaccinations</p>
                                    <p class="font-medium text-blue-600"><%= request.vaccinations?.length || 0 %></p>
                                </div>
                                <div>
                                    <p class="text-gray-500">Amount</p>
                                    <p class="font-medium text-green-600">₹<%= request.totalAmount || 0 %></p>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-8 text-center">
                    <i class="fas fa-check-circle text-4xl text-green-500 mb-2"></i>
                    <p class="text-gray-500">No requests found</p>
                </div>
            <% } %>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="mt-4 flex justify-center">
                <div class="flex gap-1">
                    <% if (currentPage > 1) { %>
                        <a href="?status=<%= currentStatus %>&page=<%= currentPage - 1 %>" class="px-3 py-1 bg-white border rounded-lg text-sm hover:bg-gray-50">« Prev</a>
                    <% } %>
                    <span class="px-3 py-1 text-sm">Page <%= currentPage %> of <%= totalPages %></span>
                    <% if (currentPage < totalPages) { %>
                        <a href="?status=<%= currentStatus %>&page=<%= currentPage + 1 %>" class="px-3 py-1 bg-white border rounded-lg text-sm hover:bg-gray-50">Next »</a>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>

<!-- Details Modal - Complete Section-wise View -->
<div id="detailsModal" class="fixed inset-0 bg-black/70 hidden items-center justify-center z-50">
    <div class="bg-white dark:bg-gray-800 rounded-xl max-w-5xl w-full mx-4 overflow-hidden max-h-[90vh] shadow-2xl">
        <div class="flex justify-between items-center p-4 bg-gradient-to-r from-blue-600 to-blue-700">
            <h3 class="text-white font-semibold">
                <i class="fas fa-syringe mr-2"></i>Vaccination Request Details
            </h3>
            <button onclick="closeDetailsModal()" class="text-white hover:text-gray-200">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div id="modalContent" class="p-5 overflow-y-auto" style="max-height: calc(90vh - 60px);">
            <div class="text-center py-12">
                <i class="fas fa-spinner fa-spin text-2xl text-blue-500"></i>
                <p class="mt-2 text-gray-500 text-sm">Loading details...</p>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let selectedRequests = new Set();
    
    function refreshPage() { window.location.reload(); }
    
    // Quick approve without modal
    async function quickApprove(requestId) {
        const result = await Swal.fire({
            title: 'Approve Request?',
            text: 'Are you sure you want to approve this vaccination request?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#22c55e',
            confirmButtonText: 'Yes, Approve',
            cancelButtonText: 'Cancel'
        });
        
        if (result.isConfirmed) {
            Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            
            try {
                const response = await fetch(`/admin/api/vaccination-request/${requestId}/verify`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'approve', notes: '' })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Approved!', text: data.message, timer: 1500, showConfirmButton: false })
                        .then(() => window.location.reload());
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Failed to approve' });
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Network error. Please try again.' });
            }
        }
    }
    
    // Quick reject without modal
    async function quickReject(requestId) {
        const result = await Swal.fire({
            title: 'Reject Request?',
            text: 'Are you sure you want to reject this vaccination request?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            confirmButtonText: 'Yes, Reject',
            cancelButtonText: 'Cancel'
        });
        
        if (result.isConfirmed) {
            Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            
            try {
                const response = await fetch(`/admin/api/vaccination-request/${requestId}/verify`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'reject', notes: '' })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Rejected!', text: data.message, timer: 1500, showConfirmButton: false })
                        .then(() => window.location.reload());
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Failed to reject' });
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Network error. Please try again.' });
            }
        }
    }
    
    // View request details
    async function viewRequestDetails(requestId) {
        const modal = document.getElementById('detailsModal');
        const modalContent = document.getElementById('modalContent');
        
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modalContent.innerHTML = '<div class="text-center py-12"><i class="fas fa-spinner fa-spin text-2xl text-blue-500"></i><p class="mt-2 text-gray-500 text-sm">Loading details...</p></div>';
        
        try {
            const response = await fetch(`/admin/api/vaccination-request/${requestId}`);
            const data = await response.json();
            
            if (data.success && data.verification) {
                renderDetailedModal(data.verification);
            } else {
                modalContent.innerHTML = `<div class="text-center py-12 text-red-500 text-sm"><i class="fas fa-exclamation-circle text-3xl mb-2"></i><p>Failed to load details: ${data.message || 'Unknown error'}</p></div>`;
            }
        } catch (error) {
            console.error('Error:', error);
            modalContent.innerHTML = `<div class="text-center py-12 text-red-500 text-sm"><i class="fas fa-exclamation-circle text-3xl mb-2"></i><p>Error loading details. Please try again.</p></div>`;
        }
    }
    
    function renderDetailedModal(data) {
        const modalContent = document.getElementById('modalContent');
        
        // Extract data with proper fallbacks
        const animal = data.animal || {};
        const farmer = data.farmer || {};
        const vaccine = data.vaccine || {};
        const payment = data.payment || {};
        const paravet = data.assignedParavet || {};
        const paravetUser = paravet.user || {};
        
        // Format dates
        const submittedDate = data.createdAt ? new Date(data.createdAt).toLocaleString() : 'N/A';
        const adminDate = data.dateAdministered ? new Date(data.dateAdministered).toLocaleDateString() : 'N/A';
        const nextDueDate = data.nextDueDate ? new Date(data.nextDueDate).toLocaleDateString() : 'N/A';
        
        modalContent.innerHTML = `
            <div class="space-y-4">
                <!-- Status Bar -->
                <div class="flex items-center justify-between p-3 rounded-lg ${data.verificationStatus === 'Pending' ? 'bg-yellow-50 border-l-4 border-yellow-500' : (data.verificationStatus === 'Verified' ? 'bg-green-50 border-l-4 border-green-500' : 'bg-red-50 border-l-4 border-red-500')}">
                    <div>
                        <p class="text-xs text-gray-500">Request Status</p>
                        <p class="font-semibold ${data.verificationStatus === 'Pending' ? 'text-yellow-700' : (data.verificationStatus === 'Verified' ? 'text-green-700' : 'text-red-700')}">
                            ${data.verificationStatus || 'Pending'}
                        </p>
                    </div>
                    <div class="text-right">
                        <p class="text-xs text-gray-500">Submitted</p>
                        <p class="text-sm font-medium">${submittedDate}</p>
                    </div>
                    <div class="text-right">
                        <p class="text-xs text-gray-500">Administered By</p>
                        <p class="text-sm font-medium">${data.administeredBy || 'N/A'}</p>
                    </div>
                </div>
                
                <!-- Two Column Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Paravet Info Card -->
                    <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4">
                        <h4 class="font-semibold text-sm mb-3 flex items-center gap-2 text-blue-700">
                            <i class="fas fa-user-md"></i> Paravet Information
                        </h4>
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between"><span class="text-gray-600">Name:</span><span class="font-medium">${paravetUser.name || data.submittedBy?.name || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Email:</span><span>${paravetUser.email || data.submittedBy?.email || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Employee Code:</span><span>${paravet.employeeCode || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Qualification:</span><span>${paravet.qualification || 'N/A'}</span></div>
                        </div>
                    </div>
                    
                    <!-- Farmer Info Card -->
                    <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4">
                        <h4 class="font-semibold text-sm mb-3 flex items-center gap-2 text-green-700">
                            <i class="fas fa-user"></i> Farmer Information
                        </h4>
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between"><span class="text-gray-600">Name:</span><span class="font-medium">${farmer.name || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Mobile:</span><span>${farmer.mobileNumber || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Farmer ID:</span><span>${farmer.uniqueFarmerId || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Village:</span><span>${farmer.address?.village || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">District:</span><span>${farmer.address?.district || 'N/A'}</span></div>
                        </div>
                    </div>
                </div>
                
                <!-- Animal & Vaccine Info -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Animal Info Card -->
                    <div class="bg-purple-50 dark:bg-purple-900/20 rounded-lg p-4">
                        <h4 class="font-semibold text-sm mb-3 flex items-center gap-2 text-purple-700">
                            <i class="fas fa-paw"></i> Animal Information
                        </h4>
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between"><span class="text-gray-600">Name:</span><span class="font-medium">${animal.name || 'Unnamed'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Type:</span><span>${animal.animalType || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Breed:</span><span>${animal.breed || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Gender:</span><span>${animal.gender || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Tag Number:</span><span>${animal.tagNumber || 'N/A'}</span></div>
                        </div>
                    </div>
                    
                    <!-- Vaccine Info Card -->
                    <div class="bg-indigo-50 dark:bg-indigo-900/20 rounded-lg p-4">
                        <h4 class="font-semibold text-sm mb-3 flex items-center gap-2 text-indigo-700">
                            <i class="fas fa-syringe"></i> Vaccine Information
                        </h4>
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between"><span class="text-gray-600">Vaccine:</span><span class="font-medium">${vaccine.name || data.vaccineName || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Type:</span><span>${vaccine.vaccineType || data.vaccineType || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Disease:</span><span>${vaccine.diseaseTarget || 'N/A'}</span></div>
                            <div class="flex justify-between"><span class="text-gray-600">Booster:</span><span>${vaccine.boosterIntervalWeeks ? vaccine.boosterIntervalWeeks + ' weeks' : (vaccine.immunityDurationMonths ? vaccine.immunityDurationMonths + ' months' : 'N/A')}</span></div>
                        </div>
                    </div>
                </div>
                
                <!-- Vaccination Details -->
                <div class="bg-gray-50 dark:bg-gray-700/30 rounded-lg p-4">
                    <h4 class="font-semibold text-sm mb-3 flex items-center gap-2 text-gray-700">
                        <i class="fas fa-calendar-check"></i> Vaccination Details
                    </h4>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                        <div><span class="text-gray-500">Administered:</span><div class="font-medium">${adminDate}</div></div>
                        <div><span class="text-gray-500">Next Due:</span><div class="font-medium">${nextDueDate}</div></div>
                        <div><span class="text-gray-500">Batch:</span><div>${data.batchNumber || 'N/A'}</div></div>
                        <div><span class="text-gray-500">Administered By:</span><div>${data.administeredBy || 'N/A'}</div></div>
                        <div><span class="text-gray-500">Dosage:</span><div>${data.dosageAmount || 1} ${data.dosageUnit || 'ml'}</div></div>
                        <div><span class="text-gray-500">Method:</span><div>${data.administrationMethod || 'Injection'}</div></div>
                        <div><span class="text-gray-500">Site:</span><div>${data.injectionSite || 'Subcutaneous'}</div></div>
                        <div><span class="text-gray-500">Dose:</span><div>${data.doseNumber}/${data.totalDosesRequired || 1}</div></div>
                    </div>
                    ${data.notes ? `<div class="mt-3 pt-2 border-t"><span class="text-gray-500 text-sm">Notes:</span><p class="text-sm mt-1">${data.notes}</p></div>` : ''}
                </div>
                
                <!-- Payment Summary -->
                <div class="bg-yellow-50 dark:bg-yellow-900/20 rounded-lg p-4">
                    <h4 class="font-semibold text-sm mb-3 flex items-center gap-2 text-yellow-700">
                        <i class="fas fa-rupee-sign"></i> Payment Summary
                    </h4>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                        <div><span class="text-gray-500">Vaccine Price:</span><div class="font-medium">₹${payment.vaccinePrice || data.vaccine?.vaccineCharge || 0}</div></div>
                        <div><span class="text-gray-500">Service Charge:</span><div>₹${payment.serviceCharge || 50}</div></div>
                        <div><span class="text-gray-500">Total:</span><div class="font-bold text-green-600">₹${payment.totalAmount || data.totalAmount || 0}</div></div>
                        <div><span class="text-gray-500">Method:</span><div>${payment.paymentMethod || 'Cash'}</div></div>
                        <div><span class="text-gray-500">Status:</span><div class="font-medium ${payment.paymentStatus === 'Completed' ? 'text-green-600' : 'text-yellow-600'}">${payment.paymentStatus || 'Pending'}</div></div>
                        ${payment.utrNumber ? `<div><span class="text-gray-500">UTR:</span><div class="text-xs">${payment.utrNumber}</div></div>` : ''}
                        ${payment.receiptNumber ? `<div><span class="text-gray-500">Receipt:</span><div>${payment.receiptNumber}</div></div>` : ''}
                    </div>
                </div>
                
                <!-- Action Buttons (Only for Pending) -->
                ${data.verificationStatus === 'Pending' ? `
                    <div class="flex gap-3 justify-end pt-3 border-t">
                        <button onclick="closeDetailsModal(); quickReject('${data._id}')" 
                                class="px-5 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition flex items-center gap-2">
                            <i class="fas fa-times"></i> Reject Request
                        </button>
                        <button onclick="closeDetailsModal(); quickApprove('${data._id}')" 
                                class="px-5 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition flex items-center gap-2">
                            <i class="fas fa-check"></i> Approve Request
                        </button>
                    </div>
                ` : ''}
            </div>
        `;
    }
    
    // Confirm single action (for modal buttons)
    async function confirmAction(requestId, action) {
        if (action === 'approve') {
            await quickApprove(requestId);
        } else {
            await quickReject(requestId);
        }
    }
    
    // Bulk approve
    async function bulkApprove() {
        const checkboxes = document.querySelectorAll('.request-checkbox:checked');
        if (checkboxes.length === 0) {
            Swal.fire({ icon: 'warning', title: 'No Selection', text: 'Please select at least one request' });
            return;
        }
        const ids = Array.from(checkboxes).map(cb => cb.dataset.id);
        const result = await Swal.fire({ title: 'Bulk Approve', text: `Approve ${ids.length} request(s)?`, icon: 'question', showCancelButton: true, confirmButtonText: 'Yes, Approve All' });
        if (result.isConfirmed) {
            Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const response = await fetch('/admin/verifications/bulk-verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ ids: ids, action: 'approve', notes: '' }) });
                const data = await response.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Success!', text: data.message, timer: 1500, showConfirmButton: false }).then(() => window.location.reload());
                } else { Swal.fire({ icon: 'error', title: 'Error', text: data.message }); }
            } catch (error) { Swal.fire({ icon: 'error', title: 'Error', text: 'Network error' }); }
        }
    }
    
    // Bulk reject
    async function bulkReject() {
        const checkboxes = document.querySelectorAll('.request-checkbox:checked');
        if (checkboxes.length === 0) {
            Swal.fire({ icon: 'warning', title: 'No Selection', text: 'Please select at least one request' });
            return;
        }
        const ids = Array.from(checkboxes).map(cb => cb.dataset.id);
        const result = await Swal.fire({ title: 'Bulk Reject', text: `Reject ${ids.length} request(s)?`, icon: 'warning', showCancelButton: true, confirmButtonText: 'Yes, Reject All' });
        if (result.isConfirmed) {
            Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const response = await fetch('/admin/verifications/bulk-verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ ids: ids, action: 'reject', notes: '' }) });
                const data = await response.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Success!', text: data.message, timer: 1500, showConfirmButton: false }).then(() => window.location.reload());
                } else { Swal.fire({ icon: 'error', title: 'Error', text: data.message }); }
            } catch (error) { Swal.fire({ icon: 'error', title: 'Error', text: 'Network error' }); }
        }
    }
    
    function updateSelectedCount() {
        const checkboxes = document.querySelectorAll('.request-checkbox:checked');
        selectedRequests.clear();
        checkboxes.forEach(cb => selectedRequests.add(cb.dataset.id));
        document.getElementById('selectedCount').innerText = `${selectedRequests.size} selected`;
        document.getElementById('bulkApproveBtn').disabled = selectedRequests.size === 0;
        document.getElementById('bulkRejectBtn').disabled = selectedRequests.size === 0;
    }
    
    document.getElementById('selectAllCheckbox')?.addEventListener('change', function() {
        document.querySelectorAll('.request-checkbox').forEach(cb => cb.checked = this.checked);
        updateSelectedCount();
    });
    document.addEventListener('change', function(e) {
        if (e.target.classList?.contains('request-checkbox')) updateSelectedCount();
    });
    
    function closeDetailsModal() {
        document.getElementById('detailsModal').classList.add('hidden');
        document.getElementById('detailsModal').classList.remove('flex');
    }
    document.getElementById('detailsModal')?.addEventListener('click', function(e) { if (e.target === this) closeDetailsModal(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeDetailsModal(); });
    
    updateSelectedCount();
</script>

<style>
    .border-l-3 { border-left-width: 3px; }
    .request-card:hover { transform: translateY(-1px); transition: all 0.2s ease; }
</style>