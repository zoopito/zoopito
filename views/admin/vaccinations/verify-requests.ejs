    .request-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px -12px rgba(0,0,0,0.15);
    }
    .filter-tab {
        transition: all 0.2s ease;
        cursor: pointer;
    }
    .filter-tab:hover {
        transform: translateY(-1px);
