<% layout("layouts/boilerplate") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header Section -->
    <div class="mb-8">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
            Farmers Management
          </h1>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Manage all registered farmers, track their animals, and monitor health records
          </p>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700">
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Farmers</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= totalCount || 0 %></p>
          </div>
          <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700">
            <p class="text-sm text-gray-500 dark:text-gray-400">Active</p>
            <p class="text-2xl font-bold text-green-600 dark:text-green-400 mt-1"><%= activeCount || 0 %></p>
          </div>
          <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700">
            <p class="text-sm text-gray-500 dark:text-gray-400">This Month</p>
            <p class="text-2xl font-bold text-blue-600 dark:text-blue-400 mt-1"><%= monthlyCount || 0 %></p>
          </div>
          <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700">
            <p class="text-sm text-gray-500 dark:text-gray-400">Avg Animals</p>
            <p class="text-2xl font-bold text-purple-600 dark:text-purple-400 mt-1"><%= avgAnimals ? avgAnimals.toFixed(1) : 0 %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Bar -->
    <div class="mb-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <!-- Search and Filters -->
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="relative">
            <input 
              type="text" 
              id="searchInput"
              placeholder="Search by name, mobile, ID..." 
              value="<%= searchQuery || '' %>"
              class="pl-10 pr-4 py-2 w-full sm:w-64 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            >
            <svg class="absolute left-3 top-2.5 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>

          <select id="villageFilter" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Villages</option>
            <% if (uniqueVillages && uniqueVillages.length > 0) { %>
              <% uniqueVillages.forEach(village => { %>
                <option value="<%= village %>" <%= selectedVillage === village ? 'selected' : '' %>><%= village %></option>
              <% }) %>
            <% } %>
          </select>

          <select id="statusFilter" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">Status: All</option>
            <option value="active" <%= statusFilter === 'active' ? 'selected' : '' %>>Active</option>
            <option value="inactive" <%= statusFilter === 'inactive' ? 'selected' : '' %>>Inactive</option>
          </select>

          <select id="paravetFilter" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Paravets</option>
            <% if (paravets && paravets.length > 0) { %>
              <% paravets.forEach(paravet => { %>
                <option value="<%= paravet._id %>" <%= selectedParavet === paravet._id.toString() ? 'selected' : '' %>><%= paravet.user?.name || 'Unknown' %></option>
              <% }) %>
            <% } %>
          </select>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-wrap gap-3">
          <% if(['ADMIN', 'SALES'].includes(currUser.role)){ %>
            <a 
              href="<%= currUser.role === 'ADMIN' ? '/admin/farmers/new' : '/sales/farmers/new' %>"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-green-500 to-green-600 text-white font-medium rounded-lg hover:from-green-600 hover:to-green-700 transition-all shadow-md hover:shadow-lg"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
              Add New Farmer
            </a>
          <% } %>

          <button onclick="exportFarmers()" class="inline-flex items-center gap-2 px-5 py-2.5 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h9m5-4v12m0 0l-4-4m4 4l4-4"/>
            </svg>
            Export
          </button>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 relative">
      
      <!-- Table Header -->
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            All Farmers (<span id="farmerCount"><%= farmers.length %></span>)
          </h2>
          <div class="text-sm text-gray-500 dark:text-gray-400">
            Showing <span id="startRange"><%= ((currentPage - 1) * limit) + 1 %></span>-<span id="endRange"><%= Math.min(currentPage * limit, totalCount) %></span> of <span id="totalCount"><%= totalCount %></span>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-100 dark:bg-gray-700">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider cursor-pointer hover:text-blue-600" onclick="sortBy('name')">
                Farmer
                <span id="sort-name" class="ml-1 inline-block"></span>
              </th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider hidden lg:table-cell cursor-pointer hover:text-blue-600" onclick="sortBy('location')">
                Location
                <span id="sort-location" class="ml-1 inline-block"></span>
              </th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider cursor-pointer hover:text-blue-600" onclick="sortBy('contact')">
                Contact
                <span id="sort-contact" class="ml-1 inline-block"></span>
              </th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider hidden md:table-cell">
                Stats
              </th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>

          <tbody id="farmersTableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
            <% if (farmers.length === 0) { %>
              <tr id="noFarmersRow">
                <td colspan="5" class="px-6 py-12 text-center">
                  <div class="mx-auto w-24 h-24 text-gray-400 mb-4">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                    </svg>
                  </div>
                  <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No farmers found</h3>
                  <p class="text-gray-500 dark:text-gray-400 mb-4">Get started by adding your first farmer</p>
                  <% if(['ADMIN', 'SALES'].includes(currUser.role)){ %>
                    <a 
                      href="<%= currUser.role === 'ADMIN' ? '/admin/farmers/new' : '/sales/farmers/new' %>"
                      class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                      </svg>
                      Add First Farmer
                    </a>
                  <% } %>
                </td>
              </tr>
            <% } %>

            <% farmers.forEach(farmer => { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors farmer-row" data-farmer-id="<%= farmer._id %>">
                <!-- Farmer Profile Column -->
                <td class="px-6 py-4">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-12 w-12 mr-4">
                      <% if(farmer.photo && farmer.photo.url) { %>
                        <img 
                          src="<%= farmer.photo.url %>" 
                          alt="<%= farmer.name %>"
                          class="h-12 w-12 rounded-full object-cover border-2 border-white dark:border-gray-700 shadow-sm"
                        >
                      <% } else { %>
                        <div class="h-12 w-12 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center text-white font-bold text-lg">
                          <%= farmer.name ? farmer.name.charAt(0).toUpperCase() : 'F' %>
                        </div>
                      <% } %>
                    </div>

                    <div>
                      <div class="flex items-center gap-2 flex-wrap">
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-white">
                          <%= farmer.name || "Unnamed Farmer" %>
                        </h3>
                        <% if(farmer.isActive) { %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                            Active
                          </span>
                        <% } else { %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                            Inactive
                          </span>
                        <% } %>
                      </div>
                      <div class="mt-1 flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400 flex-wrap">
                        <span class="flex items-center gap-1">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                          </svg>
                          ID: <code class="ml-1 font-mono text-xs"><%= farmer.uniqueFarmerId || 'PENDING' %></code>
                        </span>
                        <span class="hidden sm:inline-flex items-center gap-1">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                          </svg>
                          <%= new Date(farmer.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                        </span>
                      </div>
                    </div>
                  </div>
                </td>

                <!-- Location Column -->
                <td class="px-6 py-4 hidden lg:table-cell">
                  <div class="space-y-1">
                    <% if(farmer.address && farmer.address.village) { %>
                      <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        <span class="font-medium text-gray-900 dark:text-white"><%= farmer.address.village %></span>
                      </div>
                      <div class="text-sm text-gray-500 dark:text-gray-400 ml-6">
                        <%= farmer.address.taluka || '' %><%= farmer.address.taluka && farmer.address.district ? ', ' : '' %><%= farmer.address.district || '' %>
                      </div>
                    <% } else { %>
                      <span class="text-gray-400 italic">Location not set</span>
                    <% } %>
                    
                    <% if(farmer.totalAnimals > 0) { %>
                      <div class="mt-2">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                          <%= farmer.totalAnimals %> animal<%= farmer.totalAnimals !== 1 ? 's' : '' %>
                        </span>
                      </div>
                    <% } %>
                  </div>
                </td>

                <!-- Contact Column -->
                <td class="px-6 py-4">
                  <div class="space-y-1">
                    <a 
                      href="tel:<%= farmer.mobileNumber %>" 
                      class="flex items-center gap-2 text-sm font-medium text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                      </svg>
                      <%= farmer.mobileNumber || 'Not provided' %>
                    </a>
                    
                    <% if(farmer.assignedParavet && farmer.assignedParavet.user) { %>
                      <div class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                        Paravet: <%= farmer.assignedParavet.user.name %>
                      </div>
                    <% } %>
                  </div>
                </td>

                <!-- Stats Column -->
                <td class="px-6 py-4 hidden md:table-cell">
                  <div class="space-y-2">
                    <div class="flex items-center gap-2">
                      <% if(farmer.totalAnimals > 0) { %>
                        <div class="flex -space-x-2">
                          <% for(let i = 0; i < Math.min(farmer.totalAnimals, 4); i++) { %>
                            <div class="w-6 h-6 rounded-full bg-gradient-to-br from-green-400 to-green-500 border-2 border-white dark:border-gray-800 flex items-center justify-center text-white text-[10px] font-bold">
                              <%= ['🐄','🐃','🐐','🐑'][i % 4] %>
                            </div>
                          <% } %>
                          <% if(farmer.totalAnimals > 4) { %>
                            <div class="w-6 h-6 rounded-full bg-gray-300 dark:bg-gray-600 border-2 border-white dark:border-gray-800 flex items-center justify-center text-xs font-medium">
                              +<%= farmer.totalAnimals - 4 %>
                            </div>
                          <% } %>
                        </div>
                      <% } else { %>
                        <span class="text-sm text-gray-400">No animals</span>
                      <% } %>
                    </div>
                    <% if(farmer.lastVisitDate) { %>
                      <div class="text-xs text-gray-500 dark:text-gray-400">
                        Last visit: <%= new Date(farmer.lastVisitDate).toLocaleDateString() %>
                      </div>
                    <% } %>
                  </div>
                </td>

                <!-- Actions Column -->
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <!-- View Button -->
                    <a 
                      href="<%= currUser.role === 'ADMIN' ? '/admin/farmers/' + farmer._id : '/sales/farmers/' + farmer._id %>"
                      class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors"
                      title="View Details"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                      </svg>
                      View
                    </a>

                    <!-- More Actions Dropdown -->
                    <div class="relative" data-dropdown-container="<%= farmer._id %>">
                      <button 
                        class="p-1.5 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg"
                        onclick="toggleDropdown(event, '<%= farmer._id %>')"
                      >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/>
                        </svg>
                      </button>
                      
                      <div 
                        id="dropdown-<%= farmer._id %>" 
                        class="hidden fixed w-56 bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 z-50"
                      >
                        <a 
                          href="<%= currUser.role === 'ADMIN' ? '/admin/farmers/' + farmer._id + '/animals' : '/sales/farmers/' + farmer._id + '/animals' %>"
                          class="flex items-center gap-2 px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700"
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                          </svg>
                          Manage Animals
                        </a>
                        
                        <a 
                          href="<%= currUser.role === 'ADMIN' ? '/admin/farmers/' + farmer._id + '/edit' : '/sales/farmers/' + farmer._id + '/edit' %>"
                          class="flex items-center gap-2 px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700"
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                          </svg>
                          Edit Details
                        </a>
                        
                        <a 
                          href="<%= currUser.role === 'ADMIN' ? '/admin/farmers/' + farmer._id + '/vaccinations' : '/sales/farmers/' + farmer._id + '/vaccinations' %>"
                          class="flex items-center gap-2 px-4 py-3 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700"
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                          </svg>
                          Vaccination History
                        </a>
                        
                        <% if(currUser.role === 'ADMIN'){ %>
                          <hr class="border-gray-200 dark:border-gray-700">
                          
                          <button 
                            type="button"
                            onclick="toggleStatus('<%= farmer._id %>', `<%= farmer.isActive %>`)"
                            class="flex items-center gap-2 w-full text-left px-4 py-3 text-sm <%= farmer.isActive ? 'text-amber-600 dark:text-amber-400' : 'text-green-600 dark:text-green-400' %> hover:bg-gray-100 dark:hover:bg-gray-700"
                          >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <%= farmer.isActive ? 'Deactivate' : 'Activate' %>
                          </button>
                          
                          <button 
                            type="button"
                            onclick="confirmDelete('<%= farmer._id %>')"
                            class="flex items-center gap-2 w-full text-left px-4 py-3 text-sm text-red-600 dark:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700"
                          >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                            Delete Farmer
                          </button>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="text-sm text-gray-700 dark:text-gray-300">
              Page <span class="font-medium"><%= currentPage %></span> of <span class="font-medium"><%= totalPages %></span>
            </div>

            <div class="flex items-center justify-center gap-2 flex-wrap">
              <a 
                href="?page=1<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= selectedVillage ? '&village=' + encodeURIComponent(selectedVillage) : '' %><%= statusFilter ? '&status=' + statusFilter : '' %><%= selectedParavet ? '&paravet=' + selectedParavet : '' %>"
                class="inline-flex items-center px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 <%= currentPage === 1 ? 'opacity-50 cursor-not-allowed' : '' %>"
                <%= currentPage === 1 ? 'aria-disabled="true"' : '' %>>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
                </svg>
              </a>

              <a 
                href="?page=<%= currentPage - 1 %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= selectedVillage ? '&village=' + encodeURIComponent(selectedVillage) : '' %><%= statusFilter ? '&status=' + statusFilter : '' %><%= selectedParavet ? '&paravet=' + selectedParavet : '' %>"
                class="inline-flex items-center px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 <%= currentPage === 1 ? 'opacity-50 cursor-not-allowed' : '' %>"
                <%= currentPage === 1 ? 'aria-disabled="true"' : '' %>>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </a>

              <% 
                let startPage = Math.max(1, currentPage - 2);
                let endPage = Math.min(totalPages, currentPage + 2);
                
                if (startPage > 1) { %>
                  <span class="px-3 py-2 text-gray-500">...</span>
              <% } %>
              
              <% for (let i = startPage; i <= endPage; i++) { %>
                <a 
                  href="?page=<%= i %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= selectedVillage ? '&village=' + encodeURIComponent(selectedVillage) : '' %><%= statusFilter ? '&status=' + statusFilter : '' %><%= selectedParavet ? '&paravet=' + selectedParavet : '' %>"
                  class="inline-flex items-center justify-center w-10 h-10 rounded-lg <%= i === currentPage ? 'bg-blue-600 text-white' : 'border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700' %>"
                >
                  <%= i %>
                </a>
              <% } %>
              
              <% if (endPage < totalPages) { %>
                <span class="px-3 py-2 text-gray-500">...</span>
              <% } %>

              <a 
                href="?page=<%= currentPage + 1 %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= selectedVillage ? '&village=' + encodeURIComponent(selectedVillage) : '' %><%= statusFilter ? '&status=' + statusFilter : '' %><%= selectedParavet ? '&paravet=' + selectedParavet : '' %>"
                class="inline-flex items-center px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 <%= currentPage === totalPages ? 'opacity-50 cursor-not-allowed' : '' %>"
                <%= currentPage === totalPages ? 'aria-disabled="true"' : '' %>>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>

              <a 
                href="?page=<%= totalPages %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= selectedVillage ? '&village=' + encodeURIComponent(selectedVillage) : '' %><%= statusFilter ? '&status=' + statusFilter : '' %><%= selectedParavet ? '&paravet=' + selectedParavet : '' %>"
                class="inline-flex items-center px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 <%= currentPage === totalPages ? 'opacity-50 cursor-not-allowed' : '' %>"
                <%= currentPage === totalPages ? 'aria-disabled="true"' : '' %>>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
                </svg>
              </a>
            </div>

            <div class="text-sm text-gray-500 dark:text-gray-400">
              <%= totalCount %> total farmers
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  // ================ DROPDOWN FUNCTIONS ================
  
  function toggleDropdown(event, farmerId) {
    event.stopPropagation();
    const dropdown = document.getElementById(`dropdown-${farmerId}`);
    const button = event.currentTarget;
    const isHidden = dropdown.classList.contains('hidden');
    
    // Close other dropdowns
    document.querySelectorAll('[id^="dropdown-"]').forEach(drop => {
      drop.classList.add('hidden');
    });
    
    if (isHidden) {
      dropdown.classList.remove('hidden');
      
      // Position dropdown relative to button
      const rect = button.getBoundingClientRect();
      dropdown.style.top = (rect.bottom + 5) + 'px';
      dropdown.style.left = (rect.left - 200 + button.offsetWidth) + 'px';
      dropdown.style.position = 'fixed';
    }
  }

  // Close dropdowns when clicking outside
  document.addEventListener('click', function(event) {
    if (!event.target.closest('[data-dropdown-container]')) {
      document.querySelectorAll('[id^="dropdown-"]').forEach(drop => {
        drop.classList.add('hidden');
      });
    }
  });

  // ================ FILTER FUNCTIONS ================

  let searchTimeout;

  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const villageFilter = document.getElementById('villageFilter');
    const statusFilter = document.getElementById('statusFilter');
    const paravetFilter = document.getElementById('paravetFilter');

    function applyFilters() {
      const params = new URLSearchParams();
      params.set('page', '1');
      
      const search = searchInput?.value;
      if (search) params.set('search', search);
      
      const village = villageFilter?.value;
      if (village) params.set('village', village);
      
      const status = statusFilter?.value;
      if (status) params.set('status', status);
      
      const paravet = paravetFilter?.value;
      if (paravet) params.set('paravet', paravet);
      
      window.location.href = `?${params.toString()}`;
    }

    if (searchInput) {
      searchInput.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(applyFilters, 500);
      });
    }
    
    if (villageFilter) villageFilter.addEventListener('change', applyFilters);
    if (statusFilter) statusFilter.addEventListener('change', applyFilters);
    if (paravetFilter) paravetFilter.addEventListener('change', applyFilters);
  });

  // ================ SORTING FUNCTIONS ================

  let currentSort = `<%= sortBy || '' %>`;
  let currentOrder = `<%= sortOrder || 'asc' %>`;

  function sortBy(field) {
    if (currentSort === field) {
      currentOrder = currentOrder === 'asc' ? 'desc' : 'asc';
    } else {
      currentSort = field;
      currentOrder = 'asc';
    }
    
    const params = new URLSearchParams(window.location.search);
    params.set('sortBy', currentSort);
    params.set('sortOrder', currentOrder);
    params.set('page', '1');
    
    window.location.href = `?${params.toString()}`;
  }

  // ================ STATUS FUNCTIONS ================

  async function toggleStatus(farmerId, currentStatus) {
    const action = currentStatus ? "Deactivate" : "Activate";
    if (!confirm(`Are you sure you want to ${action} this farmer?`)) return;

    showLoading();
    try {
      const res = await fetch(`/admin/farmers/${farmerId}/toggle-status`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
      });
      const data = await res.json();
      hideLoading();
      if (data.success) {
        window.location.reload();
      } else {
        alert(data.message || "Something went wrong");
      }
    } catch (err) {
      hideLoading();
      alert("Unable to update farmer status");
    }
  }

  // ================ DELETE FUNCTIONS ================

  async function confirmDelete(farmerId) {
    if (!confirm("⚠️ This action cannot be undone. Delete this farmer permanently?")) return;

    showLoading();
    try {
      const res = await fetch(`/admin/farmers/${farmerId}`, {
        method: "DELETE",
        headers: { "Content-Type": "application/json" },
      });
      const data = await res.json();
      hideLoading();
      if (data.success) {
        alert(data.message || "Farmer deleted successfully");
        window.location.href = "/admin/farmers";
      } else {
        alert(data.message || "Delete failed");
      }
    } catch (err) {
      hideLoading();
      alert("Unable to delete farmer");
    }
  }

  // ================ EXPORT FUNCTIONS ================

  function exportFarmers() {
    const format = confirm("Export as CSV? Click OK for CSV, Cancel for Excel");
    const exportFormat = format ? 'csv' : 'excel';
    
    const params = new URLSearchParams();
    params.set('format', exportFormat);
    
    const search = document.getElementById('searchInput')?.value;
    if (search) params.set('search', search);
    
    const village = document.getElementById('villageFilter')?.value;
    if (village) params.set('village', village);
    
    const status = document.getElementById('statusFilter')?.value;
    if (status) params.set('status', status);
    
    window.location.href = `/admin/farmers/export?${params.toString()}`;
  }

  // ================ LOADING FUNCTIONS ================

  function showLoading() {
    let loader = document.getElementById('globalLoader');
    if (!loader) {
      loader = document.createElement('div');
      loader.id = 'globalLoader';
      loader.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-50';
      loader.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 flex items-center space-x-4 shadow-2xl">
          <svg class="animate-spin h-8 w-8 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="text-gray-700 dark:text-gray-300 font-medium">Processing...</span>
        </div>
      `;
      document.body.appendChild(loader);
    }
    loader.classList.remove('hidden');
  }

  function hideLoading() {
    const loader = document.getElementById('globalLoader');
    if (loader) loader.classList.add('hidden');
  }
</script>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin {
    animation: spin 1s linear infinite;
  }
</style>