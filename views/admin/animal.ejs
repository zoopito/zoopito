<% layout("layouts/boilerplate") %>

<div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-6 py-4 lg:py-6">

  <!-- Header with Bulk Actions -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 lg:mb-8 space-y-3 md:space-y-0">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-800 dark:text-gray-100">Animals Management</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Manage all registered animals and their farmers</p>
    </div>

    <div class="flex flex-wrap gap-2">
      <% if(currUser.role == "ADMIN"){ %>
        <a href="/admin/animals/new" class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white rounded-lg text-sm font-medium transition-colors duration-200 shadow-md hover:shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Single Registration
        </a>
        <a href="/admin/animals/new?type=bulk" class="inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 dark:bg-green-500 dark:hover:bg-green-600 text-white rounded-lg text-sm font-medium transition-colors duration-200 shadow-md hover:shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          Bulk Registration
        </a>
      <% } else { %>
        <a href="/sales/animals/new" class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white rounded-lg text-sm font-medium transition-colors duration-200 shadow-md hover:shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add New Animal
        </a>
      <% } %>
    </div>
  </div>

  <!-- Enhanced Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-3 sm:gap-4 mb-6 lg:mb-8">
    <!-- Total Animals -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-xl p-4 border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-blue-100 dark:bg-blue-900/30 p-2 rounded-lg">
          <svg class="h-5 w-5 text-blue-600 dark:text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400">Total Animals</p>
          <p class="text-xl font-bold text-gray-800 dark:text-gray-100"><%= totalAnimals || 0 %></p>
          <p class="text-xs text-green-600 dark:text-green-400 mt-0.5">
            <span class="font-medium"><%= totalActive || 0 %></span> active
          </p>
        </div>
      </div>
    </div>

    <!-- Today's Registrations -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-xl p-4 border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-green-100 dark:bg-green-900/30 p-2 rounded-lg">
          <svg class="h-5 w-5 text-green-600 dark:text-green-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400">Today's Registrations</p>
          <p class="text-xl font-bold text-gray-800 dark:text-gray-100"><%= todayRegistrations || 0 %></p>
        </div>
      </div>
    </div>

    <!-- Bulk Batches -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-xl p-4 border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-purple-100 dark:bg-purple-900/30 p-2 rounded-lg">
          <svg class="h-5 w-5 text-purple-600 dark:text-purple-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400">Bulk Batches</p>
          <p class="text-xl font-bold text-gray-800 dark:text-gray-100"><%= totalBatches || 0 %></p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
            <%= bulkAnimalCount || 0 %> animals
          </p>
        </div>
      </div>
    </div>

    <!-- Pregnant Animals -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-xl p-4 border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-pink-100 dark:bg-pink-900/30 p-2 rounded-lg">
          <svg class="h-5 w-5 text-pink-600 dark:text-pink-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400">Pregnant Animals</p>
          <p class="text-xl font-bold text-gray-800 dark:text-gray-100"><%= pregnantAnimals || 0 %></p>
        </div>
      </div>
    </div>

    <!-- Vaccinated Animals -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-xl p-4 border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-teal-100 dark:bg-teal-900/30 p-2 rounded-lg">
          <svg class="h-5 w-5 text-teal-600 dark:text-teal-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400">Vaccinated</p>
          <p class="text-xl font-bold text-gray-800 dark:text-gray-100"><%= vaccinatedCount || 0 %></p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
            <%= Math.round((vaccinatedCount / totalAnimals) * 100) || 0 %>% coverage
          </p>
        </div>
      </div>
    </div>

    <!-- Overdue Vaccinations -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-xl p-4 border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-red-100 dark:bg-red-900/30 p-2 rounded-lg">
          <svg class="h-5 w-5 text-red-600 dark:text-red-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400">Overdue Vaccinations</p>
          <p class="text-xl font-bold text-red-600 dark:text-red-400"><%= overdueCount || 0 %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Animal Type Distribution Chart (Quick Stats) -->
  <div class="bg-white dark:bg-gray-800 shadow rounded-xl p-4 mb-6 border border-gray-200 dark:border-gray-700">
    <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Animal Type Distribution</h3>
    <div class="flex flex-wrap gap-4">
      <% if (animalTypeStats && animalTypeStats.length > 0) { %>
      <%  const colors = ['blue', 'green', 'purple', 'orange', 'pink', 'teal', 'indigo', 'red']; %>
      
     <% animalTypeStats.forEach((type, idx) => { %>
      <%    const percentage = Math.round((type.count / totalAnimals) * 100) || 0; %>
      
        <div class="flex items-center">
          <div class="w-3 h-3 rounded-full bg-<%= colors[idx % colors.length] %>-500 mr-2"></div>
          <span class="text-sm text-gray-600 dark:text-gray-400"><%= type._id %>:</span>
          <span class="text-sm font-semibold text-gray-800 dark:text-gray-200 ml-1"><%= type.count %></span>
          <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">(<%= percentage %>%)</span>
        </div>
        
      <% }) } else { %>
        <p class="text-sm text-gray-500 dark:text-gray-400">No data available</p>
      <% } %>
    </div>
  </div>

  <!-- Enhanced Filter & Search Bar -->
  <div class="bg-white dark:bg-gray-800 shadow rounded-xl p-4 mb-6 border border-gray-200 dark:border-gray-700">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center space-y-3 md:space-y-0">
      <div class="flex flex-wrap gap-2">
        <select id="filterStatus" class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
          <option value="all">All Animals</option>
          <option value="active">Active Only</option>
          <option value="inactive">Inactive</option>
          <option value="pregnant">Pregnant</option>
          <option value="upcoming">Upcoming Vaccinations</option>
          <option value="overdue">Overdue Vaccinations</option>
        </select>

        <select id="filterType" class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
          <option value="all">All Types</option>
          <option value="Cow">Cow</option>
          <option value="Buffalo">Buffalo</option>
          <option value="Goat">Goat</option>
          <option value="Sheep">Sheep</option>
          <option value="Dog">Dog</option>
          <option value="Cat">Cat</option>
          <option value="Poultry">Poultry</option>
          <option value="Other">Other</option>
        </select>

        <select id="filterGender" class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
          <option value="all">All Genders</option>
          <option value="Male">Male</option>
          <option value="Female">Female</option>
        </select>

        <select id="filterHealth" class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
          <option value="all">All Health Status</option>
          <option value="Healthy">Healthy</option>
          <option value="Sick">Sick</option>
          <option value="Under Treatment">Under Treatment</option>
        </select>

        <% if(currUser.role == "ADMIN"){ %>
        <select id="filterBatch" class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
          <option value="all">All Registrations</option>
          <option value="single">Single Registrations</option>
          <option value="bulk">Bulk Registrations</option>
        </select>
        <% } %>
      </div>

      <div class="relative w-full md:w-72">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input 
          type="text" 
          id="searchInput" 
          placeholder="Search by tag, ID, name, farmer..." 
          class="w-full pl-10 pr-4 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          value="<%= searchQuery || '' %>"
        >
      </div>
    </div>
  </div>

  <!-- Bulk Actions Bar -->
  <div id="bulkActionsBar" class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-4 mb-6 hidden items-center justify-between">
    <div class="flex items-center space-x-4">
      <span class="text-sm font-medium text-blue-700 dark:text-blue-300">
        <span id="selectedCount">0</span> animals selected
      </span>
      <div class="h-4 w-px bg-blue-200 dark:bg-blue-800"></div>
      <button onclick="bulkTransfer()" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium">
        Transfer to Farmer
      </button>
      <div class="h-4 w-px bg-blue-200 dark:bg-blue-800"></div>
      <button onclick="bulkStatusUpdate()" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium">
        Update Status
      </button>
      <div class="h-4 w-px bg-blue-200 dark:bg-blue-800"></div>
      <button onclick="bulkDelete()" class="text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 font-medium">
        Delete
      </button>
      <div class="h-4 w-px bg-blue-200 dark:bg-blue-800"></div>
      <button onclick="bulkVaccination()" class="text-sm text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 font-medium">
        Schedule Vaccination
      </button>
    </div>
    <button onclick="clearSelection()" class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Main Table -->
  <div class="bg-white dark:bg-gray-800 shadow-xl rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-900/50 sticky top-0 z-10">
          <tr>
            <th class="px-3 sm:px-4 py-3 w-10">
              <input type="checkbox" id="selectAll" onclick="toggleSelectAll()" class="h-4 w-4 text-blue-600 rounded border-gray-300 dark:border-gray-600 focus:ring-blue-500">
            </th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">#</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Unique ID</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Animal</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Farmer</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Type/Species</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Age/Gender</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Plan</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Health</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Vaccination</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
            <th class="px-3 sm:px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>

        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
          <% if (animals.length === 0) { %>
            <tr>
              <td colspan="12" class="text-center py-12 text-gray-400 dark:text-gray-500">
                <div class="flex flex-col items-center">
                  <svg class="h-12 w-12 text-gray-300 dark:text-gray-600 mb-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <p class="text-base font-medium text-gray-500 dark:text-gray-400">No animals registered yet</p>
                  <p class="text-sm text-gray-400 dark:text-gray-500 mt-1">Get started by adding your first animal</p>
                </div>
              </td>
            </tr>
          <% } %>

          <% animals.forEach((animal, index) => { %>
          <%  const daysUntilDue = animal.vaccinationSummary?.nextVaccinationDate ? Math.ceil((new Date(animal.vaccinationSummary.nextVaccinationDate) - new Date()) / (1000 * 60 * 60 * 24)) : null;
          %>
          
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors duration-150 group">
              <!-- Select Checkbox -->
              <td class="px-3 sm:px-4 py-3">
                <input type="checkbox" class="animal-checkbox h-4 w-4 text-blue-600 rounded border-gray-300 dark:border-gray-600 focus:ring-blue-500" value="<%= animal._id %>">
              </td>
              
              <td class="px-3 sm:px-4 py-3 text-sm font-medium text-gray-700 dark:text-gray-300">
                <%= (currentPage - 1) * limit + index + 1 %>
              </td>
              
              <td class="px-3 sm:px-4 py-3">
                <div class="text-sm font-semibold text-blue-600 dark:text-blue-400 font-mono">
                  <%= animal.uniqueAnimalId %>
                </div>
                <div class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                  Tag: <%= animal.tagNumber || 'N/A' %>
                </div>
              </td>
              
              <td class="px-3 sm:px-4 py-3">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-8 w-8 rounded-full bg-gradient-to-r from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30 flex items-center justify-center">
                    <svg class="h-4 w-4 text-blue-600 dark:text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
                    </svg>
                  </div>
                  <div class="ml-3">
                    
                    <div class="text-sm font-medium text-gray-900 dark:text-gray-100">
                      <%= animal.name || "Unnamed" %>
                    </div>
                    <div class="text-xs text-gray-500 dark:text-gray-400">
                      Reg: <%= animal.createdAt ? new Date(animal.createdAt).toLocaleDateString() : 'N/A' %>
                    </div>
                  </div>
                </div>
              </td>
              
              <td class="px-3 sm:px-4 py-3">
                <div class="text-sm text-gray-900 dark:text-gray-100">
                  <%= animal.farmer?.name || "N/A" %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                  <%= animal.farmer?.uniqueFarmerId || "" %>
                </div>
              </td>
              
              <td class="px-3 sm:px-4 py-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
                  <%= animal.animalType %>
                </span>
                <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                  <%= animal.breed || 'Mixed' %>
                </div>
              </td>
              
              <td class="px-3 sm:px-4 py-3">
                <div class="flex items-center">
                  <% if (animal.gender === 'Male') { %>
                    <svg class="h-4 w-4 text-blue-500 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                  <% } else if (animal.gender === 'Female') { %>
                    <svg class="h-4 w-4 text-pink-500 mr-1.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H9v-1a2 2 0 012-2h2a2 2 0 012 2v1zm5-18a2 2 0 00-2-2h-2a2 2 0 00-2 2v12a2 2 0 002 2h2a2 2 0 002-2V3z" />
                    </svg>
                  <% } %>
                  
                  <div>
                    <span class="text-sm text-gray-700 dark:text-gray-300">
                      <%= animal.gender || "Unknown" %>
                    </span>
                    <div class="text-xs text-gray-500 dark:text-gray-400">
                      <%= animal.age?.value ? `${animal.age.value} ${animal.age.unit}` : 'Age N/A' %>
                    </div>
                  </div>
                </div>
              </td>
              
              <!-- Plan Info -->
              <td class="px-3 sm:px-4 py-3">
                <% if (animal.plan && animal.plan.type !== 'none') { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= animal.plan.type === 'premium' ? 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-300' : 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300' %>">
                    <%= animal.plan.name %>
                  </span>
                  <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    <%= animal.plan.status === 'active' ? 'Active' : 'Pending' %>
                  </div>
                <% } else { %>
                  <span class="text-xs text-gray-400 dark:text-gray-500">No Plan</span>
                <% } %>
              </td>
              
              <!-- Health Status -->
              <td class="px-3 sm:px-4 py-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= 
                  animal.healthStatus?.currentStatus === 'Healthy' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' :
                  animal.healthStatus?.currentStatus === 'Sick' ? 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300' :
                  'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300'
                %>">
                  <%= animal.healthStatus?.currentStatus || 'Healthy' %>
                </span>
                <% if (animal.pregnancyStatus?.isPregnant) { %>
                  <div class="text-xs text-pink-500 dark:text-pink-400 mt-1">
                    🤰 Pregnant
                  </div>
                <% } %>
              </td>
              
              <!-- Vaccination Status -->
              <td class="px-3 sm:px-4 py-3">
                <% if (animal.vaccinationSummary) { %>
                  <% if (animal.vaccinationSummary.isUpToDate) { %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">
                      <span class="h-1.5 w-1.5 rounded-full bg-green-500 dark:bg-green-400 mr-1.5"></span>
                      Up to Date
                    </span>
                  <% } else if (daysUntilDue !== null) { %>
                    <% if (daysUntilDue < 0) { %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300">
                        <span class="h-1.5 w-1.5 rounded-full bg-red-500 dark:bg-red-400 mr-1.5"></span>
                        Overdue
                      </span>
                    <% } else if (daysUntilDue <= 7) { %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300">
                        <span class="h-1.5 w-1.5 rounded-full bg-yellow-500 dark:bg-yellow-400 mr-1.5"></span>
                        Due in <%= daysUntilDue %>d
                      </span>
                    <% } else { %>
                      
                      <span class="text-xs text-gray-500 dark:text-gray-400">
                        Due: <%= new Date(animal.vaccinationSummary.nextVaccinationDate).toLocaleDateString() %>
                      </span>
                    <% } %>
                    
                  <% } else { %>
                    <span class="text-xs text-gray-400 dark:text-gray-500">No records</span>
                  <% } %>
                  <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    <%= animal.vaccinationSummary.totalVaccinations || 0 %> vaccinations
                  </div>
                  </div>
                <% } else { %>
                  <span class="text-xs text-gray-400 dark:text-gray-500">No records</span>
                <% } %>
              </td>
              
              <td class="px-3 sm:px-4 py-3">
                <% if (animal.isActive) { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">
                    <span class="h-1.5 w-1.5 rounded-full bg-green-500 dark:bg-green-400 mr-1.5"></span>
                    Active
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300">
                    <span class="h-1.5 w-1.5 rounded-full bg-red-500 dark:bg-red-400 mr-1.5"></span>
                    Inactive
                  </span>
                <% } %>
              </td>
              
              <td class="px-3 sm:px-4 py-3 text-right">
                <div class="flex justify-end space-x-1">
                  <a href="/<%= currUser.role.toLowerCase() %>/animals/<%= animal._id %>" 
                     class="inline-flex items-center p-1.5 text-gray-400 hover:text-blue-600 dark:text-gray-500 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-lg transition-colors duration-150"
                     title="View Details">
                    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                  </a>
                  
                  <a href="/<%= currUser.role.toLowerCase() %>/animals/<%= animal._id %>/edit" 
                     class="inline-flex items-center p-1.5 text-gray-400 hover:text-green-600 dark:text-gray-500 dark:hover:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/30 rounded-lg transition-colors duration-150"
                     title="Edit">
                    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </a>
                  
                  <div class="relative inline-block text-left">
                    <button type="button" onclick="toggleDropdown('<%= animal._id %>')" class="inline-flex items-center p-1.5 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors duration-150" title="More options">
                      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
                      </svg>
                    </button>

                    <div id="dropdown-<%= animal._id %>" class="absolute right-0 mt-1 w-56 bg-white dark:bg-gray-800 rounded-lg shadow-lg ring-1 ring-black ring-opacity-5 dark:ring-gray-700 z-50 hidden transition-all duration-200 origin-top-right">
                      <div class="py-1">
                        <a href="/<%= currUser.role.toLowerCase() %>/animals/<%= animal._id %>" class="flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                          <svg class="mr-3 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                          </svg>
                          View Details
                        </a>
                        <a href="/<%= currUser.role.toLowerCase() %>/animals/<%= animal._id %>/edit" class="flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                          <svg class="mr-3 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                          </svg>
                          Edit Animal
                        </a>
                        
                        <a href="/<%= currUser.role.toLowerCase() %>/animals/<%= animal._id %>/vaccinations" class="flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                          <svg class="mr-3 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                          Vaccination History
                        </a>
                        
                        <% if (animal.registrationBatchId) { %>
                        <a href="/<%= currUser.role.toLowerCase() %>/animals/batch/<%= animal.registrationBatchId %>" class="flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                          <svg class="mr-3 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                          </svg>
                          View Batch
                        </a>
                        <% } %>
                        
                        <div class="border-t border-gray-200 dark:border-gray-700 my-1"></div>
                        
                        <a href="#" onclick="toggleAnimalStatus('<%= animal._id %>', `<%= !animal.isActive %>`)" class="flex items-center px-4 py-2 text-sm <%= animal.isActive ? 'text-yellow-600 dark:text-yellow-400' : 'text-green-600 dark:text-green-400' %> hover:bg-gray-100 dark:hover:bg-gray-700">
                          <svg class="mr-3 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <% if (animal.isActive) { %>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            <% } else { %>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            <% } %>
                          </svg>
                          <%= animal.isActive ? 'Deactivate' : 'Activate' %>
                        </a>
                        
                        <a href="#" onclick="deleteAnimal('<%= animal._id %>')" class="flex items-center px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700">
                          <svg class="mr-3 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                          Delete Animal
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Enhanced Pagination -->
  <% if (totalPages > 1) { %>
    <div class="mt-6 lg:mt-8 flex flex-col sm:flex-row items-center justify-between space-y-3 sm:space-y-0">
      <div class="text-sm text-gray-500 dark:text-gray-400">
        Showing <span class="font-medium"><%= (currentPage - 1) * limit + 1 %></span> to 
        <span class="font-medium"><%= Math.min(currentPage * limit, totalAnimals) %></span> of 
        <span class="font-medium"><%= totalAnimals %></span> animals
      </div>
      
      <div class="flex items-center space-x-1">
        <a href="?page=<%= currentPage - 1 %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= filterStatus && filterStatus !== 'all' ? '&status=' + filterStatus : '' %><%= filterType && filterType !== 'all' ? '&type=' + filterType : '' %>" 
           class="inline-flex items-center px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 1 ? 'text-gray-400 dark:text-gray-600 bg-gray-100 dark:bg-gray-800 cursor-not-allowed' : 'text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700' %>"
           <%= currentPage === 1 ? 'tabindex="-1" aria-disabled="true"' : '' %>>
          <svg class="h-4 w-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Previous
        </a>

        <% const maxVisible = 5; %>
        <% let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2)); %>
        <% let endPage = Math.min(totalPages, startPage + maxVisible - 1); %>
        <% if (endPage - startPage + 1 < maxVisible) { %>
          <% startPage = Math.max(1, endPage - maxVisible + 1); %>
        <% } %>

        <% if (startPage > 1) { %>
          <a href="?page=1<%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= filterStatus && filterStatus !== 'all' ? '&status=' + filterStatus : '' %><%= filterType && filterType !== 'all' ? '&type=' + filterType : '' %>" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">1</a>
          <% if (startPage > 2) { %>
            <span class="px-2 text-gray-400 dark:text-gray-600">...</span>
          <% } %>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
          <a href="?page=<%= i %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= filterStatus && filterStatus !== 'all' ? '&status=' + filterStatus : '' %><%= filterType && filterType !== 'all' ? '&type=' + filterType : '' %>" 
             class="px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === i ? 'bg-blue-600 text-white' : 'text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700' %>">
            <%= i %>
          </a>
        <% } %>

        <% if (endPage < totalPages) { %>
          <% if (endPage < totalPages - 1) { %>
            <span class="px-2 text-gray-400 dark:text-gray-600">...</span>
          <% } %>
          <a href="?page=<%= totalPages %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= filterStatus && filterStatus !== 'all' ? '&status=' + filterStatus : '' %><%= filterType && filterType !== 'all' ? '&type=' + filterType : '' %>" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
            <%= totalPages %>
          </a>
        <% } %>

        <a href="?page=<%= currentPage + 1 %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %><%= filterStatus && filterStatus !== 'all' ? '&status=' + filterStatus : '' %><%= filterType && filterType !== 'all' ? '&type=' + filterType : '' %>" 
           class="inline-flex items-center px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === totalPages ? 'text-gray-400 dark:text-gray-600 bg-gray-100 dark:bg-gray-800 cursor-not-allowed' : 'text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700' %>"
           <%= currentPage === totalPages ? 'tabindex="-1" aria-disabled="true"' : '' %>>
          Next
          <svg class="h-4 w-4 ml-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  <% } %>
</div>

<script>
  // ================ DROPDOWN FUNCTIONS ================
  
  function toggleDropdown(id) {
    const dropdown = document.getElementById('dropdown-' + id);
    const isHidden = dropdown.classList.contains('hidden');
    
    document.querySelectorAll('div[id^="dropdown-"]').forEach(el => {
      if (el.id !== 'dropdown-' + id) {
        el.classList.add('hidden');
      }
    });
    
    dropdown.classList.toggle('hidden');
  }

  document.addEventListener('click', function(event) {
    const isDropdownButton = event.target.closest('button[onclick^="toggleDropdown"]');
    const isDropdownContent = event.target.closest('div[id^="dropdown-"]');
    
    if (!isDropdownButton && !isDropdownContent) {
      document.querySelectorAll('div[id^="dropdown-"]').forEach(el => {
        el.classList.add('hidden');
      });
    }
  });

  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
      document.querySelectorAll('div[id^="dropdown-"]').forEach(el => {
        el.classList.add('hidden');
      });
    }
  });

  // ================ BULK SELECTION FUNCTIONS ================

  let selectedAnimals = new Set();

  function toggleSelectAll() {
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.animal-checkbox');
    
    checkboxes.forEach(checkbox => {
      checkbox.checked = selectAll.checked;
      const id = checkbox.value;
      if (selectAll.checked) {
        selectedAnimals.add(id);
      } else {
        selectedAnimals.delete(id);
      }
    });
    
    updateBulkActionsBar();
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.animal-checkbox').forEach(checkbox => {
      checkbox.addEventListener('change', function() {
        const id = this.value;
        if (this.checked) {
          selectedAnimals.add(id);
        } else {
          selectedAnimals.delete(id);
          document.getElementById('selectAll').checked = false;
        }
        updateBulkActionsBar();
      });
    });

    const filterStatus = document.getElementById('filterStatus');
    const filterType = document.getElementById('filterType');
    const filterGender = document.getElementById('filterGender');
    const filterHealth = document.getElementById('filterHealth');
    const filterBatch = document.getElementById('filterBatch');
    const searchInput = document.getElementById('searchInput');

    if (filterStatus) {
      filterStatus.addEventListener('change', applyFilters);
      filterStatus.value = '<%= filterStatus || "all" %>';
    }
    if (filterType) {
      filterType.addEventListener('change', applyFilters);
      filterType.value = '<%= filterType || "all" %>';
    }
    if (filterGender) filterGender.addEventListener('change', applyFilters);
    if (filterHealth) filterHealth.addEventListener('change', applyFilters);
    if (filterBatch) {
      filterBatch.addEventListener('change', applyFilters);
      filterBatch.value = '<%= filterBatch || "all" %>';
    }

    let searchTimeout;
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          applyFilters();
        }, 500);
      });
    }
  });

  function updateBulkActionsBar() {
    const bar = document.getElementById('bulkActionsBar');
    const count = document.getElementById('selectedCount');
    const selectedCount = selectedAnimals.size;
    
    if (selectedCount > 0) {
      count.textContent = selectedCount;
      bar.classList.remove('hidden');
      bar.classList.add('flex');
    } else {
      bar.classList.add('hidden');
      bar.classList.remove('flex');
    }
  }

  function clearSelection() {
    selectedAnimals.clear();
    document.querySelectorAll('.animal-checkbox').forEach(cb => {
      cb.checked = false;
    });
    document.getElementById('selectAll').checked = false;
    updateBulkActionsBar();
  }

  // ================ BULK ACTIONS ================

  function bulkTransfer() {
    const selectedIds = Array.from(selectedAnimals);
    if (selectedIds.length === 0) {
      alert('Please select at least one animal to transfer.');
      return;
    }
    
    const farmerId = prompt('Enter Farmer ID to transfer these animals:');
    if (farmerId) {
      if (confirm(`Transfer ${selectedIds.length} animal(s) to farmer ${farmerId}?`)) {
        showLoading();
        fetch('/<%= currUser.role.toLowerCase() %>/animals/bulk/transfer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ animalIds: selectedIds, farmerId: farmerId })
        })
        .then(res => res.json())
        .then(data => {
          hideLoading();
          if (data.success) {
            alert(`${data.transferred} animals transferred successfully!`);
            window.location.reload();
          } else {
            alert('Failed to transfer animals: ' + data.message);
          }
        })
        .catch(err => {
          hideLoading();
          console.error('Error:', err);
          alert('Failed to transfer animals. Please try again.');
        });
      }
    }
  }

  function bulkStatusUpdate() {
    const selectedIds = Array.from(selectedAnimals);
    if (selectedIds.length === 0) {
      alert('Please select at least one animal to update.');
      return;
    }
    
    const newStatus = prompt('Enter new status (active/inactive):');
    if (newStatus && ['active', 'inactive'].includes(newStatus.toLowerCase())) {
      if (confirm(`Update status to ${newStatus} for ${selectedIds.length} animal(s)?`)) {
        showLoading();
        fetch('/<%= currUser.role.toLowerCase() %>/animals/bulk/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ animalIds: selectedIds, status: newStatus.toLowerCase() })
        })
        .then(res => res.json())
        .then(data => {
          hideLoading();
          if (data.success) {
            alert(`${data.updated} animals updated successfully!`);
            window.location.reload();
          } else {
            alert('Failed to update animals: ' + data.message);
          }
        })
        .catch(err => {
          hideLoading();
          console.error('Error:', err);
          alert('Failed to update animals. Please try again.');
        });
      }
    }
  }

  function bulkDelete() {
    const selectedIds = Array.from(selectedAnimals);
    if (selectedIds.length === 0) {
      alert('Please select at least one animal to delete.');
      return;
    }
    
    if (confirm(`⚠️ Are you sure you want to delete ${selectedIds.length} animal(s)? This action cannot be undone.`)) {
      showLoading();
      fetch('/<%= currUser.role.toLowerCase() %>/animals/bulk/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: selectedIds })
      })
      .then(res => res.json())
      .then(data => {
        hideLoading();
        if (data.success) {
          alert(data.message || 'Animals deleted successfully!');
          window.location.href = data.redirectUrl || `/<%= currUser.role.toLowerCase() %>/animals`;
        } else {
          alert(data.message || 'Failed to delete animals. Please try again.');
        }
      })
      .catch(err => {
        hideLoading();
        console.error('Error:', err);
        alert('Failed to delete animals. Please try again.');
      });
    }
  }

  function bulkVaccination() {
    const selectedIds = Array.from(selectedAnimals);
    if (selectedIds.length === 0) {
      alert('Please select at least one animal to schedule vaccination.');
      return;
    }
    
    window.location.href = `/vaccination/new?animals=${selectedIds.join(',')}`;
  }

  // ================ SINGLE ANIMAL ACTIONS ================

  function toggleAnimalStatus(id, activate) {
    const action = activate ? 'activate' : 'deactivate';
    if (confirm(`Are you sure you want to ${action} this animal?`)) {
      showLoading();
      fetch(`/<%= currUser.role.toLowerCase() %>/animal/${id}/${action}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(res => res.json())
      .then(data => {
        hideLoading();
        if (data.success) {
          window.location.reload();
        } else {
          alert('Failed to update animal status.');
        }
      })
      .catch(err => {
        hideLoading();
        console.error('Error:', err);
        alert('Failed to update animal status.');
      });
    }
  }

  function deleteAnimal(id) {
    if (confirm('⚠️ Are you sure you want to delete this animal? This action cannot be undone.')) {
      showLoading();
      fetch(`/<%= currUser.role.toLowerCase() %>/animal/${id}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(res => res.json())
      .then(data => {
        hideLoading();
        if (data.success) {
          alert(data.message || 'Animal deleted successfully');
          window.location.href = data.redirectUrl || `/<%= currUser.role.toLowerCase() %>/animals`;
        } else {
          alert(data.message || 'Failed to delete animal.');
        }
      })
      .catch(err => {
        hideLoading();
        console.error('Error:', err);
        alert('Failed to delete animal. Please try again.');
      });
    }
  }

  // ================ FILTER FUNCTIONS ================

  function applyFilters() {
    const params = new URLSearchParams();
    params.set('page', '1');
    
    const status = document.getElementById('filterStatus')?.value;
    if (status && status !== 'all') params.set('status', status);
    
    const type = document.getElementById('filterType')?.value;
    if (type && type !== 'all') params.set('type', type);
    
    const gender = document.getElementById('filterGender')?.value;
    if (gender && gender !== 'all') params.set('gender', gender);
    
    const health = document.getElementById('filterHealth')?.value;
    if (health && health !== 'all') params.set('health', health);
    
    const batch = document.getElementById('filterBatch')?.value;
    if (batch && batch !== 'all') params.set('batch', batch);
    
    const search = document.getElementById('searchInput')?.value;
    if (search) params.set('search', search);
    
    window.location.href = `?${params.toString()}`;
  }

  // ================ LOADING FUNCTIONS ================

  function showLoading() {
    let loader = document.getElementById('globalLoader');
    if (!loader) {
      loader = document.createElement('div');
      loader.id = 'globalLoader';
      loader.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-50';
      loader.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 flex items-center space-x-4 shadow-2xl">
          <svg class="animate-spin h-8 w-8 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="text-gray-700 dark:text-gray-300 font-medium">Processing...</span>
        </div>
      `;
      document.body.appendChild(loader);
    }
    loader.classList.remove('hidden');
  }

  function hideLoading() {
    const loader = document.getElementById('globalLoader');
    if (loader) loader.classList.add('hidden');
  }
</script>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin {
    animation: spin 1s linear infinite;
  }
</style>