<% layout("layouts/boilerplate") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <div class="flex items-center space-x-3">
            <a href="javascript:history.back()" class="text-gray-600 hover:text-gray-800">
              <i class="fas fa-arrow-left text-xl"></i>
            </a>
            <div>
              <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
                Vaccination History
              </h1>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                <%= animal.name || 'Unnamed' %> - <%= animal.tagNumber || 'No Tag' %>
              </p>
            </div>
          </div>
        </div>
        <div class="flex space-x-3">
          <a href="/paravet/farmers/<%= animal.farmer?._id %>" 
             class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
            <i class="fas fa-tractor mr-2"></i>
            View Farmer
          </a>
        </div>
      </div>
    </div>

    <!-- Animal Info Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
            <i class="fas fa-paw text-blue-600"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-gray-500">Species</p>
            <p class="font-semibold"><%= animal.animalType %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
            <i class="fas fa-syringe text-green-600"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-gray-500">Total Vaccinations</p>
            <p class="text-2xl font-bold"><%= vaccinations.length %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
            <i class="fas fa-calendar-alt text-purple-600"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-gray-500">Last Vaccination</p>
            <p class="font-semibold"><%= vaccinations[0] ? moment(vaccinations[0].dateAdministered).format('DD MMM YYYY') : 'Never' %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center">
            <i class="fas fa-clock text-yellow-600"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-gray-500">Next Due</p>
            <p class="font-semibold"><%= vaccinations[0]?.nextDueDate ? moment(vaccinations[0].nextDueDate).format('DD MMM YYYY') : 'Not scheduled' %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Vaccination Timeline -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
        <h2 class="text-lg font-semibold flex items-center">
          <i class="fas fa-timeline mr-2 text-blue-500"></i>
          Vaccination Timeline
        </h2>
      </div>
      
      <div class="p-6">
        <% if (vaccinations.length > 0) { %>
          <div class="relative">
            <!-- Timeline line -->
            <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-600"></div>
            
            <div class="space-y-8">
              <% vaccinations.forEach((vac, index) => { 
                const isOverdue = vac.nextDueDate && new Date(vac.nextDueDate) < new Date();
              %>
                <div class="relative flex items-start">
                  <!-- Timeline dot -->
                  <div class="absolute left-4 w-4 h-4 rounded-full transform -translate-x-1/2 mt-1 
                              <%= vac.status === 'Administered' || vac.status === 'Completed' ? 'bg-green-500' : 'bg-yellow-500' %>">
                  </div>
                  
                  <div class="ml-12 flex-1">
                    <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
                      <div class="flex flex-wrap justify-between items-start gap-2">
                        <div>
                          <h3 class="font-semibold text-gray-900 dark:text-white">
                            <%= vac.vaccine?.name || vac.vaccineName || 'Unknown Vaccine' %>
                          </h3>
                          <p class="text-sm text-gray-500 mt-1">
                            <%= vac.vaccine?.diseaseTarget || 'Preventive vaccination' %>
                          </p>
                        </div>
                        <span class="px-2 py-1 rounded-full text-xs <%= 
                          vac.status === 'Administered' || vac.status === 'Completed' ? 'bg-green-100 text-green-800' : 
                          vac.status === 'Scheduled' ? 'bg-blue-100 text-blue-800' : 'bg-yellow-100 text-yellow-800' %>">
                          <%= vac.status || 'Pending' %>
                        </span>
                      </div>
                      
                      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4 text-sm">
                        <div>
                          <p class="text-gray-500">Administered Date</p>
                          <p class="font-medium"><%= vac.dateAdministered ? moment(vac.dateAdministered).format('DD MMM YYYY') : 'Not yet' %></p>
                        </div>
                        <div>
                          <p class="text-gray-500">Next Due Date</p>
                          <p class="font-medium <%= isOverdue ? 'text-red-600' : '' %>">
                            <%= vac.nextDueDate ? moment(vac.nextDueDate).format('DD MMM YYYY') : 'Not set' %>
                          </p>
                        </div>
                        <div>
                          <p class="text-gray-500">Dose</p>
                          <p class="font-medium"><%= vac.doseNumber || 1 %>/<%= vac.totalDosesRequired || 1 %></p>
                        </div>
                        <div>
                          <p class="text-gray-500">Batch Number</p>
                          <p class="font-medium"><%= vac.batchNumber || 'N/A' %></p>
                        </div>
                      </div>
                      
                      <% if (vac.administeredBy) { %>
                        <p class="text-xs text-gray-500 mt-3">
                          <i class="fas fa-user-md mr-1"></i>
                          Administered by: <%= vac.administeredBy %>
                        </p>
                      <% } %>
                      
                      <% if (vac.notes) { %>
                        <p class="text-sm text-gray-600 mt-2 p-2 bg-gray-100 rounded">
                          <i class="fas fa-comment mr-1"></i>
                          <%= vac.notes %>
                        </p>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        <% } else { %>
          <div class="text-center py-12">
            <i class="fas fa-syringe text-6xl text-gray-400 mb-4"></i>
            <h3 class="text-xl font-medium text-gray-900 dark:text-white mb-2">No Vaccination Records</h3>
            <p class="text-gray-500">This animal has not received any vaccinations yet.</p>
            <a href="/paravet/farmers/<%= animal.farmer?._id %>/vaccinate" 
               class="inline-block mt-4 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
              <i class="fas fa-plus mr-2"></i>
              Schedule First Vaccination
            </a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>