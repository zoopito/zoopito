<% layout("layouts/boilerplate") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
            Upcoming Vaccination Schedules
          </h1>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
            Manage and track all scheduled vaccinations
          </p>
        </div>
        <div class="flex space-x-2">
          <button onclick="setPeriod('today')" class="period-btn px-4 py-2 rounded-lg transition" data-period="today">Today</button>
          <button onclick="setPeriod('week')" class="period-btn px-4 py-2 rounded-lg transition" data-period="week">This Week</button>
          <button onclick="setPeriod('month')" class="period-btn px-4 py-2 rounded-lg transition" data-period="month">This Month</button>
        </div>
      </div>
    </div>

    <!-- Stats Summary -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 text-center">
        <p class="text-2xl font-bold text-blue-600"><%= schedules.filter(s => moment(s.scheduledDate).isSame(moment(), 'day')).length %></p>
        <p class="text-sm text-gray-500">Today</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 text-center">
        <p class="text-2xl font-bold text-green-600"><%= schedules.filter(s => moment(s.scheduledDate).isSameOrAfter(moment().startOf('week')) && moment(s.scheduledDate).isSameOrBefore(moment().endOf('week'))).length %></p>
        <p class="text-sm text-gray-500">This Week</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 text-center">
        <p class="text-2xl font-bold text-purple-600"><%= schedules.length %></p>
        <p class="text-sm text-gray-500">Total Scheduled</p>
      </div>
    </div>

    <!-- Schedules List -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
        <h2 class="text-lg font-semibold flex items-center">
          <i class="fas fa-list mr-2 text-blue-500"></i>
          Scheduled Vaccinations
        </h2>
      </div>
      
      <div class="divide-y divide-gray-200 dark:divide-gray-700">
        <% if (schedules.length > 0) { %>
          <% 
            const groupedSchedules = {};
            schedules.forEach(s => {
              const dateKey = moment(s.scheduledDate).format('YYYY-MM-DD');
              if (!groupedSchedules[dateKey]) groupedSchedules[dateKey] = [];
              groupedSchedules[dateKey].push(s);
            });
          %>
          
          <% Object.keys(groupedSchedules).sort().forEach(dateKey => { 
            const isToday = moment(dateKey).isSame(moment(), 'day');
            const isPast = moment(dateKey).isBefore(moment(), 'day');
          %>
            <div class="px-6 py-4">
              <h3 class="text-lg font-semibold mb-4 <%= isToday ? 'text-blue-600' : isPast ? 'text-red-500' : 'text-gray-700' %>">
                <%= moment(dateKey).format('dddd, DD MMMM YYYY') %>
                <% if (isToday) { %>
                  <span class="ml-2 text-sm bg-blue-100 text-blue-800 px-2 py-0.5 rounded-full">Today</span>
                <% } else if (isPast) { %>
                  <span class="ml-2 text-sm bg-red-100 text-red-800 px-2 py-0.5 rounded-full">Overdue</span>
                <% } %>
              </h3>
              
              <div class="space-y-3">
                <% groupedSchedules[dateKey].forEach(schedule => { %>
                  <div class="flex flex-wrap items-center justify-between p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
                    <div class="flex items-center space-x-4">
                      <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-syringe text-blue-600"></i>
                      </div>
                      <div>
                        <p class="font-medium text-gray-900 dark:text-white">
                          <%= schedule.vaccine?.name || schedule.vaccineName %>
                        </p>
                        <p class="text-sm text-gray-500">
                          <%= schedule.animal?.name || 'Animal' %> • 
                          <%= schedule.farmer?.name %> • 
                          <%= schedule.farmer?.address?.village || 'Location N/A' %>
                        </p>                        <p class="text-xs text-amber-600 font-semibold mt-1">
                          <i class="fas fa-clock mr-1"></i>
                          <%= moment(schedule.scheduledDate).format('hh:mm A') %>
                        </p>                      </div>
                    </div>
                    <div class="flex items-center space-x-3 mt-2 sm:mt-0">
                      <span class="px-2 py-1 rounded-full text-xs <%= 
                        schedule.status === 'Scheduled' ? 'bg-blue-100 text-blue-800' : 'bg-yellow-100 text-yellow-800' %>">
                        <%= schedule.status || 'Pending' %>
                      </span>
                      <button onclick="openScheduleModal('<%= schedule._id %>', '<%= schedule.farmer?._id %>', '<%= schedule.animal?._id %>', '<%= schedule.vaccine?.name || schedule.vaccineName %>')" 
                         class="px-3 py-1 bg-blue-600 text-white rounded-lg text-sm hover:bg-blue-700">
                        <i class="fas fa-calendar mr-1"></i>
                        Schedule
                      </button>
                      <a href="/paravet/farmers/<%= schedule.farmer?._id %>/vaccinate" 
                         class="px-3 py-1 bg-green-600 text-white rounded-lg text-sm hover:bg-green-700">
                        <i class="fas fa-syringe mr-1"></i>
                        Start
                      </a>
                    </div>
                  </div>
                <% }); %>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="text-center py-12">
            <i class="fas fa-calendar-check text-6xl text-gray-400 mb-4"></i>
            <h3 class="text-xl font-medium text-gray-900 dark:text-white mb-2">No Scheduled Vaccinations</h3>
            <p class="text-gray-500">No upcoming vaccinations found for the selected period.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
  function setPeriod(period) {
    const url = new URL(window.location.href);
    url.searchParams.set('period', period);
    window.location.href = url.toString();
  }
  
  // Highlight active period button
  const urlParams = new URLSearchParams(window.location.search);
  const currentPeriod = urlParams.get('period') || 'week';
  document.querySelectorAll('.period-btn').forEach(btn => {
    if (btn.dataset.period === currentPeriod) {
      btn.classList.add('bg-blue-600', 'text-white');
      btn.classList.remove('bg-gray-200', 'text-gray-700');
    } else {
      btn.classList.add('bg-gray-200', 'text-gray-700');
      btn.classList.remove('bg-blue-600', 'text-white');
    }
  });

  // Schedule Modal Functions
  function openScheduleModal(scheduleId, farmerId, animalId, vaccineName) {
    document.getElementById('scheduleVaccinationId').value = scheduleId;
    document.getElementById('scheduleFarmerId').value = farmerId;
    document.getElementById('scheduleAnimalId').value = animalId;
    document.getElementById('scheduleVaccineName').textContent = vaccineName;
    document.getElementById('scheduleModal').classList.remove('hidden');
  }

  function closeScheduleModal() {
    document.getElementById('scheduleModal').classList.add('hidden');
  }

  async function submitSchedule(event) {
    event.preventDefault();
    const vaccinationId = document.getElementById('scheduleVaccinationId').value;
    const scheduledDate = document.getElementById('scheduledDate').value;
    const scheduledTime = document.getElementById('scheduledTime').value;
    const assignedParavet = document.getElementById('assignedParavet').value;

    if (!scheduledDate || !scheduledTime) {
      alert('Please select both date and time');
      return;
    }

    const [hours, minutes] = scheduledTime.split(':');
    const dateTime = new Date(scheduledDate);
    dateTime.setHours(parseInt(hours), parseInt(minutes), 0, 0);

    try {
      const response = await fetch(`/vaccination/${vaccinationId}/schedule`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          scheduledDate: dateTime.toISOString(),
          assignedParavet: assignedParavet || null
        })
      });

      const data = await response.json();
      if (data.success) {
        alert('Vaccination scheduled successfully!');
        closeScheduleModal();
        location.reload();
      } else {
        alert('Error: ' + data.message);
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Failed to schedule vaccination');
    }
  }
</script>

<!-- Schedule Modal -->
<div id="scheduleModal" class="fixed inset-0 bg-black/50 hidden overflow-y-auto h-full w-full z-50">
  <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-lg bg-white dark:bg-gray-800">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Schedule Vaccination</h3>
      <button onclick="closeScheduleModal()" class="text-gray-400 hover:text-gray-600">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form onsubmit="submitSchedule(event)">
      <input type="hidden" id="scheduleVaccinationId">
      <input type="hidden" id="scheduleFarmerId">
      <input type="hidden" id="scheduleAnimalId">
      
      <div class="mb-4">
        <p class="text-sm text-gray-600 mb-3">
          Vaccine: <span id="scheduleVaccineName" class="font-semibold text-blue-600"></span>
        </p>
        
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Date</label>
          <input type="date" id="scheduledDate" required class="w-full px-3 py-2 border rounded-lg" value="<%= new Date().toISOString().split('T')[0] %>">
        </div>

        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Time</label>
          <input type="time" id="scheduledTime" required class="w-full px-3 py-2 border rounded-lg" value="<%= new Date().toTimeString().slice(0, 5) %>">
        </div>

        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Assign Paravet (Optional)</label>
          <select id="assignedParavet" class="w-full px-3 py-2 border rounded-lg">
            <option value="">Select a Paravet</option>
            <% if (locals.paravets) { %>
              <% paravets.forEach(p => { %>
                <option value="<%= p._id %>"><%= p.user?.name %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
      </div>

      <div class="flex justify-end space-x-3">
        <button type="button" onclick="closeScheduleModal()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Cancel</button>
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Schedule</button>
      </div>
    </form>
  </div>
</div>