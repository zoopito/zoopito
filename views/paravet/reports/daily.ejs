<% layout("layouts/boilerplate", {
    title: 'Daily Report',
    description: 'Daily vaccination report',
    pageStyles: `
        .report-card {
            transition: all 0.3s ease;
        }
        .print-only {
            display: none;
        }
        @media print {
            .no-print {
                display: none;
            }
            .print-only {
                display: block;
            }
            .report-card {
                break-inside: avoid;
                page-break-inside: avoid;
            }
        }
    `
}) -%>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Page Header -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Daily Report</h1>
                <p class="text-gray-600 dark:text-gray-400 mt-2"><%= reportDate %></p>
            </div>
            <div class="flex space-x-3 mt-4 sm:mt-0 no-print">
                <button onclick="window.location.href='/paravet/reports/daily?date=<%= moment(reportDate, 'DD MMMM YYYY').subtract(1, 'day').format('YYYY-MM-DD') %>'" 
                        class="px-4 py-2 border rounded-lg hover:bg-gray-50">
                    <i class="fas fa-chevron-left mr-1"></i>Previous
                </button>
                <button onclick="window.location.href='/paravet/reports/daily?date=<%= moment(reportDate, 'DD MMMM YYYY').add(1, 'day').format('YYYY-MM-DD') %>'" 
                        class="px-4 py-2 border rounded-lg hover:bg-gray-50">
                    Next<i class="fas fa-chevron-right ml-1"></i>
                </button>
                <button onclick="window.print()" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
                    <i class="fas fa-print mr-2"></i>Print
                </button>
            </div>
        </div>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="report-card bg-white dark:bg-gray-800 rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Total Vaccinations</p>
                        <p class="text-2xl font-bold text-gray-900"><%= summary.total %></p>
                    </div>
                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-syringe text-blue-600 text-xl"></i>
                    </div>
                </div>
            </div>
            <div class="report-card bg-white dark:bg-gray-800 rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Total Earnings</p>
                        <p class="text-2xl font-bold text-green-600">₹<%= summary.totalEarnings.toLocaleString() %></p>
                    </div>
                    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-rupee-sign text-green-600 text-xl"></i>
                    </div>
                </div>
            </div>
            <div class="report-card bg-white dark:bg-gray-800 rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Farmers Served</p>
                        <p class="text-2xl font-bold text-gray-900"><%= Object.keys(summary.byFarmer).length %></p>
                    </div>
                    <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-users text-purple-600 text-xl"></i>
                    </div>
                </div>
            </div>
            <div class="report-card bg-white dark:bg-gray-800 rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Vaccine Types</p>
                        <p class="text-2xl font-bold text-gray-900"><%= Object.keys(summary.byVaccine).length %></p>
                    </div>
                    <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-capsules text-orange-600 text-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payment Breakdown -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Payment Breakdown</h3>
                <div class="space-y-3">
                    <div class="flex justify-between items-center">
                        <span>Cash Payments</span>
                        <span class="font-semibold">₹<%= summary.paymentBreakdown.cash.toLocaleString() %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span>Online Payments</span>
                        <span class="font-semibold">₹<%= summary.paymentBreakdown.online.toLocaleString() %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span>Pending Payments</span>
                        <span class="font-semibold text-orange-600">₹<%= summary.paymentBreakdown.pending.toLocaleString() %></span>
                    </div>
                    <div class="pt-3 border-t">
                        <div class="flex justify-between items-center font-bold">
                            <span>Total Collected</span>
                            <span>₹<%= (summary.paymentBreakdown.cash + summary.paymentBreakdown.online).toLocaleString() %></span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Vaccine Distribution</h3>
                <div class="space-y-2">
                    <% Object.entries(summary.byVaccine).forEach(([vaccine, count]) => { %>
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span><%= vaccine %></span>
                                <span><%= count %> doses</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-2">
                                <div class="bg-blue-600 h-2 rounded-full" style="width: <%= (count / summary.total) * 100 %>%"></div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>

        <!-- Vaccination Details Table -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Vaccination Details</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-700">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Farmer</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Animal</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vaccine</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Payment</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                        <% vaccinations.forEach(vac => { %>
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                                    <%= moment(vac.dateAdministered).format('hh:mm A') %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900 dark:text-white">
                                    <%= vac.farmer?.name %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900 dark:text-white">
                                    <%= vac.animal?.name %> (<%= vac.animal?.tagNumber %>)
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900 dark:text-white">
                                    <%= vac.vaccine?.name %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900 dark:text-white">
                                    ₹<%= vac.payment?.totalAmount || vac.vaccine?.price || 0 %>
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <span class="px-2 py-1 rounded-full text-xs <%= vac.payment?.status === 'Paid' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
                                        <%= vac.payment?.status || 'Pending' %>
                                    </span>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>