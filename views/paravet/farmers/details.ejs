<% layout("layouts/boilerplate") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header with Navigation -->
    <div class="mb-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <a href="/paravet/farmers" class="text-gray-600 hover:text-gray-800">
            <i class="fas fa-arrow-left text-xl"></i>
          </a>
          <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
              <%= farmer.name %>
            </h1>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
              <i class="fas fa-map-marker-alt mr-1"></i>
              <%= farmer.address?.village || 'N/A' %>, <%= farmer.address?.taluka || '' %>, <%= farmer.address?.district || '' %>
            </p>
          </div>
        </div>
        <div class="flex space-x-3">
          <a href="/paravet/farmers/<%= farmer._id %>/vaccinate" 
             class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 flex items-center">
            <i class="fas fa-syringe mr-2"></i>
            Bulk Vaccinate
          </a>
        </div>
      </div>
    </div>

    <!-- Farmer Information Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
            <i class="fas fa-paw text-blue-600"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-gray-500">Total Animals</p>
            <p class="text-2xl font-bold"><%= animals.length %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
            <i class="fas fa-check-circle text-green-600"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-gray-500">Vaccinated</p>
            <p class="text-2xl font-bold"><%= animals.filter(a => a.isFullyVaccinated).length %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center">
            <i class="fas fa-clock text-yellow-600"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-gray-500">Need Vaccination</p>
            <p class="text-2xl font-bold"><%= animals.filter(a => a.pendingRecommended.length > 0).length %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
            <i class="fas fa-tag text-purple-600"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-gray-500">Need Tagging</p>
            <p class="text-2xl font-bold"><%= animals.filter(a => a.needsTagging).length %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Location Map Section (if available) -->
    <% if (mapUrl) { %>
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4 mb-8">
        <h3 class="text-lg font-semibold mb-3 flex items-center">
          <i class="fas fa-map text-red-500 mr-2"></i>
          Farmer Location
        </h3>
        <div class="bg-gray-100 dark:bg-gray-700 rounded-lg p-4 text-center">
          <p class="mb-2">📍 Coordinates: <%= location[1] %>, <%= location[0] %></p>
          <a href="<%= mapUrl %>" target="_blank" 
             class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
            <i class="fas fa-external-link-alt mr-2"></i>
            Open in Maps
          </a>
        </div>
      </div>
    <% } %>

    <!-- Animals List -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
        <h2 class="text-lg font-semibold flex items-center">
          <i class="fas fa-paw mr-2 text-green-500"></i>
          Animals (<%= animals.length %>)
        </h2>
      </div>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Animal</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tag ID</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Species</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Vaccination Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Next Due</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Health</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            <% animals.forEach(animal => { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4">
                  <div class="flex items-center">
                    <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center">
                      <i class="fas fa-paw text-gray-500"></i>
                    </div>
                    <div class="ml-3">
                      <p class="font-medium text-gray-900 dark:text-white">
                        <%= animal.name || 'Unnamed' %>
                      </p>
                      <p class="text-xs text-gray-500">
                        <%= animal.animalType %> | <%= animal.gender || 'Unknown' %>
                      </p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <% if (animal.tagNumber) { %>
                    <span class="px-2 py-1 bg-green-100 text-green-800 rounded-full text-xs">
                      <i class="fas fa-tag mr-1"></i><%= animal.tagNumber %>
                    </span>
                  <% } else { %>
                    <span class="px-2 py-1 bg-yellow-100 text-yellow-800 rounded-full text-xs">
                      <i class="fas fa-exclamation-triangle mr-1"></i>Not Tagged
                    </span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-sm">
                  <%= animal.animalType %>
                  <div class="text-xs text-gray-500"><%= animal.breed || 'Mixed' %></div>
                </td>
                <td class="px-6 py-4">
                  <div class="flex flex-col">
                    <div class="flex items-center">
                      <span class="text-sm font-medium">
                        <%= animal.vaccinationCount || 0 %>/<%= (animal.recommendedVaccines?.length || 0) + (animal.vaccinationCount || 0) %>
                      </span>
                      <span class="ml-2 text-xs text-gray-500">vaccines</span>
                    </div>
                    <div class="w-24 h-1.5 bg-gray-200 rounded-full mt-1">
                      <div class="bg-green-500 rounded-full h-1.5" 
                           style="width: <%= animal.vaccinationProgress?.percentage || 0 %>%"></div>
                    </div>
                    <% if (animal.pendingRecommended && animal.pendingRecommended.length > 0) { %>
                      <span class="text-xs text-yellow-600 mt-1">
                        <%= animal.pendingRecommended.length %> vaccines due
                      </span>
                    <% } %>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <% if (animal.nextVaccination) { %>
                    <span class="text-sm"><%= moment(animal.nextVaccination).format('DD MMM YYYY') %></span>
                    <% const days = moment(animal.nextVaccination).diff(moment(), 'days'); %>
                    <% if (days <= 7 && days > 0) { %>
                      <span class="text-xs text-orange-500 block">Due in <%= days %> days</span>
                    <% } else if (days < 0) { %>
                      <span class="text-xs text-red-500 block">Overdue</span>
                    <% } %>
                  <% } else { %>
                    <span class="text-sm text-gray-400">Not scheduled</span>
                  <% } %>
                </td>
                <td class="px-6 py-4">
                  <span class="px-2 py-1 rounded-full text-xs <%= 
                    animal.healthStatus?.currentStatus === 'Healthy' ? 'bg-green-100 text-green-800' : 
                    animal.healthStatus?.currentStatus === 'Sick' ? 'bg-red-100 text-red-800' : 
                    'bg-yellow-100 text-yellow-800' %>">
                    <%= animal.healthStatus?.currentStatus || 'Healthy' %>
                  </span>
                  <% if (animal.pregnancyStatus?.isPregnant) { %>
                    <span class="ml-1 px-2 py-1 bg-pink-100 text-pink-800 rounded-full text-xs">
                      <i class="fas fa-baby"></i> Pregnant
                    </span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex justify-end space-x-2">
                    <a href="/paravet/vaccinations/history/<%= animal._id %>" 
                       class="text-blue-600 hover:text-blue-800" title="View History">
                      <i class="fas fa-history"></i>
                    </a>
                    <% if (animal.needsTagging) { %>
                      <button onclick="openTagModal('<%= animal._id %>', '<%= animal.name || 'Animal' %>')" 
                              class="text-purple-600 hover:text-purple-800" title="Add Tag">
                        <i class="fas fa-tag"></i>
                      </button>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Tag Modal -->
<div id="tagModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
  <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-lg bg-white dark:bg-gray-800">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold">Add Tag ID</h3>
      <button onclick="closeTagModal()" class="text-gray-400 hover:text-gray-600">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="tagForm" onsubmit="submitTag(event)">
      <input type="hidden" id="tagAnimalId">
      <div class="mb-4">
        <p class="text-sm text-gray-600 mb-2">Animal: <span id="tagAnimalName" class="font-semibold"></span></p>
        <label class="block text-sm font-medium text-gray-700 mb-2">Tag Number</label>
        <input type="text" id="tagNumber" required 
               class="w-full px-3 py-2 border rounded-lg focus:ring-blue-500 focus:border-blue-500"
               placeholder="Enter unique tag number">
        <p class="text-xs text-gray-500 mt-1">Use uppercase letters and numbers only</p>
      </div>
      <div class="flex justify-end space-x-3">
        <button type="button" onclick="closeTagModal()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Cancel</button>
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save Tag</button>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  function openTagModal(animalId, animalName) {
    document.getElementById('tagAnimalId').value = animalId;
    document.getElementById('tagAnimalName').textContent = animalName;
    document.getElementById('tagModal').classList.remove('hidden');
  }

  function closeTagModal() {
    document.getElementById('tagModal').classList.add('hidden');
  }

  async function submitTag(event) {
    event.preventDefault();
    const animalId = document.getElementById('tagAnimalId').value;
    const tagNumber = document.getElementById('tagNumber').value.toUpperCase();
    
    if (!tagNumber) {
      Swal.fire({ icon: 'warning', title: 'Required', text: 'Please enter a tag number' });
      return;
    }
    
    Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
    
    try {
      const response = await fetch(`/paravet/animals/${animalId}/tag`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tagNumber })
      });
      const data = await response.json();
      
      if (data.success) {
        Swal.fire({ icon: 'success', title: 'Success!', text: data.message, timer: 2000 })
          .then(() => location.reload());
      } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message });
      }
    } catch (error) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to add tag' });
    }
    closeTagModal();
  }
</script>