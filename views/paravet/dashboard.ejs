<% layout("layouts/boilerplate", {
    title: 'Paravet Dashboard - Zoopito',
    description: 'Manage your vaccinations and schedules',
    pageStyles: `
        .stat-card { transition: all 0.3s ease; }
        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); }
        .progress-bar { transition: width 0.5s ease; }
        .schedule-item { transition: all 0.2s ease; }
        .schedule-item:hover { background-color: #f9fafb; transform: translateX(5px); }
        .status-badge { padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
        .status-upcoming { background-color: #dbeafe; color: #1e40af; }
        .status-today { background-color: #fef3c7; color: #92400e; animation: pulse 2s infinite; }
        .status-overdue { background-color: #fee2e2; color: #991b1b; }
        @keyframes pulse { 0%,100% { opacity:1 } 50% { opacity:0.7 } }
        .quick-action-btn { transition: all 0.2s ease; }
        .quick-action-btn:hover { transform: scale(1.05); }
    `
}) -%>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- Top Navigation -->
    <nav class="bg-white dark:bg-gray-800 shadow-sm border-b border-gray-200 dark:border-gray-700">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
                        <i class="fas fa-user-md text-blue-600 mr-2"></i>
                        Paravet Dashboard
                    </h1>
                </div>
                <div class="flex items-center space-x-4">
                    <span class="text-sm text-gray-600 dark:text-gray-300">
                        <i class="fas fa-map-marker-alt mr-1"></i>
                        <%= paravet.assignedAreas?.[0]?.village || 'Area not assigned' %>
                    </span>
                    <div class="relative">
                        <button onclick="toggleNotifications()" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700">
                            <i class="fas fa-bell text-gray-600 dark:text-gray-300"></i>
                            <span class="absolute top-0 right-0 h-4 w-4 bg-red-500 rounded-full text-xs text-white flex items-center justify-center">
                                <%= stats.pendingVaccinations %>
                            </span>
                        </button>
                    </div>
                    <div class="flex items-center space-x-3">
                        <img src="<%= user.avatar || '/images/default-avatar.png' %>" 
                             class="h-8 w-8 rounded-full border-2 border-blue-500">
                        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                            <%= user.name %>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Welcome Banner -->
        <div class="bg-gradient-to-r from-blue-600 to-green-600 rounded-2xl shadow-xl p-6 mb-8 text-white">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-2xl font-bold mb-2">Welcome back, <%= user.name %>! 👋</h2>
                    <p class="text-blue-100"><%= moment().format('dddd, DD MMMM YYYY') %></p>
                </div>
                <div class="flex space-x-3">
                    <a href="/paravet/reports/daily" 
                       class="bg-white/20 hover:bg-white/30 px-4 py-2 rounded-lg flex items-center">
                        <i class="fas fa-file-alt mr-2"></i>
                        Daily Report
                    </a>
                    <a href="/paravet/tasks" 
                       class="bg-white/20 hover:bg-white/30 px-4 py-2 rounded-lg flex items-center">
                        <i class="fas fa-tasks mr-2"></i>
                        My Tasks
                    </a>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <!-- Today's Schedule -->
            <div class="stat-card bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 border-l-4 border-blue-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Today's Schedule</p>
                        <p class="text-3xl font-bold text-gray-900 dark:text-white"><%= stats.todaySchedules %></p>
                    </div>
                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-calendar-day text-blue-600 text-xl"></i>
                    </div>
                </div>
                <div class="mt-3 flex items-center text-sm">
                    <span class="text-green-600 font-semibold"><%= stats.completedToday %></span>
                    <span class="text-gray-500 ml-1">completed</span>
                </div>
            </div>

            <!-- Pending Vaccinations -->
            <div class="stat-card bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 border-l-4 border-yellow-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Pending</p>
                        <p class="text-3xl font-bold text-gray-900 dark:text-white"><%= stats.pendingVaccinations %></p>
                    </div>
                    <div class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-clock text-yellow-600 text-xl"></i>
                    </div>
                </div>
                <div class="mt-3 flex items-center text-sm">
                    <span class="text-red-600 font-semibold"><%= stats.upcomingSchedules %></span>
                    <span class="text-gray-500 ml-1">due this week</span>
                </div>
            </div>

            <!-- Total Farmers -->
            <div class="stat-card bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 border-l-4 border-green-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">My Farmers</p>
                        <p class="text-3xl font-bold text-gray-900 dark:text-white"><%= stats.totalFarmers %></p>
                    </div>
                    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-users text-green-600 text-xl"></i>
                    </div>
                </div>
                <div class="mt-3 flex items-center text-sm">
                    <span class="text-blue-600 font-semibold"><%= stats.totalAnimals %></span>
                    <span class="text-gray-500 ml-1">total animals</span>
                </div>
            </div>

            <!-- Total Earnings -->
            <div class="stat-card bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 border-l-4 border-purple-500">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Total Earnings</p>
                        <p class="text-3xl font-bold text-gray-900 dark:text-white">₹<%= stats.totalEarnings.toLocaleString() %></p>
                    </div>
                    <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-rupee-sign text-purple-600 text-xl"></i>
                    </div>
                </div>
                <div class="mt-3 flex items-center text-sm">
                    <span class="text-green-600 font-semibold"><%= stats.totalCompleted %></span>
                    <span class="text-gray-500 ml-1">total vaccinations</span>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <button onclick="startVisit()" class="quick-action-btn bg-blue-600 hover:bg-blue-700 text-white rounded-xl p-4 flex items-center justify-between">
                <div class="flex items-center">
                    <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center mr-3">
                        <i class="fas fa-play text-white"></i>
                    </div>
                    <div class="text-left">
                        <h3 class="font-semibold">Start Visit</h3>
                        <p class="text-sm text-blue-100">Begin farmer visit</p>
                    </div>
                </div>
                <i class="fas fa-arrow-right"></i>
            </button>

            <button onclick="window.location.href='/paravet/vaccination/pending'" 
                    class="quick-action-btn bg-green-600 hover:bg-green-700 text-white rounded-xl p-4 flex items-center justify-between">
                <div class="flex items-center">
                    <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center mr-3">
                        <i class="fas fa-syringe text-white"></i>
                    </div>
                    <div class="text-left">
                        <h3 class="font-semibold">Pending Vaccinations</h3>
                        <p class="text-sm text-green-100"><%= stats.pendingVaccinations %> pending</p>
                    </div>
                </div>
                <i class="fas fa-arrow-right"></i>
            </button>

            <button onclick="window.location.href='/paravet/farmer-list'" 
                    class="quick-action-btn bg-purple-600 hover:bg-purple-700 text-white rounded-xl p-4 flex items-center justify-between">
                <div class="flex items-center">
                    <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center mr-3">
                        <i class="fas fa-list text-white"></i>
                    </div>
                    <div class="text-left">
                        <h3 class="font-semibold">My Farmers</h3>
                        <p class="text-sm text-purple-100"><%= stats.totalFarmers %> farmers</p>
                    </div>
                </div>
                <i class="fas fa-arrow-right"></i>
            </button>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column - Upcoming Schedule -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Today's Schedule Card -->
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
                    <div class="px-6 py-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white flex justify-between items-center">
                        <h3 class="font-semibold flex items-center">
                            <i class="fas fa-calendar-alt mr-2"></i>
                            Today's Schedule
                        </h3>
                        <span class="text-sm bg-white/20 px-3 py-1 rounded-full">
                            <%= stats.todaySchedules %> appointments
                        </span>
                    </div>
                    
                    <div class="divide-y divide-gray-200 dark:divide-gray-700">
                        <% if (upcomingSchedules && upcomingSchedules.length > 0) { %>
                            <% upcomingSchedules.filter(s => moment(s.scheduledDate).isSame(moment(), 'day')).forEach(schedule => { %>
                                <div class="schedule-item p-4 hover:bg-gray-50 dark:hover:bg-gray-700">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center space-x-3">
                                            <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                                                <i class="fas fa-paw text-blue-600"></i>
                                            </div>
                                            <div>
                                                <h4 class="font-medium text-gray-900 dark:text-white">
                                                    <%= schedule.animal?.name || 'Unnamed' %> 
                                                    <span class="text-sm text-gray-500">(<%= schedule.animal?.tagNumber || 'No Tag' %>)</span>
                                                </h4>
                                                <p class="text-sm text-gray-500 dark:text-gray-400">
                                                    <i class="fas fa-user mr-1"></i><%= schedule.farmer?.name %>
                                                </p>
                                                <p class="text-xs text-gray-400">
                                                    <i class="fas fa-map-marker-alt mr-1"></i><%= schedule.farmer?.address?.village %>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="text-right">
                                            <span class="status-badge status-today">
                                                <%= moment(schedule.scheduledDate).format('h:mm A') %>
                                            </span>
                                            <button onclick="startVaccination('<%= schedule._id %>')" 
                                                    class="mt-2 text-sm bg-green-100 text-green-700 px-3 py-1 rounded-lg hover:bg-green-200">
                                                Start
                                            </button>
                                        </div>
                                    </div>
                                    <div class="mt-2 flex items-center text-xs text-gray-500">
                                        <i class="fas fa-syringe mr-1"></i><%= schedule.vaccine?.name %> |
                                        <i class="fas fa-tag ml-2 mr-1"></i>Dose <%= schedule.doseNumber %>/<%= schedule.totalDosesRequired %>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="p-8 text-center text-gray-500">
                                <i class="fas fa-calendar-check text-4xl mb-3 text-gray-400"></i>
                                <p>No schedules for today</p>
                                <p class="text-sm mt-2">Enjoy your day!</p>
                            </div>
                        <% } %>
                    </div>
                    
                    <div class="px-6 py-3 bg-gray-50 dark:bg-gray-700">
                        <a href="/paravet/tasks" class="text-sm text-blue-600 hover:text-blue-800 flex items-center">
                            <i class="fas fa-calendar-week mr-1"></i>
                            View all schedules
                            <i class="fas fa-arrow-right ml-2 text-xs"></i>
                        </a>
                    </div>
                </div>

                <!-- This Week's Schedule -->
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
                    <div class="px-6 py-4 bg-gradient-to-r from-green-500 to-green-600 text-white flex justify-between items-center">
                        <h3 class="font-semibold flex items-center">
                            <i class="fas fa-calendar-week mr-2"></i>
                            This Week
                        </h3>
                    </div>
                    
                    <div class="divide-y divide-gray-200 dark:divide-gray-700">
                        <% if (upcomingSchedules && upcomingSchedules.length > 0) { %>
                            <% 
                            const groupedByDay = {};
                            upcomingSchedules.forEach(s => {
                                const day = moment(s.scheduledDate).format('dddd, DD MMM');
                                if (!groupedByDay[day]) groupedByDay[day] = [];
                                groupedByDay[day].push(s);
                            });
                            %>
                            <% Object.entries(groupedByDay).forEach(([day, schedules]) => { %>
                                <div class="p-4">
                                    <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"><%= day %></h4>
                                    <% schedules.forEach(schedule => { %>
                                        <div class="ml-4 mb-2 p-2 hover:bg-gray-50 rounded-lg">
                                            <div class="flex justify-between items-center">
                                                <div>
                                                    <p class="text-sm font-medium">
                                                        <%= schedule.farmer?.name %> - <%= schedule.animal?.name %>
                                                    </p>
                                                    <p class="text-xs text-gray-500"><%= schedule.vaccine?.name %></p>
                                                </div>
                                                <span class="text-xs bg-gray-100 px-2 py-1 rounded">
                                                    <%= moment(schedule.scheduledDate).format('h:mm A') %>
                                                </span>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="p-8 text-center text-gray-500">
                                <i class="fas fa-calendar-week text-4xl mb-3 text-gray-400"></i>
                                <p>No upcoming schedules this week</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Right Column - Stats & Recent Activity -->
            <div class="space-y-6">
                <!-- Performance Card -->
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
                    <div class="px-6 py-4 bg-gradient-to-r from-purple-500 to-purple-600 text-white">
                        <h3 class="font-semibold flex items-center">
                            <i class="fas fa-chart-line mr-2"></i>
                            Performance
                        </h3>
                    </div>
                    
                    <div class="p-6">
                        <div class="space-y-4">
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-gray-600 dark:text-gray-400">This Week's Target</span>
                                    <span class="font-semibold"><%= stats.completedThisWeek || 0 %>/50</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="progress-bar bg-purple-600 h-2 rounded-full" 
                                         style="width: <%= Math.min((stats.completedThisWeek || 0) / 50 * 100, 100) %>%"></div>
                                </div>
                            </div>
                            
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-gray-600 dark:text-gray-400">Monthly Goal</span>
                                    <span class="font-semibold"><%= stats.totalCompleted || 0 %>/200</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="progress-bar bg-green-600 h-2 rounded-full" 
                                         style="width: <%= Math.min((stats.totalCompleted || 0) / 200 * 100, 100) %>%"></div>
                                </div>
                            </div>
                            
                            <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
                                <div class="flex justify-between items-center">
                                    <span class="text-gray-600 dark:text-gray-400">Earnings This Month</span>
                                    <span class="text-xl font-bold text-green-600">₹<%= (performanceMetrics?.reduce((sum, d) => sum + (d.totalAmount || 0), 0) || 0).toLocaleString() %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
                    <div class="px-6 py-4 bg-gradient-to-r from-orange-500 to-orange-600 text-white">
                        <h3 class="font-semibold flex items-center">
                            <i class="fas fa-history mr-2"></i>
                            Recent Activity
                        </h3>
                    </div>
                    
                    <div class="divide-y divide-gray-200 dark:divide-gray-700">
                        <% if (recentActivities && recentActivities.length > 0) { %>
                            <% recentActivities.slice(0, 5).forEach(activity => { %>
                                <div class="p-4 hover:bg-gray-50 dark:hover:bg-gray-700">
                                    <div class="flex items-start space-x-3">
                                        <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
                                            <i class="fas fa-check text-green-600 text-xs"></i>
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-sm text-gray-900 dark:text-white">
                                                <%= activity.animal?.name %> vaccinated
                                            </p>
                                            <p class="text-xs text-gray-500 dark:text-gray-400">
                                                <%= activity.farmer?.name %> • <%= activity.vaccine?.name %>
                                            </p>
                                            <p class="text-xs text-gray-400 mt-1">
                                                <%= moment(activity.dateAdministered).fromNow() %>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="p-8 text-center text-gray-500">
                                <i class="fas fa-history text-4xl mb-3 text-gray-400"></i>
                                <p>No recent activity</p>
                            </div>
                        <% } %>
                    </div>
                    
                    <div class="px-6 py-3 bg-gray-50 dark:bg-gray-700">
                        <a href="/paravet/recent" class="text-sm text-orange-600 hover:text-orange-800 flex items-center">
                            View all activity
                            <i class="fas fa-arrow-right ml-2"></i>
                        </a>
                    </div>
                </div>

                <!-- Quick Stats -->
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
                    <h3 class="font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                        <i class="fas fa-chart-pie mr-2 text-blue-500"></i>
                        Quick Stats
                    </h3>
                    
                    <div class="space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-600 dark:text-gray-400">Average per day</span>
                            <span class="font-semibold"><%= Math.round((stats.totalCompleted || 0) / 30) || 0 %></span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-600 dark:text-gray-400">Completion rate</span>
                            <span class="font-semibold text-green-600">
                                <%= stats.totalCompleted ? Math.round((stats.totalCompleted / (stats.totalCompleted + stats.pendingVaccinations)) * 100) : 0 %>%
                            </span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-600 dark:text-gray-400">Farmers served</span>
                            <span class="font-semibold"><%= stats.totalFarmers %></span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-600 dark:text-gray-400">Animals vaccinated</span>
                            <span class="font-semibold"><%= stats.totalAnimals %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Start Visit Modal -->
<div id="startVisitModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-lg bg-white dark:bg-gray-800">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Start Farmer Visit</h3>
            <button onclick="closeModal('startVisitModal')" class="text-gray-400 hover:text-gray-600">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <form id="startVisitForm" onsubmit="submitStartVisit(event)">
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Select Farmer
                </label>
                <select id="visitFarmerId" class="w-full px-3 py-2 border border-gray-300 rounded-lg" required>
                    <option value="">Choose farmer...</option>
                    <% paravet.assignedFarmers.forEach(farmer => { %>
                        <option value="<%= farmer._id %>">
                            <%= farmer.name %> - <%= farmer.address?.village || 'N/A' %>
                        </option>
                    <% }); %>
                </select>
            </div>
            
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Purpose of Visit
                </label>
                <select id="visitPurpose" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
                    <option value="vaccination">Vaccination</option>
                    <option value="followup">Follow-up</option>
                    <option value="emergency">Emergency</option>
                    <option value="other">Other</option>
                </select>
            </div>
            
            <div class="flex justify-end space-x-3">
                <button type="button" onclick="closeModal('startVisitModal')" 
                        class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                    Start Visit
                </button>
            </div>
        </form>
    </div>
</div>

<script>
$(document).ready(function() {
    // Auto-refresh data every 5 minutes
    setInterval(refreshStats, 300000);
});

function refreshStats() {
    $.get('/paravet/api/stats', function(response) {
        if (response.success) {
            // Update stats in UI
            console.log('Stats refreshed:', response.stats);
        }
    });
}

function startVisit() {
    $('#startVisitModal').removeClass('hidden');
}

function submitStartVisit(event) {
    event.preventDefault();
    
    const farmerId = $('#visitFarmerId').val();
    const purpose = $('#visitPurpose').val();
    
    if (!farmerId) {
        Swal.fire({
            icon: 'warning',
            title: 'No Farmer Selected',
            text: 'Please select a farmer'
        });
        return;
    }
    
    $.ajax({
        url: '/paravet/visit/start',
        method: 'POST',
        data: JSON.stringify({ farmerId, purpose }),
        contentType: 'application/json',
        success: function(response) {
            if (response.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Visit Started!',
                    text: 'Redirecting to farmer page...',
                    timer: 1500
                }).then(() => {
                    window.location.href = `/paravet/farmer/${farmerId}/animals`;
                });
            }
        },
        error: function() {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to start visit'
            });
        }
    });
}

