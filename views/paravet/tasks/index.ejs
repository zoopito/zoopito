<% layout("layouts/boilerplate", {
    title: 'My Tasks - Zoopito',
    description: 'Manage your daily tasks and schedules',
    pageStyles: `
        .task-card {
            transition: all 0.3s ease;
        }
        .task-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
        }
        .priority-high { border-left-color: #ef4444; }
        .priority-medium { border-left-color: #f59e0b; }
        .priority-low { border-left-color: #10b981; }
        .task-status {
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .status-pending { background-color: #fef3c7; color: #92400e; }
        .status-in-progress { background-color: #dbeafe; color: #1e40af; }
        .status-completed { background-color: #d1fae5; color: #065f46; }
        .status-overdue { background-color: #fee2e2; color: #991b1b; }
        .filter-btn {
            transition: all 0.2s ease;
        }
        .filter-btn.active {
            background-color: #3b82f6;
            color: white;
        }
        .date-group {
            position: sticky;
            top: 0;
            background: white;
            z-index: 10;
            padding: 12px 0;
        }
        .dark .date-group {
            background: #1f2937;
        }
        .complete-btn {
            transition: all 0.3s ease;
        }
        .complete-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
        }
    `
}) -%>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Page Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">My Tasks</h1>
            <p class="text-gray-600 dark:text-gray-400 mt-2">Complete vaccination tasks and record details</p>
        </div>

        <!-- Stats Overview -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Total Tasks</p>
                        <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= totalTasks || 0 %></p>
                    </div>
                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-tasks text-blue-600"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Today's Tasks</p>
                        <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= todayTasks || 0 %></p>
                    </div>
                    <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-calendar-day text-green-600"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Upcoming</p>
                        <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= upcomingTasks || 0 %></p>
                    </div>
                    <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-calendar-week text-purple-600"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Overdue</p>
                        <p class="text-2xl font-bold text-red-600"><%= overdueTasks || 0 %></p>
                    </div>
                    <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-exclamation-triangle text-red-600"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-6 p-4">
            <div class="flex flex-wrap gap-2">
                <button class="filter-btn px-4 py-2 rounded-lg text-sm font-medium transition-all <%= !currentFilter || currentFilter === 'all' ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300' %>" onclick="filterTasks('all')">
                    <i class="fas fa-list mr-1"></i>All Tasks
                </button>
                <button class="filter-btn px-4 py-2 rounded-lg text-sm font-medium transition-all <%= currentFilter === 'today' ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300' %>" onclick="filterTasks('today')">
                    <i class="fas fa-calendar-day mr-1"></i>Today
                </button>
                <button class="filter-btn px-4 py-2 rounded-lg text-sm font-medium transition-all <%= currentFilter === 'upcoming' ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300' %>" onclick="filterTasks('upcoming')">
                    <i class="fas fa-calendar-week mr-1"></i>Upcoming
                </button>
                <button class="filter-btn px-4 py-2 rounded-lg text-sm font-medium transition-all <%= currentFilter === 'overdue' ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300' %>" onclick="filterTasks('overdue')">
                    <i class="fas fa-exclamation-circle mr-1"></i>Overdue
                </button>
                <button class="filter-btn px-4 py-2 rounded-lg text-sm font-medium transition-all <%= currentFilter === 'completed' ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300' %>" onclick="filterTasks('completed')">
                    <i class="fas fa-check-circle mr-1"></i>Completed
                </button>
            </div>
        </div>

        <!-- Area Filter -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-6 p-4">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Filter by Area</label>
            <div class="flex flex-wrap gap-2">
                <button class="area-filter-btn px-3 py-1.5 rounded-lg text-sm transition-all <%= !selectedArea || selectedArea === 'all' ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-700' %>" onclick="filterByArea('all')">
                    All Areas
                </button>
                <% if(availableAreas && availableAreas.length > 0) { %>
                    <% availableAreas.forEach(area => { %>
                        <button class="area-filter-btn px-3 py-1.5 rounded-lg text-sm transition-all <%= selectedArea === (area.village || area) ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-700' %>" onclick="filterByArea('<%= area.village || area %>')">
                            <i class="fas fa-map-marker-alt mr-1"></i>
                            <%= area.village || area %>
                            <% if(pendingByArea && pendingByArea.find(a => a._id === (area.village || area))) { %>
                                <span class="ml-1 px-1.5 py-0.5 bg-red-500 text-white rounded-full text-xs">
                                    <%= pendingByArea.find(a => a._id === (area.village || area)).count %>
                                </span>
                            <% } %>
                        </button>
                    <% }); %>
                <% } %>
            </div>
        </div>

        <!-- Tasks List -->
        <div id="tasksList" class="space-y-6">
            <% if (groupedTasks && Object.keys(groupedTasks).length > 0) { %>
                <% Object.entries(groupedTasks).forEach(([date, tasks]) => { %>
                    <% if (tasks && tasks.length > 0) { %>
                        <div>
                            <div class="date-group mb-3">
                                <h2 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center">
                                    <i class="fas fa-calendar-alt mr-2 text-blue-500"></i>
                                    <%= date %>
                                    <span class="ml-2 text-sm bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded"><%= tasks.length %> tasks</span>
                                </h2>
                            </div>
                            <div class="space-y-3">
                                <% tasks.forEach(task => { %>
                                    <div class="task-card bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border-l-4 priority-<%= task.priority %>">
                                        <div class="p-5">
                                            <div class="flex items-start justify-between">
                                                <div class="flex-1">
                                                    <div class="flex items-center gap-2 mb-2 flex-wrap">
                                                        <span class="task-status status-<%= task.status %>">
                                                            <i class="fas <%= task.status === 'completed' ? 'fa-check-circle' : 'fa-clock' %> mr-1"></i>
                                                            <%= task.status ? task.status.charAt(0).toUpperCase() + task.status.slice(1) : 'Pending' %>
                                                        </span>
                                                        <span class="text-xs px-2 py-1 rounded-full <%= task.priority === 'high' ? 'bg-red-100 text-red-700' : task.priority === 'medium' ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700' %>">
                                                            <i class="fas fa-flag mr-1"></i><%= task.priority || 'normal' %>
                                                        </span>
                                                        <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700">
                                                            <i class="fas fa-syringe mr-1"></i>Vaccination
                                                        </span>
                                                    </div>
                                                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2"><%= task.title %></h3>
                                                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-3"><%= task.description || 'No description provided' %></p>
                                                    <div class="flex flex-wrap gap-4 text-sm text-gray-500 dark:text-gray-400">
                                                        <span><i class="fas fa-user mr-1"></i><%= task.farmer?.name || 'N/A' %></span>
                                                        <span><i class="fas fa-map-marker-alt mr-1"></i><%= task.farmer?.address?.village || task.location || 'Not specified' %></span>
                                                        <span><i class="fas fa-clock mr-1"></i><%= moment(task.scheduledDate).format('DD MMM YYYY, hh:mm A') %></span>
                                                        <% if (task.scheduledDate && new Date(task.scheduledDate) < new Date() && task.status !== 'completed') { %>
                                                            <span class="text-red-600"><i class="fas fa-exclamation-circle mr-1"></i>Overdue</span>
                                                        <% } %>
                                                    </div>
                                                    
                                                    <!-- Vaccines to Administer -->
                                                    <% if (task.vaccines && task.vaccines.length > 0) { %>
                                                        <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700">
                                                            <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Vaccines to administer:</p>
                                                            <div class="flex flex-wrap gap-1">
                                                                <% task.vaccines.forEach(vaccine => { %>
                                                                    <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded-full">
                                                                        <i class="fas fa-syringe mr-1 text-green-600"></i>
                                                                        <%= vaccine.vaccineId?.name || vaccine.name || 'Unknown Vaccine' %>
                                                                        <% if(vaccine.doseNumber) { %> (Dose <%= vaccine.doseNumber %>)<% } %>
                                                                    </span>
                                                                <% }); %>
                                                            </div>
                                                        </div>
                                                    <% } %>
                                                </div>
                                                
                                                <div class="flex items-center ml-4">
                                                    <% if (task.status !== 'completed') { %>
    <button onclick="completeTask('<%= task._id %>')" 
            class="complete-btn px-6 py-2.5 bg-gradient-to-r from-green-500 to-green-600 text-white font-medium rounded-lg hover:from-green-600 hover:to-green-700 transition-all shadow-md">
        <i class="fas fa-syringe mr-2"></i> Complete Vaccination
    </button>
<% } else { %>
    <button class="px-6 py-2.5 bg-gray-300 text-gray-600 rounded-lg cursor-not-allowed text-sm font-medium" disabled>
        <i class="fas fa-check-circle mr-2"></i> Completed
    </button>
<% } %>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                <% }); %>
            <% } else { %>
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-12 text-center">
                    <i class="fas fa-check-circle text-6xl text-green-500 mb-4"></i>
                    <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">No Tasks Found</h3>
                    <p class="text-gray-600 dark:text-gray-400">
                        You have no pending tasks. Great job! 🎉
                    </p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function filterTasks(filter) {
    window.location.href = `/paravet/tasks?filter=${filter}`;
}

function filterByArea(area) {
    const currentFilter = new URLSearchParams(window.location.search).get('filter') || 'all';
    window.location.href = `/paravet/tasks?filter=${currentFilter}&area=${area}`;
}

function completeTask(taskId, farmerId, animalId) {
    // Directly redirect to vaccination form with task details
    window.location.href = `/paravet/tasks/${taskId}/complete`;
}
</script>