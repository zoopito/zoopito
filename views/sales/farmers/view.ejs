<% layout("layouts/boilerplate") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Back Button & Header -->
    <div class="mb-6">
      <a href="/sales/farmers" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Farmers
      </a>
      
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="w-20 h-20 rounded-full bg-gradient-to-r from-blue-500 to-blue-600 flex items-center justify-center text-white text-3xl font-bold shadow-lg">
            <%= farmer.name ? farmer.name.charAt(0).toUpperCase() : 'F' %>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= farmer.name %></h1>
            <div class="flex flex-wrap gap-2 mt-1">
              <span class="inline-flex items-center gap-1 px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-800">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <%= farmer.uniqueFarmerId %>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-1 text-xs rounded-full bg-green-100 text-green-800">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                <%= farmer.isActive ? 'Active' : 'Inactive' %>
              </span>
            </div>
          </div>
        </div>
        
        <div class="flex gap-3">
          <a href="/sales/farmers/<%= farmer._id %>/edit" 
             class="inline-flex items-center gap-2 px-4 py-2 bg-amber-500 text-white rounded-lg hover:bg-amber-600 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Edit Details
          </a>
          <button onclick="toggleStatus('<%= farmer._id %>', '<%= farmer.isActive %>')" 
                  class="inline-flex items-center gap-2 px-4 py-2 <%= farmer.isActive ? 'bg-red-500 hover:bg-red-600' : 'bg-green-500 hover:bg-green-600' %> text-white rounded-lg transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= farmer.isActive ? 'Deactivate' : 'Activate' %>
          </button>
        </div>
      </div>
    </div>

    <!-- Farmer Information Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Contact Info -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase mb-4">Contact Information</h3>
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <div>
              <p class="text-sm text-gray-500">Mobile Number</p>
              <p class="font-medium text-gray-900 dark:text-white"><%= farmer.mobileNumber || 'Not provided' %></p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <div>
              <p class="text-sm text-gray-500">Email</p>
              <p class="font-medium text-gray-900 dark:text-white"><%= farmer.email || 'Not provided' %></p>
            </div>
          </div>
          <% if (farmer.assignedParavet?.user) { %>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <div>
                <p class="text-sm text-gray-500">Assigned Paravet</p>
                <p class="font-medium text-gray-900 dark:text-white"><%= farmer.assignedParavet.user.name %></p>
              </div>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Address Info -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase mb-4">Address</h3>
        <div class="space-y-2">
          <% if (farmer.address?.village) { %>
            <p class="text-gray-900 dark:text-white"><%= farmer.address.village %></p>
            <p class="text-sm text-gray-500"><%= farmer.address.taluka ? farmer.address.taluka + ', ' : '' %><%= farmer.address.district || '' %></p>
            <p class="text-sm text-gray-500"><%= farmer.address.state || '' %> <%= farmer.address.pincode || '' %></p>
          <% } else { %>
            <p class="text-gray-500">No address provided</p>
          <% } %>
          
          <% if (hasLocation) { %>
            <div class="mt-3">
              <a href="<%= mapUrl %>" target="_blank" class="inline-flex items-center gap-2 text-sm text-blue-600 hover:text-blue-700">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                </svg>
                View Location on Map
              </a>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Registration Info -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase mb-4">Registration Details</h3>
        <div class="space-y-3">
          <div>
            <p class="text-sm text-gray-500">Registered On</p>
            <p class="font-medium text-gray-900 dark:text-white"><%= moment(farmer.createdAt).format('DD MMM YYYY, hh:mm A') %></p>
          </div>
          <div>
            <p class="text-sm text-gray-500">Registered By</p>
            <p class="font-medium text-gray-900 dark:text-white"><%= currentUser.name %></p>
          </div>
          <div>
            <p class="text-sm text-gray-500">Last Updated</p>
            <p class="font-medium text-gray-900 dark:text-white"><%= moment(farmer.updatedAt).format('DD MMM YYYY, hh:mm A') %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Animal Statistics Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-200 dark:border-gray-700">
        <p class="text-2xl font-bold text-blue-600"><%= animalStats.total %></p>
        <p class="text-xs text-gray-500">Total Animals</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-200 dark:border-gray-700">
        <p class="text-2xl font-bold text-green-600"><%= animalStats.healthy %></p>
        <p class="text-xs text-gray-500">Healthy</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-200 dark:border-gray-700">
        <p class="text-2xl font-bold text-purple-600"><%= animalStats.vaccinated %></p>
        <p class="text-xs text-gray-500">Vaccinated</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-200 dark:border-gray-700">
        <p class="text-2xl font-bold text-pink-600"><%= animalStats.pregnant %></p>
        <p class="text-xs text-gray-500">Pregnant</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-200 dark:border-gray-700">
        <p class="text-2xl font-bold text-blue-400"><%= animalStats.male %></p>
        <p class="text-xs text-gray-500">Male</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-200 dark:border-gray-700">
        <p class="text-2xl font-bold text-pink-400"><%= animalStats.female %></p>
        <p class="text-xs text-gray-500">Female</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-200 dark:border-gray-700">
        <p class="text-2xl font-bold text-orange-600"><%= vaccinationRate %>%</p>
        <p class="text-xs text-gray-500">Vaccination Rate</p>
      </div>
    </div>

    <!-- Animals Section -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 mb-8">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 flex justify-between items-center flex-wrap gap-3">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
          <i class="fas fa-paw mr-2"></i>Animals (<%= animals.length %>)
        </h2>
        <a href="/sales/animals/new?farmerId=<%= farmer._id %>" 
           class="inline-flex items-center gap-2 px-3 py-1.5 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add Animal
        </a>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-100 dark:bg-gray-700">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase">Animal</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase hidden md:table-cell">Type/Breed</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase">Tag/ID</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase hidden lg:table-cell">Health</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase">Vaccination</th>
              <th class="px-4 py-3 text-center text-xs font-semibold uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y dark:divide-gray-700">
            <% if (animals.length === 0) { %>
              <tr>
                <td colspan="6" class="px-4 py-8 text-center text-gray-500">
                  No animals added yet. <a href="/sales/animals/new?farmerId=<%= farmer._id %>" class="text-blue-600">Add first animal</a>
                </td>
              </tr>
            <% } %>
            <% animals.forEach(animal => { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                <td class="px-4 py-3">
                  <div>
                    <p class="font-medium text-gray-900 dark:text-white"><%= animal.name || 'Unnamed' %></p>
                    <p class="text-xs text-gray-500"><%= animal.gender %></p>
                  </div>
                </td>
                <td class="px-4 py-3 hidden md:table-cell">
                  <p><%= animal.animalType %></p>
                  <p class="text-xs text-gray-500"><%= animal.breed || 'Unknown breed' %></p>
                </td>
                <td class="px-4 py-3">
                  <code class="text-xs bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded"><%= animal.tagNumber || 'Not tagged' %></code>
                  <p class="text-xs text-gray-500 mt-1">ID: <%= animal.uniqueAnimalId %></p>
                </td>
                <td class="px-4 py-3 hidden lg:table-cell">
                  <% if (animal.healthStatus?.currentStatus === 'Healthy') { %>
                    <span class="px-2 py-1 text-xs bg-green-100 text-green-800 rounded-full">Healthy</span>
                  <% } else if (animal.healthStatus?.currentStatus === 'Under Treatment') { %>
                    <span class="px-2 py-1 text-xs bg-yellow-100 text-yellow-800 rounded-full">Under Treatment</span>
                  <% } else { %>
                    <span class="px-2 py-1 text-xs bg-gray-100 text-gray-800 rounded-full"><%= animal.healthStatus?.currentStatus || 'Unknown' %></span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <% if (animal.vaccinationSummary?.isUpToDate) { %>
                    <span class="text-green-600 text-sm">✓ Up to date</span>
                  <% } else if (animal.nextVaccination) { %>
                    <span class="text-amber-600 text-sm">Due: <%= moment(animal.nextVaccination.nextDueDate).format('DD MMM') %></span>
                  <% } else { %>
                    <span class="text-gray-500 text-sm">No records</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-center">
                  <a href="/sales/animals/<%= animal._id %>" class="text-blue-600 hover:text-blue-700" title="View Details">
                    <svg class="w-5 h-5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Vaccination Summary Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      <!-- Upcoming Vaccinations -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            <svg class="w-5 h-5 inline mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Upcoming Vaccinations
          </h2>
        </div>
        <div class="divide-y dark:divide-gray-700 max-h-80 overflow-y-auto">
          <% if (upcomingVaccinations.length === 0) { %>
            <div class="px-6 py-8 text-center text-gray-500">
              No upcoming vaccinations scheduled
            </div>
          <% } %>
          <% upcomingVaccinations.slice(0, 10).forEach(vac => { %>
            <div class="px-6 py-4 hover:bg-gray-50 dark:hover:bg-gray-700/50">
              <div class="flex justify-between items-start">
                <div>
                  <p class="font-medium text-gray-900 dark:text-white"><%= vac.vaccine?.name || vac.vaccineName %></p>
                  <p class="text-sm text-gray-500">Animal: <%= vac.animal?.name || vac.animal?.tagNumber %></p>
                </div>
                <div class="text-right">
                  <p class="text-sm <%= new Date(vac.nextDueDate) < new Date() ? 'text-red-600' : 'text-amber-600' %>">
                    <%= moment(vac.nextDueDate).format('DD MMM YYYY') %>
                  </p>
                  <p class="text-xs text-gray-500">Due in <%= moment(vac.nextDueDate).fromNow() %></p>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Recent Activities -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            <svg class="w-5 h-5 inline mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            Recent Activities
          </h2>
        </div>
        <div class="divide-y dark:divide-gray-700 max-h-80 overflow-y-auto">
          <% if (activities.length === 0) { %>
            <div class="px-6 py-8 text-center text-gray-500">
              No recent activities
            </div>
          <% } %>
          <% activities.forEach(activity => { %>
            <div class="px-6 py-4 hover:bg-gray-50 dark:hover:bg-gray-700/50">
              <div class="flex gap-3">
                <div class="flex-shrink-0">
                  <% if (activity.type === 'vaccination') { %>
                    <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center">
                      <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                  <% } else { %>
                    <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                      <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                      </svg>
                    </div>
                  <% } %>
                </div>
                <div class="flex-1">
                  <p class="text-sm font-medium text-gray-900 dark:text-white"><%= activity.title %></p>
                  <p class="text-xs text-gray-500"><%= activity.description %></p>
                  <p class="text-xs text-gray-400 mt-1"><%= moment(activity.timestamp).fromNow() %></p>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Vaccination History Table -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
          <svg class="w-5 h-5 inline mr-2 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          Vaccination History
        </h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-100 dark:bg-gray-700">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase">Date</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase">Vaccine</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase">Animal</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase">Next Due</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y dark:divide-gray-700">
            <% if (vaccinations.length === 0) { %>
              <tr>
                <td colspan="5" class="px-4 py-8 text-center text-gray-500">
                  No vaccination records found
                </td>
              </tr>
            <% } %>
            <% vaccinations.slice(0, 10).forEach(vac => { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                <td class="px-4 py-3 text-sm"><%= moment(vac.dateAdministered || vac.createdAt).format('DD MMM YYYY') %></td>
                <td class="px-4 py-3">
                  <p class="font-medium"><%= vac.vaccine?.name || vac.vaccineName %></p>
                  <p class="text-xs text-gray-500"><%= vac.vaccineType %></p>
                </td>
                <td class="px-4 py-3"><%= vac.animal?.name || vac.animal?.tagNumber || 'Unknown' %></td>
                <td class="px-4 py-3">
                  <%= vac.nextDueDate ? moment(vac.nextDueDate).format('DD MMM YYYY') : '-' %>
                </td>
                <td class="px-4 py-3">
                  <% if (vac.status === 'Completed') { %>
                    <span class="px-2 py-1 text-xs bg-green-100 text-green-800 rounded-full">Completed</span>
                  <% } else if (vac.status === 'Scheduled') { %>
                    <span class="px-2 py-1 text-xs bg-blue-100 text-blue-800 rounded-full">Scheduled</span>
                  <% } else if (vac.status === 'Payment Pending') { %>
                    <span class="px-2 py-1 text-xs bg-yellow-100 text-yellow-800 rounded-full">Payment Pending</span>
                  <% } else { %>
                    <span class="px-2 py-1 text-xs bg-gray-100 text-gray-800 rounded-full"><%= vac.status %></span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  async function toggleStatus(id, currentStatus) {
    const action = currentStatus ? 'deactivate' : 'activate';
    if (!confirm(`Are you sure you want to ${action} this farmer?`)) return;
    
    try {
      const res = await fetch(`/sales/farmers/${id}/toggle-status`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json();
      if (data.success) {
        window.location.reload();
      } else {
        alert(data.message);
      }
    } catch (err) {
      alert('Failed to update status');
    }
  }
</script>